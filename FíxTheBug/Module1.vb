                            dbo.cliente ON dbo.cliente_bodega.IdCliente = dbo.cliente.IdCliente ON dbo.trans_pe_enc.IdCliente = dbo.cliente.IdCliente
                    WHERE  (CONVERT(DATE,dbo.trans_pe_enc.Fecha_Pedido) BETWEEN '20230411' AND '20230811')
                    GROUP BY dbo.trans_pe_enc.IdPedidoEnc, dbo.propietarios.nombre_comercial, dbo.cliente.nombre_comercial, dbo.trans_pe_enc.IdBodega, 
