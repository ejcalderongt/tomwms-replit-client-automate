<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSources>
		<!-- Origen principal para paquetes públicos -->
		<add key="nuget.org" value="https://api.nuget.org/v3/index.json" />

		<!-- Alternativamente, use the DevExpress NuGet Feed: https://nuget.devexpress.com -->

		<!-- Origen local de DevExtreme/DevExpress.
         Corregido para tu versión instalada 24.2.12 -->
		<add key="devextreme-controls-netcore"
			 value="C:\Program Files\DevExpress 24.2\DevExtreme\System\DevExtreme\Bin\AspNetCore" />
	</packageSources>

	<!-- PackageSourceMapping habilitado -->
	<packageSourceMapping>
		<packageSource key="nuget.org">
			<package pattern="Microsoft.*" />
			<package pattern="System.*" />
			<package pattern="Serilog*" />
			<package pattern="Swashbuckle.AspNetCore*" />
			<package pattern="NSwag.*" />
			<package pattern="AutoMapper*" />
			<package pattern="Humanizer.*" />
			<package pattern="Mono.TextTemplating*" />
			<package pattern="Newtonsoft.Json*" />
		</packageSource>

		<!-- Mapeo para paquetes locales de DevExpress/DevExtreme -->
		<packageSource key="devextreme-controls-netcore">
			<package pattern="DevExpress.*" />
			<package pattern="DevExtreme.*" />
		</packageSource>

		<!-- Si prefieres usar solo el feed online de DevExpress, comenta el source local de arriba
         y agrega aquí el mapping para https://nuget.devexpress.com -->
	</packageSourceMapping>
</configuration>
