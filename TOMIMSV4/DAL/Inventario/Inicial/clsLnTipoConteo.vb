Imports System.Data.SqlClient
Imports System.Reflection

Public Class clsLnTipoConteo

    Public Shared Sub Cargar(ByRef oBeTipoConteo As clsBeTipoConteo, ByRef dr As DataRow)
        Try
            With oBeTipoConteo
                .IdTipoConteo = IIf(IsDBNull(dr.Item("IdTipoConteo")), 0, dr.Item("IdTipoConteo"))
                .Descripcion = IIf(IsDBNull(dr.Item("Descripcion")), "", dr.Item("Descripcion"))
            End With
        Catch ex As Exception
            Throw New Exception(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message))
        End Try
    End Sub

    Public Shared Function Insertar(ByRef oBeTipoConteo As clsBeTipoConteo, Optional ByVal pConection as SqlConnection = Nothing, Optional Byval pTransaction as SqlTransaction = Nothing) As Integer

        Dim lConnection As New SqlConnection(Configuration.ConfigurationManager.AppSettings("CST"))
        Dim lTransaction As SqlTransaction = Nothing

        Try

            Ins.Init("tipoconteo")
            Ins.Add("idtipoconteo", "@idtipoconteo", DataType.Parametro)
            Ins.Add("descripcion", "@descripcion", DataType.Parametro)

            Dim sp As String = Ins.SQL()
            Dim cmd As New SqlCommand(sp, lConnection) With {.CommandType = CommandType.Text}

            Dim Es_Transaccion_Remota As Boolean = (pConection IsNot Nothing AndAlso pTransaction IsNot Nothing)

            If Es_Transaccion_Remota Then
                cmd = New SqlCommand(sp, pConection)
                cmd.Transaction = pTransaction
            Else
                lConnection.Open() : lTransaction = lConnection.BeginTransaction(IsolationLevel.ReadCommitted)
                cmd = New SqlCommand(sp, lConnection, lTransaction)
            End If

            cmd.Parameters.Add(New SqlParameter("@IDTIPOCONTEO", oBeTipoConteo.IdTipoConteo))
            cmd.Parameters.Add(New SqlParameter("@DESCRIPCION", oBeTipoConteo.Descripcion))

            Dim rowsAffected As Integer = cmd.ExecuteNonQuery()

            cmd.Dispose()

            If Not Es_Transaccion_Remota Then lTransaction.Commit()

            Return rowsAffected

            oBeTipoConteo.IdTipoConteo = CInt(cmd.Parameters("@IDTIPOCONTEO").Value)

        Catch ex As Exception
            If lTransaction IsNot Nothing Then lTransaction.Rollback()
            Throw ex
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close()
            If lTransaction IsNot Nothing Then lTransaction.Dispose()
        End Try

    End Function

