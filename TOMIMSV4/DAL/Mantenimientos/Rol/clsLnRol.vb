Imports System.Data.SqlClient
Imports System.Reflection

Public Class clsLnRol

    Public Shared Sub Cargar(ByRef oBeRol As clsBeRol, ByRef dr As DataRow)
        Try
            With oBeRol
                .IdRol = IIf(IsDBNull(dr.Item("IdRol")), 0, dr.Item("IdRol"))
                .IdEmpresa = IIf(IsDBNull(dr.Item("IdEmpresa")), 0, dr.Item("IdEmpresa"))
                .Nombre = IIf(IsDBNull(dr.Item("nombre")), "", dr.Item("nombre"))
                .User_agr = IIf(IsDBNull(dr.Item("user_agr")), "", dr.Item("user_agr"))
                .Fec_agr = IIf(IsDBNull(dr.Item("fec_agr")), Date.Now, dr.Item("fec_agr"))
                .User_mod = IIf(IsDBNull(dr.Item("user_mod")), "", dr.Item("user_mod"))
                .Fec_mod = IIf(IsDBNull(dr.Item("fec_mod")), Date.Now, dr.Item("fec_mod"))
                .Activo = IIf(IsDBNull(dr.Item("activo")), False, dr.Item("activo"))
                .Registrar_clave_autorizacion = IIf(IsDBNull(dr.Item("registrar_clave_autorizacion")), False, dr.Item("registrar_clave_autorizacion"))
            End With

        Catch ex1 As SQLException
            Throw ex1
        Catch ex As Exception
            Dim vMsgError As String = String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message)
            clsLnLog_error_wms.Agregar_Error(vMsgError)
            Throw ex
        End Try
    End Sub

    Public Shared Function Insertar(ByRef oBeRol As clsBeRol, Optional ByVal pConection as SqlConnection = Nothing, Optional Byval pTransaction as SqlTransaction = Nothing) As Integer

        Dim lConnection As New SqlConnection(Configuration.ConfigurationManager.AppSettings("CST"))
        Dim lTransaction As SqlTransaction = Nothing

        Try

            Ins.Init("rol")
            Ins.Add("idrol", "@idrol", DataType.Parametro)
            Ins.Add("idempresa", "@idempresa", DataType.Parametro)
            Ins.Add("nombre", "@nombre", DataType.Parametro)
            Ins.Add("user_agr", "@user_agr", DataType.Parametro)
            Ins.Add("fec_agr", "@fec_agr", DataType.Parametro)
            Ins.Add("user_mod", "@user_mod", DataType.Parametro)
            Ins.Add("fec_mod", "@fec_mod", DataType.Parametro)
            Ins.Add("activo", "@activo", DataType.Parametro)
            Ins.Add("registrar_clave_autorizacion", "@registrar_clave_autorizacion", DataType.Parametro)

            Dim sp As String = Ins.SQL()
            Dim cmd As New SqlCommand With {.CommandType = CommandType.Text}

            Dim Es_Transaccion_Remota As Boolean = (pConection IsNot Nothing AndAlso pTransaction IsNot Nothing)

            If Es_Transaccion_Remota Then
                cmd = New SqlCommand(sp, pConection, pTransaction)
            Else
                lConnection.Open() : lTransaction = lConnection.BeginTransaction(IsolationLevel.ReadCommitted)
                cmd = New SqlCommand(sp, lConnection, lTransaction)
            End If


            cmd.Parameters.Add(New SqlParameter("@IDROL", oBeRol.IdRol))
            cmd.Parameters.Add(New SqlParameter("@IDEMPRESA", oBeRol.IdEmpresa))
            cmd.Parameters.Add(New SqlParameter("@NOMBRE", oBeRol.Nombre))
            cmd.Parameters.Add(New SqlParameter("@USER_AGR", oBeRol.User_agr))
            cmd.Parameters.Add(New SqlParameter("@FEC_AGR", oBeRol.Fec_agr))
            cmd.Parameters.Add(New SqlParameter("@USER_MOD", oBeRol.User_mod))
            cmd.Parameters.Add(New SqlParameter("@FEC_MOD", oBeRol.Fec_mod))
            cmd.Parameters.Add(New SqlParameter("@ACTIVO", oBeRol.Activo))
            cmd.Parameters.Add(New SqlParameter("@REGISTRAR_CLAVE_AUTORIZACION", oBeRol.Registrar_clave_autorizacion))


            Dim rowsAffected As Integer = cmd.ExecuteNonQuery()

            cmd.Dispose()

            If Not Es_Transaccion_Remota Then lTransaction.Commit()

            Return rowsAffected

            oBeRol.IdRol = CInt(cmd.Parameters("@IDROL").Value)

        Catch ex1 As SqlException
            If lTransaction IsNot Nothing Then lTransaction.Rollback()
            Throw ex1
        Catch ex As Exception
            If lTransaction IsNot Nothing Then lTransaction.Rollback()
            Throw ex
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close()
            If lTransaction IsNot Nothing Then lTransaction.Dispose()
            If lConnection IsNot Nothing Then lConnection.Dispose()
        End Try

    End Function

