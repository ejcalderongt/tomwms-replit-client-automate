    End Function

    '#CKFK 20180109 07:12 PM Creé esta función para poder reservar el stock para reemplazo de producto
    Public Shared Function Reservar_Stock_By_IdStock(IdStock As Integer,
                                                     ByVal CantSol As Double,
                                                     ByVal MaquinaQueSolicita As String,
                                                     ByVal IdPickingEnc As Integer,
                                                     ByVal IdPedidoEnc As Integer,
                                                     ByVal IdUsuarioHH As Integer,
                                                     ByVal IdPedidoDet As Integer,
                                                     ByVal IdPickingUbic As Integer,
                                                     ByVal EsPicking As Boolean,
                                                     ByVal IdPresentacionPedido As Integer,
                                                     ByVal Tipo As Integer) As Boolean

        Dim lConnection As New SqlConnection(Configuration.ConfigurationManager.AppSettings("CST"))
        Dim lTransaction As SqlTransaction = Nothing

        Reservar_Stock_By_IdStock = False

        Try

            Dim lBeStockAReservar As New List(Of clsBeStock_res)
            Dim BeStock As New clsBeStock
            Dim BeStockRes As New clsBeStock_res

            If IdStock <> 0 Then

                lConnection.Open() : lTransaction = lConnection.BeginTransaction

                BeStock.IdStock = IdStock
                '#CKFK 20180331 11:25 PM Agregué la función con transaccionalidad anteriormente estaba esta clsLnStock.GetSingle(BeStock)
                BeStock = clsLnStock.GetSingle(BeStock.IdStock, lConnection, lTransaction)

                Dim vCantidadCompletada As Boolean = False
                Dim vCantidadStock As Double = 0
                Dim vCantidadPendiente As Double = 0
                Dim vCantidadSolicitadaPedido As Double = 0
                Dim vValorEnteroCantidadSolicitadaPedido As Integer = 0
                Dim vCantidadAReservarPorIdStock As Double = 0

                If IdPresentacionPedido = 0 Then
                    vCantidadSolicitadaPedido = CantSol
                Else

                    Dim BePres As New clsBeProducto_Presentacion With {.IdPresentacion = BeStock.IdPresentacion}
                    clsLnProducto_presentacion.GetSingle(BePres, lConnection, lTransaction)

                    If BePres.EsPallet Then

                        Dim vFactorPallet As Double = (BePres.Factor * BePres.CajasPorCama * BePres.CamasPorTarima)

                        If vFactorPallet > 0 Then
                            vCantidadSolicitadaPedido = CantSol * vFactorPallet
                        Else
                            Throw New Exception("No se pudo reservar el stock para el tipo de producto pallet porque los factores de conversión dan un denominador = 0")
                        End If

                    Else

                        vCantidadSolicitadaPedido = CantSol * BePres.Factor

                        If Not clsLnProducto.Tiene_Control_Por_Peso_By_IdProductoBodega(BeStock.IdProductoBodega, lConnection, lTransaction) Then

                            If Integer.TryParse(vCantidadSolicitadaPedido, vValorEnteroCantidadSolicitadaPedido) Then
                                vCantidadSolicitadaPedido = vValorEnteroCantidadSolicitadaPedido
                            Else
                                vCantidadSolicitadaPedido = Math.Truncate(vCantidadSolicitadaPedido)
                            End If

                        Else
                            vCantidadSolicitadaPedido = Math.Round(vCantidadSolicitadaPedido, 6)
                        End If

                    End If

                End If

                If Not BeStock Is Nothing Then

                    vCantidadPendiente = vCantidadSolicitadaPedido

                    vCantidadStock = BeStock.Cantidad

                    BeStockRes = New clsBeStock_res
                    BeStockRes.IdTransaccion = IdPedidoEnc
                    BeStockRes.Indicador = "PED"
                    BeStockRes.IdBodega = BeStock.IdBodega
                    BeStockRes.IdStock = BeStock.IdStock
                    BeStockRes.IdPropietarioBodega = BeStock.IdPropietarioBodega
                    BeStockRes.IdProductoBodega = BeStock.IdProductoBodega

                    If vCantidadPendiente = vCantidadStock Then
                        vCantidadAReservarPorIdStock = vCantidadStock
                        vCantidadPendiente -= vCantidadStock
                    ElseIf vCantidadPendiente < vCantidadStock Then
                        vCantidadAReservarPorIdStock = vCantidadPendiente
                        vCantidadPendiente -= vCantidadAReservarPorIdStock
                    ElseIf vCantidadPendiente > vCantidadStock Then
                        vCantidadAReservarPorIdStock = vCantidadStock
                        vCantidadPendiente -= vCantidadStock
                    End If

                    BeStockRes.IdUbicacion = BeStock.IdUbicacion
                    BeStockRes.IdProductoEstado = BeStock.IdProductoEstado
                    '#CKFK 20180219 Cambié la asignación de BeStock.Presentacion.IdPresentación por BeStosck.IdPresentacion
                    BeStockRes.IdPresentacion = IdPresentacionPedido
                    BeStockRes.IdUnidadMedida = BeStock.IdUnidadMedida
                    BeStockRes.Lote = BeStock.Lote
                    BeStockRes.Lic_plate = BeStock.Lic_plate
                    BeStockRes.Serial = BeStock.Serial
                    BeStockRes.Peso = BeStock.Peso
                    BeStockRes.Estado = "UNCOMMITED HH"
                    BeStockRes.Fecha_ingreso = BeStock.Fecha_Ingreso
                    BeStockRes.Fecha_vence = BeStock.Fecha_vence
                    BeStockRes.Uds_lic_plate = BeStock.Uds_lic_plate
                    '#CKFK 20171120 06:41PM Guardé en el campo Ubicacion_ant el id de la ubicación anterior de Stock
                    BeStockRes.Ubicacion_ant = BeStock.IdUbicacion_anterior
                    BeStockRes.No_bulto = BeStock.No_bulto
                    BeStockRes.IdRecepcion = BeStock.IdRecepcionEnc
                    BeStockRes.IdPicking = IdPickingEnc
                    BeStockRes.IdPedido = IdPedidoEnc
                    BeStockRes.IdPedidoDet = IdPedidoDet
                    BeStockRes.IdDespacho = 0
                    BeStockRes.añada = BeStock.Añada
                    BeStockRes.Fecha_manufactura = BeStock.Fecha_Manufactura
                    '#CM20181308_3:23PM:Redondea la cantidad a reservar por IdStock a 6 cifras.
                    BeStockRes.Cantidad = Math.Round(vCantidadAReservarPorIdStock, 6)
                    BeStockRes.IdRecepcion = BeStock.IdRecepcionEnc
                    '#EJC20171018_0715PM: Registrar en tabla stock_res la PC que bloqueó/reservó el stock
                    BeStockRes.Host = MaquinaQueSolicita
                    '#CKFK 20180208 08:50 PM agregué campos que faltaban en StockRes
                    BeStockRes.User_agr = IdUsuarioHH
                    BeStockRes.User_mod = IdUsuarioHH
                    vCantidadCompletada = (vCantidadPendiente = 0)

                    'pStockRes.Cantidad = vCantidadReservada
                    lBeStockAReservar.Add(BeStockRes)

                End If

                If lBeStockAReservar.Count > 0 Then

                    '#CKFK 20201129 Inserto el nuevo stock reservado
                    If Inserta_Stock_Reservado(lBeStockAReservar, lConnection, lTransaction) Then
                        Reservar_Stock_By_IdStock = True
                    Else
                        Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0006, BeStock.IdProductoBodega))
                    End If

                Else
                    Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0005, BeStock.IdProductoBodega))
                End If

                '#CKFK 20180208 11:47PM Actualizar la cantidad solicitada en trans_picking_ubic
                Dim bePickingUbicExistente As New clsBeTrans_picking_ubic With {
                    .IdPickingUbic = IdPickingUbic
                }

                clsLnTrans_picking_ubic.GetSingle(bePickingUbicExistente, lConnection, lTransaction) '#CKFK 20180331 11:25 PM Agregué la función con transaccionalidad anteriormente estaba esta clsLnTrans_picking_ubic.GetSingle(bePickingUbic

                bePickingUbicExistente.Cantidad_Solicitada -= CantSol

                If Not EsPicking Then
                    bePickingUbicExistente.Cantidad_Recibida -= CantSol
                End If

                If bePickingUbicExistente.Cantidad_Solicitada <> 0 Then

                    bePickingUbicExistente.IdStockRes = lBeStockAReservar(0).IdStockRes

                    bePickingUbicExistente.Cantidad_Solicitada = CantSol

                    bePickingUbicExistente.Acepto = 0
                    bePickingUbicExistente.Encontrado = 0

                    bePickingUbicExistente.Dañado_picking = False
                    bePickingUbicExistente.Dañado_verificacion = False

                    If Not EsPicking Then
                        bePickingUbicExistente.Cantidad_Recibida = CantSol
                    End If

                    bePickingUbicExistente.IdPickingUbic = clsLnTrans_picking_ubic.MaxID(lConnection, lTransaction) + 1

                    clsLnTrans_picking_ubic.Insertar(bePickingUbicExistente)

                ElseIf bePickingUbicExistente.Cantidad_Solicitada = 0 Then

                    bePickingUbicExistente.IdStockRes = lBeStockAReservar(0).IdStockRes

                    bePickingUbicExistente.Cantidad_Solicitada = CantSol

                    bePickingUbicExistente.Acepto = 0

                    bePickingUbicExistente.Acepto = 0
                    bePickingUbicExistente.Encontrado = 0

                    bePickingUbicExistente.Dañado_picking = False
                    bePickingUbicExistente.Dañado_verificacion = False

                    If Not EsPicking Then
                        bePickingUbicExistente.Cantidad_Recibida = CantSol
                    End If

                    bePickingUbicExistente.IdPickingUbic = clsLnTrans_picking_ubic.MaxID(lConnection, lTransaction) + 1

                    clsLnTrans_picking_ubic.Insertar(bePickingUbicExistente)

                End If

                If Not EsPicking Then

                    Dim BePickingEnc As New clsBeTrans_picking_enc
                    BePickingEnc.IdPickingEnc = clsLnTrans_picking_ubic.ObtienIdPickingEnc_Y_Verifica_Estado_PickingEnc_ByPickingUbic(IdPickingUbic, lConnection, lTransaction)

                    If BePickingEnc.IdPickingEnc <> 0 Then
                        BePickingEnc.Estado = "Pendiente"
                        clsLnTrans_picking_enc.ActualizarEstadoByRemplazo(BePickingEnc, lConnection, lTransaction)
                    End If

                End If


                '#CKFK20250317 Agregué esta validación para impedir reservas mayores a lo solicitado
                Dim listaPicking = clsLnTrans_picking_ubic.Get_All_PickingUbic_By_IdPedidoDet(IdPedidoDet,
                                                                              IdPedidoEnc,
                                                                              bePickingUbicExistente.IdBodega,
                                                                              lConnection,
                                                                              lTransaction)

                Dim cantidadPickingIdPedidoDet As Double = If(listaPicking IsNot Nothing AndAlso listaPicking.Any(),
                                              listaPicking.Sum(Function(x) x.Cantidad_Solicitada),
                                              0)
                Dim cantidadPedidoDet As Double = clsLnTrans_pe_det.Get_Single_By_IdPedidoDet(IdPedidoDet).Cantidad

                If cantidadPedidoDet < cantidadPickingIdPedidoDet AndAlso cantidadPickingIdPedidoDet > 0 Then
                    Throw New Exception("Error_Reemplazo_B: No es posible reservar más de lo solicitado")
                Else
                    lTransaction.Commit()
                End If

                'lTransaction.Commit()

            Else
                Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0004, BeStock.IdProductoBodega))
            End If

        Catch ex As Exception
            If lTransaction IsNot Nothing Then lTransaction.Rollback()
            Throw New Exception(ex.Message)
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close() : lConnection.Dispose()
            If lTransaction IsNot Nothing Then lTransaction.Dispose()
        End Try

    End Function

    '#AT 20220107 Copia de Reservar_Stock_By_IdStock
    Public Shared Function Reservar_Stock_By_Stock_Reem(ByVal Stock As clsBeStock,
                                                        ByVal CantSol As Double,
                                                        ByVal MaquinaQueSolicita As String,
                                                        ByVal IdPickingEnc As Integer,
                                                        ByVal IdPedidoEnc As Integer,
                                                        ByVal IdUsuarioHH As Integer,
                                                        ByVal IdPedidoDet As Integer,
                                                        ByVal IdPickingUbic As Integer,
                                                        ByVal EsPicking As Boolean,
                                                        ByVal IdPresentacionPedido As Integer,
                                                        ByVal Tipo As Integer,
                                                        ByRef CantidadPendiente As Double,
                                                        ByRef lConnection As SqlConnection,
                                                        ByRef lTransaction As SqlTransaction) As Boolean

        Reservar_Stock_By_Stock_Reem = False

        Try

            Dim lBeStockAReservar As New List(Of clsBeStock_res)
            Dim BeStockRes As New clsBeStock_res
            Dim RowsUpdate As Integer = 0
            Dim CantidadStockDestino As Double = 0

            If Stock IsNot Nothing Then

                Dim vCantidadCompletada As Boolean = False
                Dim vCantidadStock As Double = 0
                Dim vCantidadPendiente As Double = 0
                Dim vCantidadSolicitadaPedido As Double = 0
                Dim vValorEnteroCantidadSolicitadaPedido As Integer = 0
                Dim vCantidadAReservarPorIdStock As Double = 0

                If IdPresentacionPedido = 0 Then
                    vCantidadSolicitadaPedido = CantSol
                Else

                    Dim BePres As New clsBeProducto_Presentacion With {.IdPresentacion = Stock.IdPresentacion}
                    clsLnProducto_presentacion.GetSingle(BePres, lConnection, lTransaction)

                    If BePres.EsPallet Then

                        Dim vFactorPallet As Double = (BePres.Factor * BePres.CajasPorCama * BePres.CamasPorTarima)

                        If vFactorPallet > 0 Then
                            vCantidadSolicitadaPedido = CantSol * vFactorPallet
                        Else
                            Throw New Exception("No se pudo reservar el stock para el tipo de producto pallet porque los factores de conversión dan un denominador = 0")
                        End If

                    Else

                        vCantidadSolicitadaPedido = CantSol * BePres.Factor

                        If Not clsLnProducto.Tiene_Control_Por_Peso_By_IdProductoBodega(Stock.IdProductoBodega, lConnection, lTransaction) Then

                            If Integer.TryParse(vCantidadSolicitadaPedido, vValorEnteroCantidadSolicitadaPedido) Then
                                vCantidadSolicitadaPedido = vValorEnteroCantidadSolicitadaPedido
                            Else
                                vCantidadSolicitadaPedido = Math.Truncate(vCantidadSolicitadaPedido)
                            End If

                        Else
                            vCantidadSolicitadaPedido = Math.Round(vCantidadSolicitadaPedido, 6)
                        End If

                    End If

                End If

                If Not Stock Is Nothing Then

                    vCantidadPendiente = vCantidadSolicitadaPedido

                    vCantidadStock = Stock.Cantidad

                    If IdPedidoDet = 0 Then
                        Throw New Exception("ERR20221212 - El IdPedidoDet es 0 no se puede procesar el reemplazo")
                    End If

                    BeStockRes = New clsBeStock_res
                    BeStockRes.IdTransaccion = IdPedidoEnc
                    BeStockRes.Indicador = "PED"
                    BeStockRes.IdBodega = Stock.IdBodega
                    BeStockRes.IdStock = Stock.IdStock
                    BeStockRes.IdPropietarioBodega = Stock.IdPropietarioBodega
                    BeStockRes.IdProductoBodega = Stock.IdProductoBodega

                    If vCantidadPendiente = vCantidadStock Then
                        vCantidadAReservarPorIdStock = vCantidadStock
                        vCantidadPendiente -= vCantidadStock
                    ElseIf vCantidadPendiente < vCantidadStock Then
                        vCantidadAReservarPorIdStock = vCantidadPendiente
                        vCantidadPendiente -= vCantidadAReservarPorIdStock
                    ElseIf vCantidadPendiente > vCantidadStock Then
                        vCantidadAReservarPorIdStock = vCantidadStock
                        vCantidadPendiente -= vCantidadStock
                    End If

                    BeStockRes.IdUbicacion = Stock.IdUbicacion
                    BeStockRes.IdProductoEstado = Stock.IdProductoEstado
                    '#CKFK 20180219 Cambié la asignación de BeStock.Presentacion.IdPresentación por BeStosck.IdPresentacion
                    BeStockRes.IdPresentacion = IdPresentacionPedido
                    BeStockRes.IdUnidadMedida = Stock.IdUnidadMedida
                    BeStockRes.Lote = Stock.Lote
                    BeStockRes.Lic_plate = Stock.Lic_plate
                    BeStockRes.Serial = Stock.Serial
                    BeStockRes.Peso = Stock.Peso
                    BeStockRes.Estado = "UNCOMMITED HH"
                    BeStockRes.Fecha_ingreso = Stock.Fecha_Ingreso
                    BeStockRes.Fecha_vence = Stock.Fecha_vence
                    BeStockRes.Uds_lic_plate = Stock.Uds_lic_plate
                    '#CKFK 20171120 06:41PM Guardé en el campo Ubicacion_ant el id de la ubicación anterior de Stock
                    BeStockRes.Ubicacion_ant = Stock.IdUbicacion_anterior
                    BeStockRes.No_bulto = Stock.No_bulto
                    BeStockRes.IdRecepcion = Stock.IdRecepcionEnc
                    BeStockRes.IdPicking = IdPickingEnc
                    BeStockRes.IdPedido = IdPedidoEnc
                    BeStockRes.IdPedidoDet = IdPedidoDet
                    BeStockRes.IdDespacho = 0
                    BeStockRes.añada = Stock.Añada
                    BeStockRes.Fecha_manufactura = Stock.Fecha_Manufactura
                    '#CM20181308_3:23PM:Redondea la cantidad a reservar por IdStock a 6 cifras.
                    BeStockRes.Cantidad = Math.Round(vCantidadAReservarPorIdStock, 6)
                    BeStockRes.IdRecepcion = Stock.IdRecepcionEnc
                    '#EJC20171018_0715PM: Registrar en tabla stock_res la PC que bloqueó/reservó el stock
                    BeStockRes.Host = MaquinaQueSolicita
                    '#CKFK 20180208 08:50 PM agregué campos que faltaban en StockRes
                    BeStockRes.User_agr = IdUsuarioHH
                    BeStockRes.User_mod = IdUsuarioHH

                    CantidadPendiente = vCantidadPendiente
                    vCantidadCompletada = (vCantidadPendiente = 0)

                    'pStockRes.Cantidad = vCantidadReservada
                    lBeStockAReservar.Add(BeStockRes)

                End If

                '#AT 20220117 Permite guardar valores negativos al realizar la operación
                'Ejemplo CantSol = 50 - 380 = -330
                If IdPresentacionPedido <> 0 Then
                    Dim Factor As Double = 0
                    Factor = clsLnProducto_presentacion.Get_Factor_By_IdProductoBodega(Stock.IdProductoBodega, Stock.IdPresentacion, lConnection, lTransaction)
                    CantidadPendiente = Math.Round(CantidadPendiente / Factor, 6)
                End If

                If CantidadPendiente > 0 Then
                    CantSol = CantSol - CantidadPendiente
                End If

                If lBeStockAReservar.Count > 0 Then

                    '#CKFK 20201129 Inserto el nuevo stock reservado
                    If Inserta_Stock_Reservado(lBeStockAReservar, lConnection, lTransaction) Then
                        Reservar_Stock_By_Stock_Reem = True
                    Else
                        Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0006, Stock.IdProductoBodega))
                    End If

                Else
                    Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0005, Stock.IdProductoBodega))
                End If

                '#CKFK 20180208 11:47PM Actualizar la cantidad solicitada en trans_picking_ubic
                Dim bePickingUbicExistente As New clsBeTrans_picking_ubic With {
                    .IdPickingUbic = IdPickingUbic
                }

                '#CKFK 20180331 11:25 PM Agregué la función con transaccionalidad anteriormente
                'estaba esta clsLnTrans_picking_ubic.GetSingle(bePickingUbic
                clsLnTrans_picking_ubic.GetSingle(bePickingUbicExistente, lConnection, lTransaction)

                If bePickingUbicExistente.IdPedidoDet = 0 Then
                    Throw New Exception("ERR20221212 - El IdPedidoDet es 0 no se puede procesar el reemplazo")
                End If

                If CantSol = 0 Then
                    Throw New Exception("#AT20220909_ERROR La cantidad solicitada es 0, no se puede continuar con el proceso de reemplazo")
                End If

                bePickingUbicExistente.Cantidad_Solicitada -= CantSol
                bePickingUbicExistente.Fec_mod = Now

                If Not EsPicking Then
                    bePickingUbicExistente.Cantidad_Recibida -= CantSol
                End If

                If bePickingUbicExistente.Cantidad_Solicitada <> 0 Then

                    '#AT 20210111 Aquí entra cuando la cantidad a reemplazar es parcial 
                    '#AT 20210111 Se modifica el picking_ubic  original con la cantidad solicitada menos la cantidad dañada
                    CantidadStockDestino = bePickingUbicExistente.Cantidad_Solicitada

                    Dim vPermitirDecimales As Boolean = clsLnBodega.Get_Permitir_Decimales(bePickingUbicExistente.IdBodega, lConnection, lTransaction)
                    clsPublic.Abs(CantidadStockDestino - Fix(CantidadStockDestino), vPermitirDecimales)


                    RowsUpdate = clsLnTrans_picking_ubic.Actualizar(bePickingUbicExistente,
                                                                    lConnection,
                                                                    lTransaction)

                    '#AT20230110 Para llevar el registro de pickeo detallado y comparar el existente en la bd con el del objeto en memoria
                    clsLnTrans_picking_ubic.InsertarTmp(bePickingUbicExistente,
                                                        lConnection,
                                                        lTransaction)

                    If RowsUpdate = 0 Then
                        Throw New Exception("#AT20220825_ERROR A No se actualizó ningún registro, no se podrá realizar proceso reemplazo o no encontrado")
                    End If

                    '#AT 20210111 Se inserta un nuevo picking_ubic con el dañado y encontrado en true
                    '#AT 20210111 Agregar una validacion cuando el tipo = 2 (no encontrado)

                    If Tipo = 1 Then

                        If EsPicking Then
                            bePickingUbicExistente.Cantidad_Recibida = 0
                            bePickingUbicExistente.Dañado_picking = True
                            bePickingUbicExistente.Dañado_verificacion = False
                        Else
                            bePickingUbicExistente.Cantidad_Recibida = CantSol
                            bePickingUbicExistente.Dañado_picking = False
                            bePickingUbicExistente.Dañado_verificacion = True
                        End If

                        bePickingUbicExistente.Encontrado = 1
                        bePickingUbicExistente.No_encontrado = False

                    Else
                        bePickingUbicExistente.Dañado_picking = False
                        bePickingUbicExistente.Dañado_verificacion = False
                        bePickingUbicExistente.Encontrado = 0
                        bePickingUbicExistente.No_encontrado = True

                        '#AT20250117 Cuando se crea el registro de bitacora del no encontrado
                        'la cantidad recibida y verificada ahora es igual a la solicitada
                        bePickingUbicExistente.Cantidad_Recibida = CantSol
                        bePickingUbicExistente.Cantidad_Verificada = CantSol
                    End If

                    bePickingUbicExistente.Acepto = 0
                    bePickingUbicExistente.Cantidad_Solicitada = CantSol

                    bePickingUbicExistente.IdPickingUbic = clsLnTrans_picking_ubic.MaxID(lConnection, lTransaction) + 1

                    clsLnTrans_picking_ubic.Insertar(bePickingUbicExistente,
                                                     lConnection,
                                                     lTransaction)

                ElseIf bePickingUbicExistente.Cantidad_Solicitada = 0 Then

                    '#AT 20210111 Aquí entra cuando la cantidad a reemplazar es completa 
                    '#AT 20210111 Se va insertar un nuevo picking_ubic con el dañado y el encontrado en true

                    bePickingUbicExistente.Cantidad_Solicitada = CantSol

                    If Tipo = 1 Then

                        If EsPicking Then
                            bePickingUbicExistente.Dañado_picking = True
                            bePickingUbicExistente.Dañado_verificacion = False
                        Else
                            bePickingUbicExistente.Cantidad_Recibida = CantSol
                            bePickingUbicExistente.Dañado_picking = False
                            bePickingUbicExistente.Dañado_verificacion = True
                        End If

                        bePickingUbicExistente.Encontrado = 1
                        bePickingUbicExistente.No_encontrado = False

                    Else
                        bePickingUbicExistente.Dañado_picking = False
                        bePickingUbicExistente.Dañado_verificacion = False
                        bePickingUbicExistente.Encontrado = 0
                        bePickingUbicExistente.No_encontrado = True
                    End If

                    bePickingUbicExistente.Acepto = 0

                    RowsUpdate = clsLnTrans_picking_ubic.Actualizar(bePickingUbicExistente,
                                                                    lConnection,
                                                                    lTransaction)

                    If RowsUpdate = 0 Then
                        Throw New Exception("#AT20220825_ERRORB No se actualizó ningún registro, no se podrá realizar proceso reemplazo o no encontrado")
                    End If

                End If

                If Not EsPicking Then

                    Dim BePickingEnc As New clsBeTrans_picking_enc
                    BePickingEnc.IdPickingEnc = clsLnTrans_picking_ubic.ObtienIdPickingEnc_Y_Verifica_Estado_PickingEnc_ByPickingUbic(IdPickingUbic, lConnection, lTransaction)

                    If BePickingEnc.IdPickingEnc <> 0 Then
                        BePickingEnc.Estado = "Pendiente"
                        clsLnTrans_picking_enc.ActualizarEstadoByRemplazo(BePickingEnc, lConnection, lTransaction)
                    End If

                End If

                clsLnLog_error_wms.Agregar_Error(String.Format("Se reemplazó en {4} el IdProductoBodega {0}, de la ubicación {1}, con el IdStock {2} y la cantidad {3}",
                                                               bePickingUbicExistente.IdProductoBodega,
                                                               bePickingUbicExistente.IdUbicacion,
                                                               bePickingUbicExistente.IdStock,
                                                               CantSol,
