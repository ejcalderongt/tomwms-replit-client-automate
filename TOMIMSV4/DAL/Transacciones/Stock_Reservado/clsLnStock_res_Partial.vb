                                                                            lTransaction)
            End If

            If ListaStock IsNot Nothing Then

                If ListaStock.Count > 0 Then

                    For Each StockRes As clsBeVW_stock_res In ListaStock

                        '#EJC20220630:Hacer select sobre stock_res para insertar en tabla de log.
                        Dim vSQL As String = "SELECT * FROM stock_res 
                                              WHERE IdStock=@IdStock 
                                              AND IdBodega = @IdBodega "

                        Using lDTA As New SqlDataAdapter(vSQL, lConnection)

                            lDTA.SelectCommand.CommandType = CommandType.Text
                            lDTA.SelectCommand.Transaction = lTransaction
                            lDTA.SelectCommand.Parameters.Add(New SqlParameter("@IdStock", StockRes.IdStock))
                            lDTA.SelectCommand.Parameters.Add(New SqlParameter("@IdBodega", IdBodega))

                            Dim lDataTable As New DataTable
                            lDTA.Fill(lDataTable)

                            vIdLogReubicStockRes = clsLnTrans_log_reubic_stock_res.MaxID(lConnection, lTransaction) + 1

                            Dim BeStockResAReubicar As clsBeStock_res

                            If lDataTable IsNot Nothing AndAlso lDataTable.Rows.Count > 0 Then

                                BeStockOrigen = clsLnStock.GetSingle(StockRes.IdStock, lConnection, lTransaction)

                                If Not BeStockOrigen Is Nothing Then

                                    'Actualiza el stock
                                    rowsAffected += clsLnStock.Actualizar_IdUbicacion_By_IdStock(IdUbicacion,
                                                                                                 BeStockOrigen.IdUbicacion,
                                                                                                 IdBodega,
                                                                                                 StockRes.IdStock,
                                                                                                 lConnection,
                                                                                                 lTransaction)
                                    For Each lRow As DataRow In lDataTable.Rows

                                        BeStockResAReubicar = New clsBeStock_res
