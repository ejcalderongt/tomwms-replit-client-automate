    ''' CASO#1 - IDEAL_20231002011101: 
    ''' Hay cajas en almacenamiento que vencen primero Vrs las que están en zona de picking o ubicación de picking.
    ''' Modelado de inventario.
    ''' Insertar una caja en ubicación de almacenaje con fecha corta. 01/01/2026
    ''' Insertar una caja en ubicación de picking con fecha superior.  02/01/2026   
    ''' Resultado esperado: Reservar cajas desde almacenamiento, respetando el producto que vence antes.
    ''' </summary>
    ''' <returns></returns>
    Public Shared Function Ejecuta_QA_CASO_1_IDEAL_20231002011101(ByVal IdBodega As Integer,
                                                                      ByVal IdUsuario As Integer,
                                                                      ByRef Resultado As String) As Boolean

        Dim lConnection As New SqlConnection(Configuration.ConfigurationManager.AppSettings("CST"))
        Dim lTransaction As SqlTransaction = Nothing
        Dim BeBodega As New clsBeBodega
        Dim vCodigoProducto As String = "47022"
        Dim BeProducto As New clsBeProducto
        Dim vIdProductoBodega As Integer = 0
        Dim BeProductoPresentacionDefecto As New clsBeProducto_Presentacion
        Dim BeUbicacionNoPicking As New clsBeBodega_ubicacion
        Dim BeUbicacionPicking As New clsBeBodega_ubicacion
        Dim BeConfig As New clsBeI_nav_config_enc
        Dim BeProductoEstado As New clsBeProducto_estado
        Dim BeEstadoProductoDefecto As New clsBeProducto_estado
        Dim BeStockPushAlmacenaje As New clsBeStock
        Dim vIdPropietarioBodega As Integer = 0
        Dim BeCliente As New clsBeCliente

#Region "PREPARAR INVENTARIO"

        Try

            If Clear_BD_For_Test_Cases() Then

                lConnection.Open() : lTransaction = lConnection.BeginTransaction(IsolationLevel.ReadUncommitted)

                BeBodega = clsLnBodega.GetSingle_By_Idbodega(IdBodega, lConnection, lTransaction)

                If Not BeBodega Is Nothing Then

                    If Not clsLnStock.Existe_Stock_By_IdBodega(IdBodega, lConnection, lTransaction) Then

                        BeProducto = clsLnProducto.Get_Single_By_Codigo(vCodigoProducto, lConnection, lTransaction)

                        If Not BeProducto Is Nothing Then

                            vIdProductoBodega = clsLnProducto_bodega.Get_IdProductoBodega_By_IdProducto_And_IdBodega(BeProducto.IdProducto,
                                                                                                                    IdBodega,
                                                                                                                    lConnection,
                                                                                                                    lTransaction)

                            BeProductoPresentacionDefecto = clsLnProducto_presentacion.Get_Single_By_Codigo_Producto(vCodigoProducto, lConnection, lTransaction)

                            BeUbicacionNoPicking = clsLnBodega_ubicacion.Get_Single_Ubicacion_No_Picking(IdBodega, lConnection, lTransaction)
                            If BeUbicacionNoPicking Is Nothing Then
                                Throw New Exception("ERROR_202310021322: No se encontró una ubicación de almacenaje, revise ubicacion_picking =0 en bodega_ubicacion.")
                            End If

                            BeUbicacionPicking = clsLnBodega_ubicacion.Get_Single_Ubicacion_Picking(IdBodega, lConnection, lTransaction)
                            If BeUbicacionPicking Is Nothing Then
                                Throw New Exception("ERROR_202310021322A: No se encontró una ubicación de picking, revise ubicacion_picking =1 en bodega_ubicacion.")
                            End If

                            BeConfig = clsLnI_nav_config_enc.GetSingle_By_IdBodega_And_IdPropietario(IdBodega, 1)

                            If Not BeConfig Is Nothing Then

                                BeProductoEstado = clsLnProducto_estado.Get_Single_By_IdEstado(BeConfig.IdProductoEstado, lConnection, lTransaction)

                                If Not BeProductoEstado Is Nothing Then

                                    If Not BeProductoPresentacionDefecto Is Nothing Then

                                        vIdPropietarioBodega = clsLnPropietario_bodega.Get_IdPropietarioBodega_By_IdPropietario_And_IdBodega(BeConfig.IdPropietario,
                                                                                                                                             IdBodega,
                                                                                                                                             lConnection,
                                                                                                                                             lTransaction)

                                        If vIdPropietarioBodega = 0 Then
                                            Throw New Exception("ERROR_202310021502: No se obtuvo el IdPropietarioBodega.")
                                        End If

                                        BeCliente = clsLnCliente.Get_Cliente_Defecto_Pruebas(IdBodega,
                                                                                             BeConfig.IdPropietario,
                                                                                             IdUsuario,
                                                                                             lConnection,
                                                                                             lTransaction)


                                        If BeCliente Is Nothing Then
                                            Throw New Exception("ERROR_202310021503: No se obtuvo el cliente de pruebas.")
                                        End If

                                        BeStockPushAlmacenaje = New clsBeStock()
                                        BeStockPushAlmacenaje.IdBodega = IdBodega
                                        BeStockPushAlmacenaje.IdStock = clsLnStock.MaxID(lConnection, lTransaction) + 1
                                        BeStockPushAlmacenaje.IdProductoBodega = vIdProductoBodega
                                        BeStockPushAlmacenaje.IdPropietarioBodega = vIdPropietarioBodega
                                        BeStockPushAlmacenaje.IdProductoEstado = BeProductoEstado.IdEstado
                                        BeStockPushAlmacenaje.ProductoEstado.IdEstado = BeProductoEstado.IdEstado
                                        BeStockPushAlmacenaje.Presentacion.IdPresentacion = BeProductoPresentacionDefecto.IdPresentacion
                                        BeStockPushAlmacenaje.IdUnidadMedida = BeProducto.IdUnidadMedidaBasica
                                        BeStockPushAlmacenaje.IdUbicacion = BeUbicacionNoPicking.IdUbicacion
                                        BeStockPushAlmacenaje.IdUbicacion_anterior = BeUbicacionNoPicking.IdUbicacion
                                        If BeProducto.Control_lote Then BeStockPushAlmacenaje.Lote = "CASO_USO1_MI3_AUTOMATE"
                                        If BeProducto.Control_vencimiento Then BeStockPushAlmacenaje.Fecha_vence = New Date(2026, 1, 1)
                                        BeStockPushAlmacenaje.Fecha_Ingreso = Now
                                        BeStockPushAlmacenaje.Cantidad = Math.Round(1 * BeProductoPresentacionDefecto.Factor, 6)
                                        BeStockPushAlmacenaje.Activo = True
                                        BeStockPushAlmacenaje.Peso = 0
                                        BeStockPushAlmacenaje.Temperatura = 0
                                        BeStockPushAlmacenaje.Fec_agr = Now
                                        BeStockPushAlmacenaje.Fec_mod = Now
                                        BeStockPushAlmacenaje.User_agr = IdUsuario
                                        BeStockPushAlmacenaje.User_mod = IdUsuario
                                        BeStockPushAlmacenaje.Pallet_No_Estandar = False
                                        BeStockPushAlmacenaje.Lic_plate = FormatoFechas.tFechaHora(Now)
                                        clsLnStock.Insertar(BeStockPushAlmacenaje, lConnection, lTransaction)

                                        Dim BeStockPushPicking As New clsBeStock
                                        clsPublic.CopyObject(BeStockPushAlmacenaje, BeStockPushPicking)
                                        BeStockPushPicking.IdStock = clsLnStock.MaxID(lConnection, lTransaction) + 1
                                        BeStockPushPicking.IdUbicacion = BeUbicacionPicking.IdUbicacion
                                        BeStockPushPicking.Fecha_vence = BeStockPushPicking.Fecha_vence.AddDays(1)
                                        clsLnStock.Insertar(BeStockPushPicking, lConnection, lTransaction)

                                    Else
                                        Throw New Exception("ERROR_202310021321: El producto seleccionado no tiene presentación por defecto conocida y el escenario requiere producto con presentación.")
                                    End If

                                Else
                                    Throw New Exception("ERROR_202310021315: El estado de producto definido en la configuración de la interface no es válido ( se busca config. IdProducto buen estado).")
                                End If

                            Else
                                Throw New Exception("ERROR_202310021315: La configuración de la interface no está definida y los valores son necesarios para las pruebas automatizadas.")
                            End If

                        Else
                            Throw New Exception("ERROR_202310021310: El código para el caso de uso no es válido.")
                        End If

                    Else
                        Throw New Exception("ERROR_202310021300: La base de datos no se pudo limpiar.")
                    End If

                Else
                    Throw New Exception("ERROR_202310021312: El código para el caso de uso no es válido.")
                End If

                'Fin de preparación del inventario.
                lTransaction.Commit() : lConnection.Close()

            End If

        Catch ex As Exception
            If Not lTransaction Is Nothing Then lTransaction.Rollback()
            Throw ex
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close()
        End Try

#End Region

#Region "ENVIAR PEDIDO RESERVA_MI3"

        Try

            Dim NoPedido As Integer = 0
            NoPedido = clsLnTrans_pe_enc.MaxNoDocumento() 'No colocar transacción para no generar interbloqueo con el insert del pedido.

            Dim BeINavPedCompraEnc As New clsBeI_nav_ped_traslado_enc()
            BeINavPedCompraEnc.No = NoPedido.ToString()
            BeINavPedCompraEnc.Posting_Date = Now
            BeINavPedCompraEnc.Receipt_Date = Now
            BeINavPedCompraEnc.Shipment_Date = Now
            BeINavPedCompraEnc.Status = 1
            BeINavPedCompraEnc.Transfer_from_Code = BeBodega.Codigo
            BeINavPedCompraEnc.Transfer_from_Contact = "TEST_MI3"
            BeINavPedCompraEnc.Transfer_from_Name = BeBodega.Nombre
            BeINavPedCompraEnc.Transfer_to_Code = BeCliente.Codigo
            BeINavPedCompraEnc.Transfer_to_Name = BeCliente.Nombre_comercial
            BeINavPedCompraEnc.Transfer_to_Contact = BeCliente.Nombre_comercial
            BeINavPedCompraEnc.Is_Internal_Transfer = True
            BeINavPedCompraEnc.Document_Type = clsDataContractDI.tTipoDocumentoSalida.Pedido_De_Cliente
            BeINavPedCompraEnc.Product_Owner_Code = "01"
            BeINavPedCompraEnc.External_Document_No = ""
            BeINavPedCompraEnc.Receipt_Document_Reference = ""
            BeINavPedCompraEnc.Lineas_Detalle = New List(Of clsBeI_nav_ped_traslado_det)()

            Dim BeTrasDet As New clsBeI_nav_ped_traslado_det()
            BeTrasDet.No = vCodigoProducto
            BeTrasDet.Description = BeProducto.Nombre
            BeTrasDet.Item_No = BeTrasDet.No
            BeTrasDet.Qty_to_Receive = 0
            BeTrasDet.Qty_to_Ship = 0
            BeTrasDet.Quantity = 1
            BeTrasDet.Transfer_to_CodeField = BeCliente.Codigo
            BeTrasDet.Shipment_Date = Now
            BeTrasDet.Unit_of_Measure_Code = BeProducto.UnidadMedida.Codigo
            BeTrasDet.Line_No = 1
            BeTrasDet.Variant_Code = BeProductoPresentacionDefecto.Codigo
            BeTrasDet.Status = 1
            BeINavPedCompraEnc.Lineas_Detalle.Add(BeTrasDet)

            Dim vResultado As New RichTextBox
            clsLnI_nav_ped_traslado_enc.Importar_Pedido_Cliente_A_Tabla_Intermedia(BeINavPedCompraEnc, vResultado)

            Debug.WriteLine(vResultado)

            Resultado = vResultado.Text

            Ejecuta_QA_CASO_1_IDEAL_20231002011101 = True

        Catch ex As Exception
            Throw ex
        End Try

#End Region

    End Function

