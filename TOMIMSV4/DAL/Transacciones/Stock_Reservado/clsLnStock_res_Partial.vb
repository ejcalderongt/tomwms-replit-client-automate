    Public Shared Sub Guardar_Stock_Res(ByVal IdTareaUbicacionEnc As Integer,
                                        ByRef pListBeStock As List(Of clsBeStock),
                                        ByVal pMaquinaQueSolicita As String,
                                        ByRef lConnection As SqlConnection,
                                        ByRef lTransaction As SqlTransaction)

        Try

            Dim vIndicePres As Integer = -1
            Dim CantidadStockDestino As Double = 0

            If pListBeStock IsNot Nothing AndAlso pListBeStock.Count > 0 Then

                For Each BeStock As clsBeStock In pListBeStock

                    '#EJC20171025_1159AM: Evita insertar el stock reservado nuevamente en proceso de ubicación
                    If BeStock.IsNew Then

                        Using BeStockRes As New clsBeStock_res()

                            BeStockRes.IdStockRes = MaxID(lConnection, lTransaction) + 1
                            BeStockRes.IdTransaccion = IdTareaUbicacionEnc
                            BeStockRes.Indicador = "UBI"
                            BeStockRes.IdPedidoDet = 0
                            BeStockRes.IdStock = BeStock.IdStock
                            BeStockRes.IdPropietarioBodega = BeStock.IdPropietarioBodega
                            BeStockRes.IdProductoBodega = BeStock.IdProductoBodega
                            '#EJC20211221: Se manda inverso desde la selección del stock en cambio de ubicación forma (chapus por emergencia, buscar después causa raíz)
                            BeStockRes.IdUbicacion = BeStock.IdUbicacion_anterior
                            BeStockRes.Ubicacion_ant = BeStock.IdUbicacion
                            BeStockRes.IdProductoEstado = BeStock.IdProductoEstado
                            BeStockRes.IdPresentacion = BeStock.IdPresentacion
                            BeStockRes.IdUnidadMedida = BeStock.IdUnidadMedida
                            BeStockRes.Lote = BeStock.Lote
                            BeStockRes.Lic_plate = BeStock.Lic_plate
                            BeStockRes.Serial = BeStock.Serial

                            If BeStock.IdPresentacion = 0 Then
                                BeStockRes.Cantidad = BeStock.Cantidad
                            Else

                                vIndicePres = lPresentaciones.FindIndex(Function(x) x.IdPresentacion = BeStock.IdPresentacion)

                                If vIndicePres = -1 Then
                                    BeStock.Presentacion = New clsBeProducto_Presentacion
                                    BeStock.Presentacion.IdPresentacion = BeStock.IdPresentacion
                                    clsLnProducto_presentacion.GetSingle(BeStock.Presentacion, lConnection, lTransaction)
                                    lPresentaciones.Add(BeStock.Presentacion)
                                Else
                                    BeStock.Presentacion = lPresentaciones(vIndicePres)
                                End If

                                If BeStock.Presentacion.EsPallet Then
                                    BeStockRes.Cantidad = BeStock.Cantidad * (BeStock.Presentacion.Factor * BeStock.Presentacion.CamasPorTarima * BeStock.Presentacion.CajasPorCama)
                                Else
                                    '#CKFK20250706 Le quité a esta línea el multiplicar la cantidad por el factor
                                    'por que la cantidad ya viene en unidad de medida básica.
                                    BeStockRes.Cantidad = BeStock.Cantidad '* (BeStock.Presentacion.Factor)
                                End If

                            End If

                            BeStockRes.Peso = BeStock.Peso
                            BeStockRes.Estado = BeStock.ProductoEstado.Nombre
                            BeStockRes.Fecha_ingreso = BeStock.Fecha_Ingreso
                            BeStockRes.Fecha_vence = BeStock.Fecha_vence
                            BeStockRes.Uds_lic_plate = Val(BeStock.Uds_lic_plate)
                            BeStockRes.No_bulto = BeStock.No_bulto
                            BeStockRes.IdRecepcion = BeStock.IdRecepcionEnc
                            BeStockRes.IdPicking = BeStock.IdPickingEnc
                            BeStockRes.IdPedido = BeStock.IdPedidoEnc
                            BeStockRes.IdDespacho = BeStock.IdDespachoEnc
                            BeStockRes.User_agr = BeStock.User_agr
                            BeStockRes.Fec_agr = Now
                            BeStockRes.User_mod = BeStock.User_mod
                            BeStockRes.Fec_mod = Now
                            BeStockRes.Host = pMaquinaQueSolicita
                            BeStockRes.añada = 0
                            BeStockRes.Fecha_manufactura = BeStock.Fecha_Manufactura
                            BeStockRes.IdBodega = BeStock.IdBodega

                            CantidadStockDestino = BeStockRes.Cantidad

                            Dim vPermitirDecimales As Boolean = clsLnBodega.Get_Permitir_Decimales(BeStockRes.IdBodega, lConnection, lTransaction)
                            clsPublic.Abs(CantidadStockDestino - Fix(CantidadStockDestino), vPermitirDecimales)

                            'If Math.Abs(CantidadStockDestino - Fix(CantidadStockDestino)) Then
                            '    Throw New Exception("Error_202303101448P: El valor a insertar en stock sería un valor decimal no válido, se prevendrá continuar para evitar inconvenientes en reserva.")
                            'End If

                            Insertar(BeStockRes, lConnection, lTransaction)

                        End Using

                    End If

                Next

            End If

        Catch ex As Exception
            Dim vMsgError As String = String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message)
            clsLnLog_error_wms.Agregar_Error(vMsgError)
            Throw ex
        End Try

    End Sub

