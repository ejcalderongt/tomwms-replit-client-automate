    '#AT 20220112 Para completar el proceso de reemplazo con picking resumido
    Public Shared Function Reemplazar_ListaPu_By_Stock(ByVal pBeStock_res As clsBeStock_res,
                                                       ByVal CantSol As Double,
                                                       ByVal MaquinaQueSolicita As String,
                                                       ByVal IdPickingEnc As Integer,
                                                       ByVal IdPedidoEnc As Integer,
                                                       ByVal IdUsuarioHH As Integer,
                                                       ByVal IdPedidoDet As Integer,
                                                       ByVal BePickingUbic As clsBeTrans_picking_ubic,
                                                       ByVal EsPicking As Boolean,
                                                       ByVal Tipo As Integer,
                                                       ByVal IdUbicDestino As Integer,
                                                       ByVal IdEstDestino As Integer,
                                                       ByVal CantidadTotal As Double,
                                                       ByRef CantPend As Double) As Boolean

        Dim lConnection As New SqlConnection(Configuration.ConfigurationManager.AppSettings("CST"))
        Dim lTransaction As SqlTransaction = Nothing

        Reemplazar_ListaPu_By_Stock = False

        Try

            Dim clsLnStock As New clsLnStock
            Dim ListTransPickingUbic As New List(Of clsBeTrans_picking_ubic)
            Dim CantidadPendiente As Double = 0
            Dim tmpCantPend As Double = 0
            Dim CantTotal As Double = 0
            Dim CantSolicitada As Double = 0
            Dim CantRecibida As Double = 0
            Dim CantidadCompletada As Boolean = False
            Dim result As Boolean = False

            CantTotal = CantSol

            lConnection.Open() : lTransaction = lConnection.BeginTransaction(IsolationLevel.ReadUncommitted)

            If IdPedidoEnc = 0 Then

                IdPedidoEnc = clsLnTrans_pe_enc.Get_IdPedido_By_IdPickingEnc(IdPickingEnc,
                                                                             lConnection,
                                                                             lTransaction)

                If IdPedidoEnc = 0 Then
                    Throw New Exception("El IdPedidoEnc es 0 no se puede continuar el proceso")
                End If

            End If

            If BePickingUbic.IdPickingEnc = 0 Then
                BePickingUbic.IdPickingEnc = IdPickingEnc
            End If

            ListTransPickingUbic = clsLnTrans_picking_ubic.Get_All_PickingUbic_By_PickingUbic(BePickingUbic,
                                                                                              lConnection,
                                                                                              lTransaction)

            If ListTransPickingUbic.Count > 0 Then

                '#AT Suma cantidades solicitadas y recibidas para calcular la cantidad disponible 
                For Each tmp In ListTransPickingUbic
                    CantSolicitada += tmp.Cantidad_Solicitada
                    CantRecibida += tmp.Cantidad_Recibida
                Next

                Dim CantDisponible = CantSolicitada - CantRecibida

                '#AT Se valida si la cantidad a reemplazar es mayor a la disponible
                If CantidadTotal > CantDisponible Then
                    Throw New Exception("No se puede completar el proceso, la cantidad a reemplazar es mayor a la disponible: (" + CantDisponible.ToString + ")")
                End If

                For Each pu In ListTransPickingUbic

                    '#AT Se resta la cantidad recibida a la solicitada
                    Dim DisponibleReem = pu.Cantidad_Solicitada - pu.Cantidad_Recibida

                    If CantSol >= DisponibleReem Then

                        tmpCantPend = CantSol - (pu.Cantidad_Solicitada - pu.Cantidad_Recibida)
                        CantSol = DisponibleReem

                    End If

                    result = Reemplazar_IdStock_By_Stock(pBeStock_res,
                                                         CantSol,
                                                         MaquinaQueSolicita,
                                                         IdPickingEnc,
                                                         pu.IdPedidoEnc,
                                                         IdUsuarioHH,
                                                         IIf(IdPedidoDet = 0, pu.IdPedidoDet, IdPedidoDet),
                                                         pu.IdPickingUbic,
                                                         EsPicking,
                                                         Tipo,
                                                         IdUbicDestino,
                                                         IdEstDestino,
                                                         CantPend,
                                                         lConnection,
                                                         lTransaction)

                    CantTotal -= CantSol

                    '#CKFK20250317 Agregué esta validación
                    Dim listaPicking = clsLnTrans_picking_ubic.Get_All_PickingUbic_By_IdPedidoDet(pu.IdPedidoDet,
                                                                              pu.IdPedidoEnc,
                                                                              pu.IdBodega,
                                                                              lConnection,
                                                                              lTransaction)

                    Dim cantidadPickingIdPedidoDet As Double = If(listaPicking IsNot Nothing AndAlso listaPicking.Any(),
                                              listaPicking.Sum(Function(x) x.Cantidad_Solicitada),
                                              0)
                    Dim cantidadPedidoDet As Double = clsLnTrans_pe_det.Get_Single_By_IdPedidoDet(pu.IdPedidoDet).Cantidad

                    If cantidadPedidoDet < cantidadPickingIdPedidoDet AndAlso cantidadPickingIdPedidoDet > 0 Then
                        Throw New Exception("Error_Reemplazo_A: No es posible reservar más de lo solicitado")
                    End If

                    If result Then
                        'CantidadCompletada = (tmpCantPend = 0)
                        If CantTotal = 0 Then
                            Exit For
                        Else
                            CantSol = tmpCantPend
                        End If
                    End If
                Next

            Else
                Throw New Exception(": No se puede completar el proceso, la cantidad a reemplazar es mayor a la disponible: (0)")
            End If

            lTransaction.Commit()

            Return True

        Catch ex As Exception
            If lTransaction IsNot Nothing Then lTransaction.Rollback()
            Throw ex
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close() : lConnection.Dispose()
            If lTransaction IsNot Nothing Then lTransaction.Dispose()
        End Try

    End Function

    'AT20220614 Copia de Reemplazar_ListaPu_By_Stock para completar el proceso de reemplazo sin existencias 
    Public Shared Function Reemplazar_ListaPu_By_Stock_Sin_Exist(ByVal CantSol As Double,
                                                               ByVal IdUsuarioHH As Integer,
                                                               ByVal BePickingUbic As clsBeTrans_picking_ubic,
                                                               ByVal EsPicking As Boolean,
                                                               ByVal Tipo As Integer,
                                                               ByVal CantidadTotal As Double,
                                                               ByRef CantPend As Double,
                                                               ByVal IdUbicDestino As Integer,
                                                               ByVal IdEstadoDestino As Integer) As Boolean

        Dim lConnection As New SqlConnection(Configuration.ConfigurationManager.AppSettings("CST"))
        Dim lTransaction As SqlTransaction = Nothing

        Reemplazar_ListaPu_By_Stock_Sin_Exist = False

        Try

            Dim clsLnStock As New clsLnStock
            Dim ListTransPickingUbic As New List(Of clsBeTrans_picking_ubic)
            Dim CantidadPendiente As Double = 0
            Dim tmpCantPend As Double = 0
            Dim CantTotal As Double = 0
            Dim CantOriginal As Double = 0
            Dim CantSolicitada As Double = 0
            Dim CantRecibida As Double = 0
            Dim CantidadCompletada As Boolean = False
            Dim result As String = ""
            Dim mResult As Boolean = False
            Dim IdEmpresa As Integer = 0
            Dim BePresentacion As New clsBeProducto_Presentacion

            CantOriginal = CantSol
            CantTotal = CantSol

            lConnection.Open() : lTransaction = lConnection.BeginTransaction(IsolationLevel.ReadUncommitted)

            If EsPicking Then
                ListTransPickingUbic = clsLnTrans_picking_ubic.Get_All_PickingUbic_By_PickingUbic(BePickingUbic, lConnection, lTransaction)
            Else
                ListTransPickingUbic = clsLnTrans_picking_ubic.Get_All_PickingUbic_By_Verificacion(BePickingUbic, lConnection, lTransaction)
            End If

            If ListTransPickingUbic.Count > 0 Then

                IdEmpresa = clsLnPropietario_bodega.GetIdEmpresa_By_IdPropietarioBodega(ListTransPickingUbic(0).IdPropietarioBodega, lConnection, lTransaction)

                '#AT Suma cantidades solicitadas y recibidas para calcular la cantidad disponible 
                For Each tmp In ListTransPickingUbic

                    CantSolicitada += tmp.Cantidad_Solicitada
                    If EsPicking Then
                        CantRecibida += tmp.Cantidad_Recibida
                    Else
                        CantRecibida += tmp.Cantidad_Verificada
                    End If

                Next

                Dim CantDisponible = CantSolicitada - CantRecibida

                '#AT Se valida si la cantidad a reemplazar es mayor a la disponible
                If CantidadTotal > CantDisponible Then
                    Throw New Exception("No se puede completar el proceso, la cantidad a reemplazar es mayor a la disponible: (" + CantDisponible.ToString + ")")
                End If

                For Each pu In ListTransPickingUbic

                    CantSolicitada = pu.Cantidad_Solicitada

                    If EsPicking Then
                        CantRecibida = pu.Cantidad_Recibida
                    Else
                        CantRecibida = pu.Cantidad_Verificada
                    End If

                    '#AT Se resta la cantidad recibida a la solicitada
                    Dim DisponibleReem = CantSolicitada - CantRecibida

                    If CantSol >= DisponibleReem Then

                        tmpCantPend = CantSol - (CantSolicitada - CantRecibida)
                        CantSol = DisponibleReem

                    End If

                    Dim pHost As String = "1"


                    If Tipo = 1 Then
                        result = clsLnTrans_ubic_hh_enc.Generar_Tarea_Cambio_Estado_Sin_Exist(pu.IdBodega,
                                                                                             IdEmpresa,
                                                                                             pu.IdStock,
                                                                                             pu.IdStockRes,
                                                                                             IdUsuarioHH,
                                                                                             CantOriginal,
                                                                                             IdUbicDestino,
                                                                                             IdEstadoDestino,
                                                                                             pu.IdPropietarioBodega,
                                                                                             pu.IdPickingUbic,
                                                                                             lConnection,
                                                                                             lTransaction,
                                                                                             pHost)
                    Else

                        If BePickingUbic.IdPresentacion <> 0 Then

                            BePresentacion.IdPresentacion = BePickingUbic.IdPresentacion

                            clsLnProducto_presentacion.GetSingle(BePresentacion, lConnection, lTransaction)

                            If BePresentacion.EsPallet Then

                                Dim vFactorPallet As Double = (BePresentacion.Factor * BePresentacion.CajasPorCama * BePresentacion.CamasPorTarima)

                                If vFactorPallet > 0 Then
                                    CantSol = Math.Round(CantSol * vFactorPallet, 7)
                                Else
                                    Throw New Exception("No se pudo reservar el stock para el tipo de producto pallet porque los factores de conversión dan un denominador = 0")
                                End If

                            Else
                                CantSol = Math.Round(CantSol * BePresentacion.Factor, 7)
                            End If

                        End If

                        result = clsLnTrans_picking_ubic.Marcar_No_Encontrado(pu.IdBodega,
                                                                              IdEmpresa,
                                                                              pu.IdStock,
                                                                              pu.IdStockRes,
                                                                              IdUsuarioHH,
                                                                              CantSol,
                                                                              pu.IdPropietarioBodega,
                                                                              pu.IdPickingUbic,
                                                                              lConnection,
                                                                              lTransaction)
                    End If


                    mResult = Modificar_PickingUbic_By_Reem(CantOriginal,
                                                            pu.IdPickingUbic,
                                                            EsPicking,
                                                            Tipo,
                                                            lConnection,
                                                            lTransaction)




                    CantTotal -= CantOriginal

                    If result = "" And mResult Then
                        If CantTotal = 0 Then
                            Exit For
                        Else
                            CantSol = tmpCantPend
                        End If
                    End If
                Next

            Else
                Throw New Exception(": No se puede completar el proceso, la cantidad a reemplazar es mayor a la disponible: (0)")
            End If

            lTransaction.Commit()

            Return True

        Catch ex As Exception
            If lTransaction IsNot Nothing Then lTransaction.Rollback()
            Throw ex
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close() : lConnection.Dispose()
            If lTransaction IsNot Nothing Then lTransaction.Dispose()
        End Try

    End Function

    'AT20220614 Es una copia de Reservar_Stock_By_Stock_Reem  con el objetivo de completar el proceso de no encontrado cuando no haya existencias.
    Public Shared Function Modificar_PickingUbic_By_Reem(ByVal CantSol As Double,
                                                        ByVal IdPickingUbic As Integer,
                                                        ByVal EsPicking As Boolean,
                                                        ByVal Tipo As Integer,
                                                        ByRef lConnection As SqlConnection,
                                                        ByRef lTransaction As SqlTransaction) As Boolean

        Modificar_PickingUbic_By_Reem = False

        Try
            Dim vCantSol As Double = 0

            vCantSol = CantSol

            '#CKFK 20180208 11:47PM Actualizar la cantidad solicitada en trans_picking_ubic
            Dim bePickingUbicExistente As New clsBeTrans_picking_ubic With {
                .IdPickingUbic = IdPickingUbic
            }

            '#CKFK 20180331 11:25 PM Agregué la función con transaccionalidad anteriormente
            'estaba esta clsLnTrans_picking_ubic.GetSingle(bePickingUbic
            clsLnTrans_picking_ubic.GetSingle(bePickingUbicExistente, lConnection, lTransaction)

            bePickingUbicExistente.Cantidad_Solicitada -= CantSol

            If Not EsPicking Then
                bePickingUbicExistente.Cantidad_Recibida -= CantSol
            End If

            If bePickingUbicExistente.Cantidad_Solicitada <> 0 Then
                '#AT 20210111 Aquí entra cuando la cantidad a reemplazar es parcial 

                '#AT 20210111 Se modifica el picking_ubic  original con la cantidad solicitada menos la cantidad dañada
                clsLnTrans_picking_ubic.Actualizar(bePickingUbicExistente, lConnection, lTransaction)

                '#AT 20210111 Se inserta un nuevo picking_ubic con el dañado y encontrado en true
                '#AT 20210111 Agregar una validacion cuando el tipo = 2 (no encontrado)

                If Tipo = 1 Then

                    If EsPicking Then
                        bePickingUbicExistente.Dañado_picking = True
                        bePickingUbicExistente.Dañado_verificacion = False
                        'bePickingUbicExistente.No_packing = 1
                    Else
                        bePickingUbicExistente.Cantidad_Recibida = CantSol
                        bePickingUbicExistente.Dañado_picking = False
                        bePickingUbicExistente.Dañado_verificacion = True
                        'bePickingUbicExistente.No_packing = 2
                    End If

                    bePickingUbicExistente.Encontrado = 1
                    bePickingUbicExistente.No_encontrado = False

                Else

                    bePickingUbicExistente.Dañado_picking = False
                    bePickingUbicExistente.Dañado_verificacion = False
                    bePickingUbicExistente.Encontrado = 0
                    bePickingUbicExistente.No_encontrado = True
                    'bePickingUbicExistente.No_packing = 3

                End If

                bePickingUbicExistente.Acepto = 0
                bePickingUbicExistente.Cantidad_Solicitada = CantSol

                bePickingUbicExistente.IdPickingUbic = clsLnTrans_picking_ubic.MaxID(lConnection, lTransaction) + 1
                clsLnTrans_picking_ubic.Insertar(bePickingUbicExistente, lConnection, lTransaction)

            ElseIf bePickingUbicExistente.Cantidad_Solicitada = 0 Then
                '#AT 20210111 Aquí entra cuando la cantidad a reemplazar es completa 

                '#AT 20210111 Se va insertar un nuevo picking_ubic con el dañado y el encontrado en true

                bePickingUbicExistente.Cantidad_Solicitada = CantSol

                If Tipo = 1 Then

                    If EsPicking Then
                        bePickingUbicExistente.Dañado_picking = True
                        bePickingUbicExistente.Dañado_verificacion = False
                        'bePickingUbicExistente.No_packing = 4
                    Else
                        bePickingUbicExistente.Cantidad_Recibida = CantSol
                        bePickingUbicExistente.Dañado_picking = False
                        bePickingUbicExistente.Dañado_verificacion = True
                        'bePickingUbicExistente.No_packing = 5
                    End If

                    bePickingUbicExistente.Encontrado = 1
                    bePickingUbicExistente.No_encontrado = False

                Else
                    bePickingUbicExistente.Dañado_picking = False
                    bePickingUbicExistente.Dañado_verificacion = False
                    bePickingUbicExistente.Encontrado = 0
                    bePickingUbicExistente.No_encontrado = True
                    'bePickingUbicExistente.No_packing = 6
                End If

                bePickingUbicExistente.Acepto = 0

                clsLnTrans_picking_ubic.Actualizar(bePickingUbicExistente,
                                                   lConnection,
                                                   lTransaction)

            End If

            If Not EsPicking Then

                Dim BePickingEnc As New clsBeTrans_picking_enc
                BePickingEnc.IdPickingEnc = clsLnTrans_picking_ubic.ObtienIdPickingEnc_Y_Verifica_Estado_PickingEnc_ByPickingUbic(IdPickingUbic, lConnection, lTransaction)

                If BePickingEnc.IdPickingEnc <> 0 Then
                    BePickingEnc.Estado = "Pendiente"
                    clsLnTrans_picking_enc.ActualizarEstadoByRemplazo(BePickingEnc, lConnection, lTransaction)
                End If

            End If

        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try

    End Function

    '#AT 20220127 Nueva función para el reeemplazo verificación
