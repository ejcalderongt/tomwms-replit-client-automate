    Public Shared Function Liberar_Stock_By_List(lBeStockRes As List(Of clsBeStock_res), ByVal pIdUsuario As Integer) As Boolean

        Dim lConnection As New SqlConnection(Configuration.ConfigurationManager.AppSettings("CST"))
        Dim lTransaction As SqlTransaction = Nothing

        Liberar_Stock_By_List = False

        Dim vCantidadStockResLiberados As Integer = 0

        Try

            lConnection.Open() : lTransaction = lConnection.BeginTransaction(IsolationLevel.ReadUncommitted)

            If Not lBeStockRes Is Nothing Then

                If lBeStockRes.Count > 0 Then

                    For Each BeStockRes As clsBeStock_res In lBeStockRes

                        If BeStockRes.IdPicking <> 0 Then

                            If (clsLnTrans_picking_det.Liberar_Producto_No_Pickeado_Multiple(BeStockRes.IdPedidoDet,
                                                                                                 BeStockRes.IdPedido,
                                                                                                 BeStockRes.IdPicking,
                                                                                                 pIdUsuario,
                                                                                                 BeStockRes.IdBodega,
                                                                                                 BeStockRes.IdStockRes,
                                                                                                 lConnection,
                                                                                                 lTransaction)) Then

                                vCantidadStockResLiberados += 1

                            End If

                        ElseIf BeStockRes.Indicador = "REAB" Then
                            If (clsLnTrans_ubic_hh_enc.Anular_Tarea_Reabasto(BeStockRes.IdTransaccion,
                                                                             lConnection,
                                                                             lTransaction)) Then

                                vCantidadStockResLiberados += 1

                            End If
                        Else
                            Eliminar(BeStockRes, lConnection, lTransaction)
                            vCantidadStockResLiberados += 1
                        End If

                    Next

                End If

            End If

            Liberar_Stock_By_List = (lBeStockRes.Count = vCantidadStockResLiberados)

            lTransaction.Commit()

        Catch ex As Exception
            If Not lTransaction Is Nothing Then lTransaction.Rollback()
            Dim vMsgError As String = String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message)
            clsLnLog_error_wms.Agregar_Error(vMsgError)
            Throw ex
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close()
        End Try

    End Function

