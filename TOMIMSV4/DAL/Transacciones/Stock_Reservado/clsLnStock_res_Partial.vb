    Private Shared Function Inserta_Stock_Reservado(ByRef lStockRes As List(Of clsBeStock_res),
                                                    ByRef lConnection As SqlConnection,
                                                    ByRef ltransaction As SqlTransaction) As Boolean

        Inserta_Stock_Reservado = False

        Dim CantidadStockDestino As Double = 0

        Try


            Dim BeStockResPreviamenteInsertado As New clsBeStock_res

            For Each BeStockRes As clsBeStock_res In lStockRes

                BeStockResPreviamenteInsertado.IdStockRes = BeStockRes.IdStockRes
                BeStockResPreviamenteInsertado.IdProductoBodega = BeStockRes.IdProductoBodega

                If Not GetSingle(BeStockResPreviamenteInsertado,
                                 lConnection,
                                 ltransaction) Then

                    BeStockRes.IdStockRes = MaxID(lConnection, ltransaction) + 1

                    CantidadStockDestino = BeStockRes.Cantidad

                    Dim vPermitirDecimales As Boolean = clsLnBodega.Get_Permitir_Decimales(BeStockRes.IdBodega, lConnection, ltransaction)
                    clsPublic.Abs(CantidadStockDestino - Fix(CantidadStockDestino), vPermitirDecimales)

                    'If Math.Abs(CantidadStockDestino - Fix(CantidadStockDestino)) Then
                    '    Throw New Exception("Error_202303101448M1: El valor a insertar en stock sería un valor decimal no válido, se prevendrá continuar para evitar inconvenientes en reserva.")
                    'End If

                    Insertar(BeStockRes,
                             lConnection,
                             ltransaction)

                End If

            Next

            Inserta_Stock_Reservado = True

        Catch ex As Exception
            Throw ex
        End Try

    End Function

