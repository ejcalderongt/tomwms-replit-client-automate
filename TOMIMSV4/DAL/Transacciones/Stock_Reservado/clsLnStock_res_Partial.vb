    Public Shared Function Get_All_Pickeados_Verificados_By_IdPickingEnc(ByVal pIdPickingEnc As Integer,
                                                                      Optional ByVal pConnection As SqlConnection = Nothing,
                                                                      Optional ByVal pTransaction As SqlTransaction = Nothing) As List(Of clsBeStock_res)

        Dim lReturnList As New List(Of clsBeStock_res)
        Dim vSQL As String = "SELECT sr.* 
                          FROM trans_picking_ubic pu  
                          INNER JOIN trans_picking_det AS pkdet ON pkdet.IdPickingDet = pu.IdPickingDet 
                          INNER JOIN stock_res sr ON pkdet.IdPedidoDet = sr.IdPedidoDet AND pu.IdUbicacion = sr.IdUbicacion  
                          WHERE pkdet.IdPickingEnc = @IdPickingEnc  AND pu.cantidad_recibida <> pu.cantidad_solicitada 
                              AND pu.cantidad_verificada <> pu.cantidad_solicitada AND pu.dañado_picking = 0 and pu.dañado_verificacion = 0 
                              AND pu.no_encontrado = 0 "

        Dim lConnection As SqlConnection = If(pConnection, New SqlConnection(Configuration.ConfigurationManager.AppSettings("CST")))
        Dim Es_Transaccion_Remota As Boolean = (pConnection IsNot Nothing AndAlso pTransaction IsNot Nothing)

        Try
            If Not Es_Transaccion_Remota Then lConnection.Open()

            Using lCmd As New SqlCommand(vSQL, lConnection, If(Es_Transaccion_Remota, pTransaction, Nothing))

                lCmd.CommandType = CommandType.Text
                lCmd.Parameters.Add(New SqlParameter("@IdPickingEnc", pIdPickingEnc))

                Using lDTA As New SqlDataAdapter(lCmd)

                    Dim lDataTable As New DataTable
                    lDTA.Fill(lDataTable)

                    Dim Obj As clsBeStock_res

                    If lDataTable IsNot Nothing AndAlso lDataTable.Rows.Count > 0 Then
                        For Each lRow As DataRow In lDataTable.Rows
                            Obj = New clsBeStock_res
                            Cargar(Obj, lRow)
                            lReturnList.Add(Obj)
                        Next
                    End If

                End Using

            End Using

            Return lReturnList

        Catch ex As Exception
            Throw ex
        Finally
            If Not Es_Transaccion_Remota AndAlso lConnection.State = ConnectionState.Open Then lConnection.Close()
            If Not Es_Transaccion_Remota Then lConnection.Dispose()
        End Try

    End Function
