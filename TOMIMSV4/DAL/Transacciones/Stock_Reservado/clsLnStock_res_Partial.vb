Partial Public Class clsLnStock_res

    Private Shared lUbicaciones As New List(Of clsBeBodega_ubicacion)
    Private Shared lBeConfigInMemory As New List(Of clsBeI_nav_config_enc)
    Private Shared lProductosInMemory As New List(Of clsBeProducto)

    Public Shared Function Stock_Res_Esta_Pickeado_By_IdPedidoDet(ByVal IdPedidoDet As Integer) As Boolean

        Stock_Res_Esta_Pickeado_By_IdPedidoDet = False

        Try

            Dim vSQL As String = "SELECT * FROM stock_res WHERE IdPedidoDet=@IdPedidoDet and IdPicking <> 0 and estado = 'PICKING'"

            Using lConnection As New SqlConnection(Configuration.ConfigurationManager.AppSettings("CST"))

                lConnection.Open()

                Using lTransaction As SqlTransaction = lConnection.BeginTransaction(IsolationLevel.ReadUncommitted)

                    Using lDTA As New SqlDataAdapter(vSQL, lConnection)

                        lDTA.SelectCommand.Transaction = lTransaction
                        lDTA.SelectCommand.CommandType = CommandType.Text
                        lDTA.SelectCommand.Parameters.AddWithValue("@IdPedidoDet", IdPedidoDet)

                        Dim lDataTable As New DataTable
                        lDTA.Fill(lDataTable)

                        Stock_Res_Esta_Pickeado_By_IdPedidoDet = lDataTable.Rows.Count > 0

                        lDataTable.Dispose()
                        lDTA.Dispose()

                    End Using

                    lTransaction.Commit()

                End Using

                lConnection.Close()

                lConnection.Dispose()

            End Using

        Catch ex As Exception
            Dim vMsgError As String = String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message)
            clsLnLog_error_wms.Agregar_Error(vMsgError)
            Throw ex
        End Try

    End Function
    Public Shared Function Tiene_StockRes(ByVal IdPedidoEnc As Integer,
                                          ByVal IdPedidoDet As Integer,
                                          ByRef lConnection As SqlConnection,
                                          ByRef ltransaction As SqlTransaction) As Boolean

        Tiene_StockRes = False

        Try

            Dim vSQL As String = "SELECT * FROM stock_res WHERE IdPedido = @IdPedidoEnc AND IdPedidoDet=@IdPedidoDet "

            Using lDTA As New SqlDataAdapter(vSQL, lConnection)

                lDTA.SelectCommand.CommandType = CommandType.Text
                lDTA.SelectCommand.Transaction = ltransaction
                lDTA.SelectCommand.Parameters.AddWithValue("@IdPedidoDet", IdPedidoDet)
                lDTA.SelectCommand.Parameters.AddWithValue("@IdPedidoEnc", IdPedidoEnc)

                Dim lDataTable As New DataTable
                lDTA.Fill(lDataTable)

                Tiene_StockRes = (lDataTable.Rows.Count > 0)

            End Using

        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try

    End Function
    Public Shared Function Tiene_StockRes_By_IdPedidoEnc(ByVal pIdPedidoEnc As Integer,
                                                         ByVal pIdBodega As Integer,
                                                         ByRef lConnection As SqlConnection,
                                                         ByRef ltransaction As SqlTransaction) As Boolean

        Tiene_StockRes_By_IdPedidoEnc = False

        Try

            Dim vSQL As String = "SELECT * FROM stock_res WHERE IdPedido = @IdPedidoEnc AND IdBodega = @IdBodega"

            Using lDTA As New SqlDataAdapter(vSQL, lConnection)

                lDTA.SelectCommand.CommandType = CommandType.Text
                lDTA.SelectCommand.Transaction = ltransaction
                lDTA.SelectCommand.Parameters.AddWithValue("@IdPedidoEnc", pIdPedidoEnc)
                lDTA.SelectCommand.Parameters.AddWithValue("@IdBodega", pIdBodega)

                Dim lDataTable As New DataTable
                lDTA.Fill(lDataTable)

                Tiene_StockRes_By_IdPedidoEnc = (lDataTable.Rows.Count > 0)

            End Using

        Catch ex As Exception
            Throw New Exception(ex.Message)
        End Try

    End Function
    Private Shared Sub Split_Decimal(ByVal number As Decimal,
                                     ByRef wholePart As Decimal,
                                     ByRef fractionalPart As Decimal)

        Try

            wholePart = Math.Truncate(number)
            fractionalPart = number - wholePart

        Catch ex As Exception
            Dim vMsgError As String = String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message)
            clsLnLog_error_wms.Agregar_Error(vMsgError)
            Throw ex
        End Try

    End Sub

    '#CKFK20220612 Cambié el nombre del parámetro porque aquí lo que se manda es el IdPropietario, no el IdPropietarioBodega
    Public Shared Function Reserva_Stock(ByRef pStockRes As clsBeStock_res,
                                         ByVal pIdPropietario As Integer,
                                         ByVal DiasVencimiento As Double,
                                         ByVal MaquinaQueSolicita As String,
                                         ByRef lConnection As SqlConnection,
                                         ByRef ltransaction As SqlTransaction,
                                         Optional ByVal pExcluirUbicacionPicking As Boolean = False,
                                         Optional BeConfigEnc As clsBeI_nav_config_enc = Nothing) As Boolean

        Reserva_Stock = False


        Try

            Dim lBeStockExistente As New List(Of clsBeStock)
            Dim lBeStockAReservar As New List(Of clsBeStock_res)
            Dim BeProducto As New clsBeProducto()
            Dim BeStockRes As New clsBeStock_res()
            Dim vIdxConfig As Integer = -1
            Dim vCantidadCompletada As Boolean = False
            Dim vCantidadStock As Double = 0
            Dim vCantidadPendiente As Double = 0
            Dim vCantidadSolicitadaPedido As Double = 0
            Dim vValorEnteroCantidadSolicitadaPedido As Integer = 0
            Dim vCantidadAReservarPorIdStock As Double = 0
            Dim vCantidadEnteraPres As Integer = 0
            Dim vCantidadDecimalUMBas As Double = 0
            Dim vIdxPresentacion As Integer = -1
            Dim vCantidadPresentacionAUbicar As Double = 0
            Dim BePresentacion As New clsBeProducto_Presentacion
            Dim vCantidadTarima As Double = 0

            If vIdxConfig = -1 Then

                '#CKFK20220612 Puse esto en comentario porque ya no es necesario obtener el propietario,
                'porque ya la función lo recibe por parámetro
                'Dim vIdPropietario As Integer = clsLnPropietario_bodega.Get_IdPropietario_By_IdBodega_IdPropietarioBodega(pStockRes.IdBodega,
                '                                                                                                          pIdPropietario,
                '                                                                                                          lConnection,
                '                                                                                                          ltransaction)

                If BeConfigEnc Is Nothing Then

                    BeConfigEnc = New clsBeI_nav_config_enc With {.Idnavconfigenc = 1, .IdPropietario = pIdPropietario}

                    BeConfigEnc = clsLnI_nav_config_enc.GetSingle_By_IdBodega_And_IdPropietario(pStockRes.IdBodega,
                                                                                                pIdPropietario,
                                                                                                lConnection,
                                                                                                ltransaction)

                End If

                If Not BeConfigEnc Is Nothing Then
                    lBeConfigInMemory.Add(BeConfigEnc.Clone())
                Else
                    Throw New Exception("ERROR_202210182024: Error al obtener la configuración de interface por IdBodega: " & pStockRes.IdBodega & " e IdPropietario: " & pIdPropietario)
                End If

            Else
                BeConfigEnc = New clsBeI_nav_config_enc With {.Idnavconfigenc = 1}
                BeConfigEnc = lBeConfigInMemory(vIdxConfig).Clone()
            End If

            lBeStockExistente = clsLnStock.lStock(pStockRes,
                                                  BeProducto,
                                                  DiasVencimiento,
                                                  BeConfigEnc,
                                                  lConnection,
                                                  ltransaction,
                                                  pExcluirUbicacionPicking)

            '#EJC20171018_0750PM: Restar el stock reservado de la lista de stock
            Dim vCantidadReservada As Double = 0

            For Each S In lBeStockExistente

                'vCantidadReservada = Get_Cantidad_Reservada_By_IdStock(S.IdStock, lConnection, ltransaction)
                vCantidadReservada = Get_Cantidad_ReservadaUMBas_By_IdStock(S.IdStock,
                                                                            False,
                                                                            lConnection,
                                                                            ltransaction)

                If vCantidadReservada <> 0 Then
                    S.Cantidad -= vCantidadReservada
                End If

            Next

            lBeStockExistente = lBeStockExistente.Where(Function(x) x.Cantidad > 0).ToList()

            If lBeStockExistente.Count > 0 Then

                If pStockRes.IdPresentacion = 0 Then
                    vCantidadSolicitadaPedido = pStockRes.Cantidad
                    'pStockRes.Cantidad =? debería estarse reservando en U.M. bas, 
                    'se debe probar este escenario.
                Else

                    Dim vIdPresentacion As Integer = pStockRes.IdPresentacion
                    Dim BePres As New clsBeProducto_Presentacion

                    vIdxPresentacion = lPresentaciones.FindIndex(Function(x) x.IdPresentacion = vIdPresentacion)

                    If vIdxPresentacion = -1 Then
                        BePres = New clsBeProducto_Presentacion
                        BePres.IdPresentacion = vIdPresentacion
                        clsLnProducto_presentacion.GetSingle(BePres, lConnection, ltransaction)
                        lPresentaciones.Add(BePres.Clone())
                    Else
                        BePres = New clsBeProducto_Presentacion
                        BePres = lPresentaciones(vIdxPresentacion).Clone()
                    End If

                    If BePres.EsPallet Then

                        Dim vFactorPallet As Double = (BePres.Factor * BePres.CajasPorCama * BePres.CamasPorTarima)

                        If vFactorPallet > 0 Then
                            vCantidadSolicitadaPedido = pStockRes.Cantidad * vFactorPallet
                        Else
                            Throw New Exception("No se pudo reservar el stock para el tipo de producto pallet porque los factores de conversión dan un denominador = 0")
                        End If

                    Else

                        '#EJC20190602_0137AM: Extraer la parte decimal y la entera.
                        Split_Decimal(pStockRes.Cantidad, vCantidadEnteraPres, vCantidadDecimalUMBas)
                        '#EJC20190602_0137AM: Multiplicar la parte decimal por el factor, para obtener la cantidad de unidades de medida básica.
                        vCantidadDecimalUMBas = Math.Ceiling(vCantidadDecimalUMBas * BePres.Factor)

                        '#EJC20190602_0137AM: Anteriormente se multiplicaba la cantidad por el factor (pej. 12.3 * 12)
                        'vCantidadSolicitadaPedido = pStockRes.Cantidad * BePres.Factor
                        If vCantidadEnteraPres > 0 Then
                            vCantidadSolicitadaPedido = vCantidadEnteraPres
                        Else
                            vCantidadSolicitadaPedido = vCantidadDecimalUMBas
                        End If

                        If Not clsLnProducto.Tiene_Control_Por_Peso_By_IdProductoBodega(pStockRes.IdProductoBodega, lConnection, ltransaction) Then
                            If Integer.TryParse(vCantidadSolicitadaPedido, vValorEnteroCantidadSolicitadaPedido) Then
                                vCantidadSolicitadaPedido = vValorEnteroCantidadSolicitadaPedido
                            Else
                                vCantidadSolicitadaPedido = Math.Truncate(vCantidadSolicitadaPedido)
                            End If
                        Else
                            vCantidadSolicitadaPedido = Math.Round(vCantidadSolicitadaPedido, 6)
                        End If

                    End If

                End If

                If Not lBeStockExistente Is Nothing Then

                    '#EJC20180614: Cantidad total disponible en stock.
                    vCantidadStock = lBeStockExistente.Sum(Function(x) x.Cantidad)

                    If vCantidadSolicitadaPedido > vCantidadStock Then
                        Throw New Exception(String.Format("{0} Código: {1} Sol: {2} Disp: {3}. " & vbNewLine, clsDalEx.ErrorS0002, BeProducto.Codigo, vCantidadSolicitadaPedido, vCantidadStock))
                    End If

                    vCantidadPendiente = vCantidadSolicitadaPedido

                    For Each vStock As clsBeStock In lBeStockExistente

                        '#EJC20180611: Redonde a 6 cifras decimales.
                        vCantidadStock = Math.Round(vStock.Cantidad, 6)

                        If vCantidadStock = 0 Then
                            Debug.Print("Cantidad = 0")
                        End If

                        '#EJC20180620: Si la cantidad de un IdStock es 0, es porque la cantidad reservada es igual a lo disponible, por eso se valida aquí.
                        If vCantidadStock > 0 Then

                            BeStockRes = New clsBeStock_res
                            BeStockRes.IdTransaccion = pStockRes.IdTransaccion
                            '#CKFK 20210221 10:01 PM Modifiqué que el indicador fijo tenga PED para que tome el indicador de pStockRes
                            BeStockRes.Indicador = pStockRes.Indicador '"PED"
                            BeStockRes.IdBodega = vStock.IdBodega
                            BeStockRes.IdStock = vStock.IdStock
                            BeStockRes.IdPropietarioBodega = vStock.IdPropietarioBodega
                            BeStockRes.IdProductoBodega = vStock.IdProductoBodega

                            If vCantidadPendiente = vCantidadStock Then
                                vCantidadAReservarPorIdStock = vCantidadStock
                                vCantidadPendiente -= vCantidadStock
                                vCantidadPendiente = Math.Round(vCantidadPendiente, 6)
                            ElseIf vCantidadPendiente < vCantidadStock Then
                                vCantidadAReservarPorIdStock = vCantidadPendiente
                                vCantidadPendiente -= vCantidadAReservarPorIdStock
                                vCantidadPendiente = Math.Round(vCantidadPendiente, 6)
                            ElseIf vCantidadPendiente > vCantidadStock Then
                                vCantidadAReservarPorIdStock = vCantidadStock
                                vCantidadPendiente -= vCantidadStock
                                vCantidadPendiente = Math.Round(vCantidadPendiente, 6)
                            End If

                            BeStockRes.IdUbicacion = vStock.IdUbicacion
                            BeStockRes.IdProductoEstado = vStock.ProductoEstado.IdEstado


                            If pStockRes.IdPresentacion = 0 Then
                                BeStockRes.IdPresentacion = 0
                            Else
                                BeStockRes.IdPresentacion = vStock.Presentacion.IdPresentacion
                            End If

                            BeStockRes.IdUnidadMedida = vStock.IdUnidadMedida
                            BeStockRes.Lote = vStock.Lote
                            BeStockRes.Lic_plate = vStock.Lic_plate
                            BeStockRes.Serial = vStock.Serial
                            BeStockRes.Peso = vStock.Peso
                            BeStockRes.Estado = "UNCOMMITED"
                            BeStockRes.Fecha_ingreso = vStock.Fecha_Ingreso
                            BeStockRes.Fecha_vence = vStock.Fecha_vence
                            BeStockRes.Uds_lic_plate = vStock.Uds_lic_plate
                            '#CF 20171120 06:41PM Guardé en el campo Ubicacion_ant el id de la ubicación anterio de Stock
                            BeStockRes.Ubicacion_ant = vStock.IdUbicacion_anterior
                            BeStockRes.No_bulto = vStock.No_bulto
                            BeStockRes.IdRecepcion = vStock.IdRecepcionEnc
                            BeStockRes.IdPicking = 0
                            BeStockRes.IdPedido = pStockRes.IdPedido
                            BeStockRes.IdPedidoDet = pStockRes.IdPedidoDet
                            BeStockRes.IdDespacho = 0
                            BeStockRes.añada = vStock.Añada
                            BeStockRes.Fecha_manufactura = vStock.Fecha_Manufactura
                            '#CM20181308_3:23PM:Redondea la cantidad a reservar por IdStock a 6 cifras.
                            BeStockRes.Cantidad = Math.Round(vCantidadAReservarPorIdStock, 6)
                            BeStockRes.IdRecepcion = vStock.IdRecepcionEnc
                            '#EJC20171018_0715PM: Registrar en tabla stock_res la PC que bloqueó/reservó el stock
                            BeStockRes.Host = MaquinaQueSolicita
                            vCantidadCompletada = (vCantidadPendiente = 0)

                            'pStockRes.Cantidad = vCantidadReservada
                            lBeStockAReservar.Add(BeStockRes)

                            If vCantidadCompletada Then
                                Exit For
                            End If

                        End If

                    Next

                End If

                If lBeStockAReservar.Count > 0 Then

                    If Inserta_Stock_Reservado(lBeStockAReservar, lConnection, ltransaction) Then

                        '#EJC20190602: Si existe cantidad en fracción se reserva en unidad de medida básica en base a: ('#EJC20190602_0137AM_REF20190602-0848)
                        If vCantidadDecimalUMBas > 0 Then
                            BeStockRes.Cantidad = vCantidadDecimalUMBas
                            BeStockRes.IdPresentacion = 0
                            Reserva_Stock(BeStockRes,
                                          pIdPropietario,
                                          DiasVencimiento,
                                          MaquinaQueSolicita,
                                          lConnection,
                                          ltransaction)
                        End If

                        Reserva_Stock = True

                    Else
                        Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0006, pStockRes.IdProductoBodega))
                    End If

                Else
                    Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0005, pStockRes.IdProductoBodega))
                End If

            Else
                Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0004, pStockRes.IdProductoBodega))
            End If

        Catch ex As Exception
            Dim vMsgError As String = String.Format("ERROR_20220825_1417: {0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message)
            clsLnLog_error_wms.Agregar_Error(vMsgError)
            Throw ex
        End Try

    End Function

    ''' <summary>
    ''' #EJC20220523: Reserva_Stock_NAV_BYB
    ''' </summary>
    ''' <param name="pStockRes"></param>
    ''' <param name="DiasVencimiento"></param>
    ''' <param name="MaquinaQueSolicita"></param>
    ''' <param name="pListStockResOUT"></param>
    ''' <param name="pIdEmpresa"></param>
    ''' <param name="pIdBodega"></param>
    ''' <param name="pIdPropietario"></param>
    ''' <param name="lConnection"></param>
    ''' <param name="ltransaction"></param>
    ''' <returns></returns>
    Public Shared Function Reserva_Stock_NAV_BYB(ByRef pStockRes As clsBeStock_res,
                                                ByVal DiasVencimiento As Double,
                                                ByVal MaquinaQueSolicita As String,
                                                ByRef pListStockResOUT As List(Of clsBeStock_res),
                                                ByVal pIdEmpresa As Integer,
                                                ByVal pIdBodega As Integer,
                                                ByVal pIdPropietario As Integer,
                                                ByRef lConnection As SqlConnection,
                                                ByRef ltransaction As SqlTransaction) As Boolean

        Reserva_Stock_NAV_BYB = False

        'Inicializar la lista que se obtuvo despues de reservar stock en base a los parámetros solicitados
        pListStockResOUT = Nothing
        Dim vIdxConfig As Integer = -1

        Try

            Dim lBeStockExistente As New List(Of clsBeStock)
            Dim lBeStockAReservar As New List(Of clsBeStock_res)

            Dim BeProducto As New clsBeProducto
            Dim BeStockRes As New clsBeStock_res

            Dim vIdPresentacion As Integer = pStockRes.IdPresentacion

            Dim BeConfigEnc As New clsBeI_nav_config_enc With {.Idnavconfigenc = 1, .IdPropietario = pIdPropietario}

            lBeStockExistente = clsLnStock.lStock(pStockRes,
                                                  BeProducto,
                                                  DiasVencimiento,
                                                  BeConfigEnc,
                                                  lConnection,
                                                  ltransaction)

            '#EJC20171018_0750PM: Restar el stock reservado de la lista de stock
            Dim vCantidadReservada As Double = 0
            Dim vPesoReservado As Double = 0

            For Each S In lBeStockExistente

                If Get_Cantidad_Y_Peso_ReservadaUMBas_By_IdStock(S.IdStock,
                                                                False,
                                                                vCantidadReservada,
                                                                vPesoReservado,
                                                                lConnection,
                                                                ltransaction) Then

                    If vCantidadReservada <> 0 Then
                        S.Cantidad -= vCantidadReservada
                        S.Peso -= vPesoReservado
                    End If

                End If

            Next

            If lBeStockExistente.Count > 0 Then

                Dim vCantidadCompletada As Boolean = False
                Dim vCantidadStock As Double = 0
                Dim vCantidadStockEnPres As Double = 0
                Dim vPesoStock As Double = 0
                Dim vPesoPendiente As Double = 0
                Dim vCantidadPendiente As Double = 0
                Dim vCantidadSolicitadaPedido As Double = 0
                Dim vPesoSolicitadoPedido As Double = 0
                Dim vValorEnteroCantidadSolicitadaPedido As Integer = 0
                Dim vCantidadAReservarPorIdStock As Double = 0
                Dim vPesoAReservarPorIdStock As Double = 0
                Dim Idx As Integer = 0
                Dim BePres As New clsBeProducto_Presentacion
                Dim vCantidadEnStockEnPres As Double = 0

                '#EJC20190602_0137AM: Si piden cantidades decimales hacer la conversión a unidades de medida básica.
                Dim vCantidadEnteraPres As Double = 0
                Dim vCantidadDecimalUMBas As Double = 0
                Dim pBeConfigEnc As New clsBeI_nav_config_enc

                Dim vCantidadEnteraStockPres As Double = 0
                Dim vCantidadDecimalStockUMBas As Double = 0

                Dim vPesoEnteroPres As Double = 0
                Dim vPesoDecimalUMBas As Double = 0

                Dim vPesoEnteroPresStock As Double = 0
                Dim vPesoDecimalStockUMBas As Double = 0

                Dim vCantidadSolicitadaPedidoEnPres As Double = 0

                If pStockRes.IdPresentacion = 0 Then
                    '#CM_20180802: Redonde la cantidad solicitada a 6 decimales. 
                    vCantidadSolicitadaPedido = Math.Round(pStockRes.Cantidad, 6)
                    vPesoSolicitadoPedido = Math.Round(pStockRes.Peso, 6)
                    'pStockRes.Cantidad =? debería estarse reservando en U.M. bas, 
                    'se debe probar este escenario.
                Else

                    Idx = lPresentaciones.FindIndex(Function(x) x.IdPresentacion = vIdPresentacion)

                    If Idx = -1 Then
                        BePres = New clsBeProducto_Presentacion()
                        BePres.IdPresentacion = pStockRes.IdPresentacion
                        clsLnProducto_presentacion.GetSingle(BePres, lConnection, ltransaction)
                        lPresentaciones.Add(BePres.Clone())
                    Else
                        BePres = New clsBeProducto_Presentacion()
                        BePres = lPresentaciones(Idx).Clone()
                    End If

                    If BePres.EsPallet Then

                        Dim vFactorPallet As Double = (BePres.Factor * BePres.CajasPorCama * BePres.CamasPorTarima)

                        If vFactorPallet > 0 Then
                            vCantidadSolicitadaPedido = pStockRes.Cantidad * vFactorPallet
                        Else
                            Throw New Exception("No se pudo reservar el stock para el tipo de producto pallet porque los factores de conversión dan un denominador = 0")
                        End If

                    Else

                        pBeConfigEnc = clsLnI_nav_config_enc.Get_Single_By_IdBodega_And_IdEmpresa(pIdBodega, pIdEmpresa, lConnection, ltransaction)

                        If Not pBeConfigEnc Is Nothing Then

                            If pBeConfigEnc.Explosion_Automatica Then

                                '#EJC20190602_0137AM: Extraer la parte decimal y la entera
                                Split_Decimal(pStockRes.Cantidad, vCantidadEnteraPres, vCantidadDecimalUMBas)
                                Split_Decimal(pStockRes.Peso, vPesoEnteroPres, vPesoDecimalUMBas)

                                '#EJC20190602_0137AM: Multiplicar la parte decimal por el factor, para obtener la cantidad de unidades de medida básica.
                                vCantidadDecimalUMBas = Math.Ceiling(Math.Round(vCantidadDecimalUMBas * BePres.Factor, 2))

                                '#EJC20190602_0137AM: Anteriormente se multiplicaba la cantidad por el factor (pej. 12.3 * 12)
                                'vCantidadSolicitadaPedido = pStockRes.Cantidad * BePres.Factor
                                If vCantidadEnteraPres > 0 Then
                                    vCantidadSolicitadaPedido = vCantidadEnteraPres * BePres.Factor
                                    vPesoSolicitadoPedido = vPesoEnteroPres
                                Else
                                    vCantidadSolicitadaPedido = vCantidadDecimalUMBas
                                    vPesoSolicitadoPedido = vPesoDecimalUMBas
                                End If

                            Else

                                vCantidadSolicitadaPedido = pStockRes.Cantidad * BePres.Factor
                                '#EJC20220303: En teoría el peso ya viene proporcional desde el pedido.
                                vPesoSolicitadoPedido = pStockRes.Peso

                            End If

                        Else
                            vCantidadSolicitadaPedido = pStockRes.Cantidad * BePres.Factor
                            vPesoSolicitadoPedido = pStockRes.Peso
                        End If

                        '#CM_20180802: Se agregó función para obtener el control peso del producto. 
                        If Not clsLnProducto.Tiene_Control_Por_Peso_By_IdProductoBodega(pStockRes.IdProductoBodega, lConnection, ltransaction) Then

                            '#CM_20180802: Si el producto no tiene control de peso la presentación debe contener una cantidad exacta de UMBas sino se trunca la cantidad. 
                            If Integer.TryParse(vCantidadSolicitadaPedido, vValorEnteroCantidadSolicitadaPedido) Then
                                vCantidadSolicitadaPedido = vValorEnteroCantidadSolicitadaPedido
                            Else
                                vCantidadSolicitadaPedido = Math.Truncate(vCantidadSolicitadaPedido)
                            End If

                        Else
                            '#CM_20180802: Redonde la cantidad solicitada a 6 decimales por que el producto tiene control de peso.  
                            vCantidadSolicitadaPedido = Math.Round(vCantidadSolicitadaPedido, 6)
                            vPesoSolicitadoPedido = Math.Round(vPesoSolicitadoPedido, 6)
                        End If

                    End If

                End If


                '#EJC20191122:
                'Si la solicitud del inventario es en X presentación, 
                'Se busca el stock existente solo en esa presentación.
                'Pensar adelante en parámetro que permita reservar en otras unidades como pej: en umbas.
                'If pStockRes.IdPresentacion <> 0 Then
                '    lBeStockExistente = lBeStockExistente.Where(Function(X) X.IdPresentacion = vIdPresentacion).ToList()
                'End If


                If Not lBeStockExistente Is Nothing Then

                    '#EJC20180614: Cantidad total disponible en stock.
                    vCantidadStock = lBeStockExistente.Sum(Function(x) x.Cantidad)
                    vPesoStock = lBeStockExistente.Sum(Function(x) x.Peso)

                    If pBeConfigEnc.Explosion_Automatica Then

                        If pStockRes.IdPresentacion = 0 Then

                            If vCantidadSolicitadaPedido > vCantidadStock Then
                                Throw New Exception(String.Format("{0} Código: {1} Sol: {2} Disp: {3}. " & vbNewLine, clsDalEx.ErrorS0002,
                                                                  BeProducto.Codigo,
                                                                  vCantidadSolicitadaPedido,
                                                                  vCantidadStock))
                            End If

                        Else

                            If Not BePres Is Nothing Then

                                If (BePres.Factor > 0) Then

                                    vCantidadStockEnPres = Math.Round(vCantidadStock / BePres.Factor, 6)

                                    vCantidadSolicitadaPedidoEnPres = Math.Round(vCantidadSolicitadaPedido / BePres.Factor, 6)

                                    If vCantidadSolicitadaPedidoEnPres > vCantidadStockEnPres Then
                                        Throw New Exception(vbNewLine & String.Format("{0} Código: {1} Sol: {2} Disp: {3}", clsDalEx.ErrorS0002A, BeProducto.Codigo, vCantidadSolicitadaPedido, vCantidadStock))
                                    End If

                                End If

                            End If

                        End If

                    Else

                        If vCantidadSolicitadaPedido > vCantidadStock Then
                            Throw New Exception(vbNewLine & String.Format("{0} Código: {1} Sol: {2} Disp: {3}. " & vbNewLine, clsDalEx.ErrorS0002,
                                                BeProducto.Codigo,
                                                vCantidadSolicitadaPedido,
                                                vCantidadStock))
                        End If

                    End If

                    vCantidadPendiente = vCantidadSolicitadaPedido
                    vPesoPendiente = vPesoSolicitadoPedido

                    For Each vStock As clsBeStock In lBeStockExistente

                        '#EJC20180611: Redonde a 6 cifras decimales.
                        vCantidadStock = Math.Round(vStock.Cantidad, 6)
                        vPesoStock = Math.Round(vStock.Peso, 6)

                        '#EJC20180620: Si la cantidad de un IdStock es 0, es porque la cantidad reservada es igual a lo disponible, por eso se valida aquí.
                        If vCantidadStock > 0 Then

                            BeStockRes = New clsBeStock_res
                            BeStockRes.IdTransaccion = pStockRes.IdTransaccion
                            BeStockRes.Indicador = "PED"
                            BeStockRes.IdBodega = vStock.IdBodega
                            BeStockRes.IdStock = vStock.IdStock
                            BeStockRes.IdPropietarioBodega = vStock.IdPropietarioBodega
                            BeStockRes.IdProductoBodega = vStock.IdProductoBodega

                            If vCantidadPendiente = vCantidadStock Then
                                vCantidadAReservarPorIdStock = vCantidadStock
                                vPesoAReservarPorIdStock = vPesoStock
                                vCantidadPendiente -= vCantidadStock
                            ElseIf vCantidadPendiente < vCantidadStock Then
                                vCantidadAReservarPorIdStock = vCantidadPendiente
                                vPesoAReservarPorIdStock = Math.Round(vPesoPendiente, 6)
                                vCantidadPendiente -= vCantidadAReservarPorIdStock
                            ElseIf vCantidadPendiente > vCantidadStock Then

                                If pBeConfigEnc.Codigo_proveedor_produccion = "1060315" Then

                                    vCantidadEnStockEnPres = Math.Round(vCantidadStock / BePres.Factor, 6)

                                    '#EJC20190602_0137AM: Extraer la parte decimal y la entera
                                    Split_Decimal(vCantidadEnStockEnPres, vCantidadEnteraStockPres, vCantidadDecimalStockUMBas)
                                    Split_Decimal(pStockRes.Peso, vPesoEnteroPresStock, vPesoDecimalStockUMBas)

                                    '#EJC20190602_0137AM: Multiplicar la parte decimal por el factor, para obtener la cantidad de unidades de medida básica.
                                    vCantidadDecimalUMBas = Math.Ceiling(Math.Round(vCantidadDecimalUMBas * BePres.Factor, 2))


                                    '#EJC20220510: Si hay decimal en la posición, llevarnos solo la cantidad entera (de momento)
                                    If vCantidadDecimalStockUMBas > 0 AndAlso vCantidadEnteraStockPres > 0 Then

                                        vCantidadAReservarPorIdStock = Math.Round(vCantidadEnteraStockPres * BePres.Factor, 6)
                                        vPesoAReservarPorIdStock = vPesoEnteroPresStock
                                        vCantidadPendiente -= vCantidadAReservarPorIdStock
                                        vPesoPendiente -= vPesoEnteroPresStock

                                        '#EJC20220510: Para byb hotfix, evitar que reserve parciales.
                                        'Continue For

                                    Else

                                        If vCantidadEnteraStockPres > 0 Then
                                            vCantidadAReservarPorIdStock = Math.Round(vCantidadEnteraStockPres * BePres.Factor, 6)
                                            vPesoAReservarPorIdStock = vPesoEnteroPresStock
                                            vCantidadPendiente -= vCantidadAReservarPorIdStock
                                            vPesoPendiente -= vPesoEnteroPresStock
                                        Else
                                            '#EJC20220510: Para byb hotfix, evitar que reserve parciales. (En teoría hay menos)
                                            Continue For
                                            'vCantidadAReservarPorIdStock = vCantidadStock
                                            'vPesoAReservarPorIdStock = vPesoStock
                                            'vCantidadPendiente -= vCantidadStock
                                            'vPesoPendiente -= vPesoStock
                                        End If

                                    End If


                                Else

                                    vCantidadAReservarPorIdStock = vCantidadStock
                                    vPesoAReservarPorIdStock = vPesoStock
                                    vCantidadPendiente -= vCantidadStock
                                    vPesoPendiente -= vPesoStock

                                End If


                            End If

                            BeStockRes.IdUbicacion = vStock.IdUbicacion
                            BeStockRes.IdProductoEstado = vStock.ProductoEstado.IdEstado


                            If pStockRes.IdPresentacion = 0 Then
                                BeStockRes.IdPresentacion = 0
                            Else
                                BeStockRes.IdPresentacion = vStock.Presentacion.IdPresentacion
                            End If

                            BeStockRes.IdUnidadMedida = vStock.IdUnidadMedida
                            BeStockRes.Lote = vStock.Lote
                            BeStockRes.Lic_plate = vStock.Lic_plate
                            BeStockRes.Serial = vStock.Serial
                            BeStockRes.Estado = "UNCOMMITED"
                            BeStockRes.Fecha_ingreso = vStock.Fecha_Ingreso
                            BeStockRes.Fecha_vence = vStock.Fecha_vence
                            BeStockRes.Uds_lic_plate = vStock.Uds_lic_plate
                            '#CF 20171120 06:41PM Guardé en el campo Ubicacion_ant el id de la ubicación anterio de Stock
                            BeStockRes.Ubicacion_ant = vStock.IdUbicacion_anterior
                            BeStockRes.No_bulto = vStock.No_bulto
                            BeStockRes.IdRecepcion = vStock.IdRecepcionEnc
                            BeStockRes.IdPicking = 0
                            BeStockRes.IdPedido = pStockRes.IdPedido
                            BeStockRes.IdPedidoDet = pStockRes.IdPedidoDet
                            BeStockRes.IdDespacho = 0
                            BeStockRes.añada = vStock.Añada
                            BeStockRes.Fecha_manufactura = vStock.Fecha_Manufactura
                            '#CM20181308_3:23PM:Redondea la cantidad a reservar por IdStock a 6 cifras.
                            BeStockRes.Cantidad = Math.Round(vCantidadAReservarPorIdStock, 6)
                            '#EJC20220303: Cealsa, reservar peso proporcional
                            BeStockRes.Peso = Math.Round(vPesoAReservarPorIdStock, 6)
                            BeStockRes.IdRecepcion = vStock.IdRecepcionEnc
                            '#EJC20171018_0715PM: Registrar en tabla stock_res la PC que bloqueó/reservó el stock
                            BeStockRes.Host = MaquinaQueSolicita
                            vCantidadCompletada = (vCantidadPendiente = 0)

                            'pStockRes.Cantidad = vCantidadReservada
                            lBeStockAReservar.Add(BeStockRes)

                            If vCantidadCompletada Then
                                Exit For
                            End If

                        End If

                    Next

                End If

                If lBeStockAReservar.Count > 0 Then

                    If Inserta_Stock_Reservado(lBeStockAReservar, lConnection, ltransaction) Then

                        If Not pBeConfigEnc Is Nothing Then
                            If pBeConfigEnc.Explosion_Automatica Then
                                If vCantidadDecimalUMBas > 0 Then
                                    BeStockRes.Cantidad = vCantidadDecimalUMBas
                                    BeStockRes.IdPresentacion = 0
                                    Reserva_Stock_NAV_BYB(BeStockRes,
                                                        DiasVencimiento,
                                                        MaquinaQueSolicita,
                                                        pListStockResOUT,
                                                        pIdEmpresa,
                                                        pIdBodega,
                                                        pIdPropietario,
                                                        lConnection,
                                                        ltransaction)
                                End If
                            End If
                        End If

                        Reserva_Stock_NAV_BYB = True
                        pListStockResOUT = lBeStockAReservar

                    Else
                        Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0006, pStockRes.IdProductoBodega))
                    End If

                Else
                    Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0005, pStockRes.IdProductoBodega))
                End If

            Else
                Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0004, pStockRes.IdProductoBodega))
            End If

        Catch ex As Exception
            Dim vMsgError As String = String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message)
            clsLnLog_error_wms.Agregar_Error(vMsgError)
            Throw ex
        End Try

    End Function

    Private Shared vRecursionSolicitud As Integer = 0
    Public Shared Function Reserva_Stock_Lista_Result(ByRef pStockRes As clsBeStock_res,
                                                      ByVal DiasVencimiento As Double,
                                                      ByVal MaquinaQueSolicita As String,
                                                      ByVal pBeConfigEnc As clsBeI_nav_config_enc,
                                                      ByRef pBeTrasladoDet As clsBeI_nav_ped_traslado_det,
                                                      ByVal pIdPropietario As Integer,
                                                      ByVal Conmutar_Umbas_A_Presentacion As Boolean,
                                                      ByRef lConnection As SqlConnection,
                                                      ByRef ltransaction As SqlTransaction) As List(Of clsBeStock_res)

        Reserva_Stock_Lista_Result = Nothing

        Try

            Dim lBeStockExistente As New List(Of clsBeStock)
            Dim lBeStockAReservar As New List(Of clsBeStock_res)
            Dim lBeStockAReservarRecursivo As New List(Of clsBeStock_res)
            Dim BeProductoPresentacion As New clsBeProducto_Presentacion()
            Dim vIndicePresentacion As Integer = 0
            Dim vIdxConfig As Integer = -1
            Dim BeProducto As New clsBeProducto
            Dim BeStockRes As New clsBeStock_res
            Dim BeConfigEnc As New clsBeI_nav_config_enc With {.Idnavconfigenc = 1, .IdPropietario = pIdPropietario}
            Dim BeStockOrigen As New clsBeStock
            Dim BeStockDestino As New clsBeStock
            Dim BePres As New clsBeProducto_Presentacion()

            If vIdxConfig = -1 Then

                BeConfigEnc = clsLnI_nav_config_enc.GetSingle_By_IdBodega_And_IdPropietario(pStockRes.IdBodega,
                                                                                            pIdPropietario,
                                                                                            lConnection,
                                                                                            ltransaction)
                lBeConfigInMemory.Add(BeConfigEnc.Clone())

            Else
                BeConfigEnc = New clsBeI_nav_config_enc With {.Idnavconfigenc = 1}
                BeConfigEnc = lBeConfigInMemory(vIdxConfig).Clone()
            End If

            lBeStockExistente = clsLnStock.lStock(pStockRes,
                                                  BeProducto,
                                                  DiasVencimiento,
                                                  BeConfigEnc,
                                                  lConnection,
                                                  ltransaction,
                                                  False,
                                                  Conmutar_Umbas_A_Presentacion)

            Debug.WriteLine("Codigo Producto: " & BeProducto.Codigo & " " & "Tiene " & lBeStockExistente.Count & " Registros de stock.")

            If (lBeStockExistente.Count = 0 AndAlso Not Conmutar_Umbas_A_Presentacion) AndAlso BeConfigEnc.Explosion_Automatica Then

                lBeStockExistente = clsLnStock.lStock(pStockRes,
                                                      BeProducto,
                                                      DiasVencimiento,
                                                      BeConfigEnc,
                                                      lConnection,
                                                      ltransaction,
                                                      False,
                                                      True)

            End If

            '#EJC20171018_0750PM: Restar el stock reservado de la lista de stock
            Dim vCantidadReservada As Double = 0

            For Each S In lBeStockExistente

                '#CKFK20220322 Obtengo lo reservado en UMBas para que la resta funcione correctamente
                vCantidadReservada = Get_Cantidad_ReservadaUMBas_By_IdStock(S.IdStock,
                                                                            False,
                                                                            lConnection,
                                                                            ltransaction)

                If vCantidadReservada <> 0 Then

                    If S.IdPresentacion <> 0 Then

                        vIndicePresentacion = lPresentaciones.FindIndex(Function(x) x.IdPresentacion = S.IdPresentacion)

                        If vIndicePresentacion <> -1 Then
                            BeProductoPresentacion = New clsBeProducto_Presentacion()
                            BeProductoPresentacion = lPresentaciones(vIndicePresentacion).Clone()
                        Else
                            BeProductoPresentacion = New clsBeProducto_Presentacion()
                            BeProductoPresentacion.IdPresentacion = S.IdPresentacion
                            clsLnProducto_presentacion.GetSingle(BeProductoPresentacion,
                                                                 lConnection,
                                                                 ltransaction)
                            lPresentaciones.Add(BeProductoPresentacion.Clone())
                        End If

                        '#CKFK20220321 Aquí no aplica lo de multiplicar por el factor, porque lo reservado se obtiene en UMBAS
                        'vCantidadReservada = Math.Round(vCantidadReservada * BeProductoPresentacion.Factor, 6)
                        S.Cantidad -= vCantidadReservada

                    Else
                        S.Cantidad -= vCantidadReservada
                    End If

                End If

            Next

            If lBeStockExistente.Count > 0 Then

                Dim vCantidadCompletada As Boolean = False
                Dim vCantidadDispStock As Double = 0
                Dim vCantidadPendiente As Double = 0
                Dim vCantidadSolicitadaPedido As Double = 0
                Dim vValorEnteroCantidadSolicitadaPedido As Integer = 0
                Dim vCantidadAReservarPorIdStock As Double = 0
                Dim vCantidadEnteraPres As Integer = 0
                Dim vCantidadDecimalUMBas As Double = 0
                Dim vCantidadDecimalUMBasStock As Double = 0
                Dim vPesoEnteroPres As Integer = 0
                Dim vPesoDecimalUMBas As Double = 0
                Dim vPesoSolicitadoPedido As Double = 0
                Dim vIdProducto As Integer = 0

                If pStockRes.IdPresentacion = 0 Then
                    vCantidadSolicitadaPedido = pStockRes.Cantidad
                Else

                    BePres = New clsBeProducto_Presentacion With {.IdPresentacion = pStockRes.IdPresentacion}

                    vIndicePresentacion = lPresentaciones.FindIndex(Function(x) x.IdPresentacion = BePres.IdPresentacion)

                    If vIndicePresentacion <> -1 Then
                        BePres = New clsBeProducto_Presentacion()
                        BePres = lPresentaciones(vIndicePresentacion).Clone()
                    Else
                        BePres = New clsBeProducto_Presentacion()
                        BePres.IdPresentacion = pStockRes.IdPresentacion
                        clsLnProducto_presentacion.GetSingle(BePres, lConnection, ltransaction)
                        lPresentaciones.Add(BePres.Clone())
                    End If

                    If BePres.EsPallet Then

                        Dim vFactorPallet As Double = (BePres.Factor * BePres.CajasPorCama * BePres.CamasPorTarima)

                        If vFactorPallet > 0 Then
                            vCantidadSolicitadaPedido = pStockRes.Cantidad * vFactorPallet
                        Else
                            Throw New Exception("No se pudo reservar el stock para el tipo de producto pallet porque los factores de conversión dan un denominador = 0")
                        End If

                    Else

                        If (pBeConfigEnc.Explosion_Automatica) Then

                            If pBeConfigEnc.Explosion_Automatica Then

                                '#EJC20190602_0137AM: Extraer la parte decimal y la entera
                                Split_Decimal(pStockRes.Cantidad, vCantidadEnteraPres, vCantidadDecimalUMBas)
                                Split_Decimal(pStockRes.Peso, vPesoEnteroPres, vPesoDecimalUMBas)

                                '#EJC20190602_0137AM: Multiplicar la parte decimal por el factor, para obtener la cantidad de unidades de medida básica.
                                vCantidadDecimalUMBas = Math.Ceiling(Math.Round(vCantidadDecimalUMBas * BePres.Factor, 2))

                                '#EJC20190602_0137AM: Anteriormente se multiplicaba la cantidad por el factor (pej. 12.3 * 12)
                                'vCantidadSolicitadaPedido = pStockRes.Cantidad * BePres.Factor
                                If vCantidadEnteraPres > 0 Then
                                    vCantidadSolicitadaPedido = vCantidadEnteraPres * BePres.Factor
                                    vPesoSolicitadoPedido = vPesoEnteroPres
                                Else
                                    vCantidadSolicitadaPedido = vCantidadDecimalUMBas
                                    vPesoSolicitadoPedido = vPesoDecimalUMBas
                                End If

                            Else

                                vCantidadSolicitadaPedido = pStockRes.Cantidad * BePres.Factor
                                '#EJC20220303: En teoría el peso ya viene proporcional desde el pedido.
                                vPesoSolicitadoPedido = pStockRes.Peso

                            End If


                        Else
                            '#EJC20190602_0137AM: Anteriormente se multiplicaba la cantidad por el factor (pej. 12.3 * 12)
                            '#EJC20220314: Aquí se multiplica por el factor para obtener la cantidad a reservar en UMBAS.
                            vCantidadSolicitadaPedido = pStockRes.Cantidad * BePres.Factor
                        End If

                        If Not clsLnProducto.Tiene_Control_Por_Peso_By_IdProductoBodega(pStockRes.IdProductoBodega, lConnection, ltransaction) Then
                            If Integer.TryParse(vCantidadSolicitadaPedido, vValorEnteroCantidadSolicitadaPedido) Then
                                vCantidadSolicitadaPedido = vValorEnteroCantidadSolicitadaPedido
                            Else
                                vCantidadSolicitadaPedido = Math.Truncate(vCantidadSolicitadaPedido)
                            End If
                        Else
                            vCantidadSolicitadaPedido = Math.Round(vCantidadSolicitadaPedido, 6)
                        End If

                    End If

                End If

                If Not lBeStockExistente Is Nothing Then

                    '#EJC20180614: Cantidad total disponible en stock.
                    vCantidadDispStock = lBeStockExistente.Sum(Function(x) x.Cantidad)

                    If vCantidadSolicitadaPedido > vCantidadDispStock Then

                        '#EJC20190702: En un futuro cercano....
                        If pBeConfigEnc.Despachar_existencia_parcial = tDespacharExistenciaParcial.No Then
                            Throw New Exception(String.Format("{0} Código: {1} Sol: {2} Disp: {3}",
                                                              clsDalEx.ErrorS0002,
                                                              BeProducto.Codigo,
                                                              vCantidadSolicitadaPedido,
                                                              vCantidadDispStock))
                        Else
                            If vCantidadDispStock > 0 Then
                                pBeTrasladoDet.Qty_to_Receive = vCantidadDispStock
                                pBeTrasladoDet.Is_Partially_Processed = True
                                clsLnI_nav_ped_traslado_det.Actualizar_Partially_Processed(pBeTrasladoDet,
                                                                                           lConnection,
                                                                                           ltransaction)
                            End If
                        End If

                    Else
                        '#EJC20220328: This is the default value, just to be explicit
                        'We are not taking a partial quantity so, we don't update the table.
                        pBeTrasladoDet.Is_Partially_Processed = False
                    End If

                    vCantidadPendiente = vCantidadSolicitadaPedido

                    Dim vCantidadEnStockEnPres As Double = 0
                    Dim vCantidadDecimalStockUMBas As Double = 0
                    Dim vCantidadEnteraStockPres As Double = 0
                    Dim vPesoEnteroPresStock As Double = 0
                    Dim vPesoDecimalStockUMBas As Double = 0
                    Dim vPesoAReservarPorIdStock As Double = 0
                    Dim vPesoPendiente As Double = 0

                    For Each vStockOrigen As clsBeStock In lBeStockExistente

                        BeStockDestino = New clsBeStock()
                        '#EJC20220510: Copiar stock_origen.
                        clsPublic.CopyObject(vStockOrigen, BeStockDestino)

                        '#EJC20180611: Redonde a 6 cifras decimales.
                        vCantidadDispStock = Math.Round(vStockOrigen.Cantidad, 6)

                        If vStockOrigen.IdStock = 3612 Then
                            Debug.Write("Espera que el factor es 0.")
                        End If

                        If vCantidadDispStock < 0 Then
                            Throw New Exception("ERROR_202302061300D: La cantidad disponible en stock, reflejó un resultado negativo y no hay fundamento técncio para que eso ocurra (aún), reportar a dsearrollo.")
                        End If

                        '#EJC20180620: Si la cantidad de un IdStock es 0, es porque la cantidad reservada es igual a lo disponible, por eso se valida aquí.
                        If vCantidadDispStock > 0 Then

                            BeStockRes = New clsBeStock_res()
                            BeStockRes.IdTransaccion = pStockRes.IdTransaccion
                            BeStockRes.Indicador = "PED"
                            BeStockRes.IdBodega = vStockOrigen.IdBodega
                            BeStockRes.IdStock = vStockOrigen.IdStock
                            BeStockRes.IdPropietarioBodega = vStockOrigen.IdPropietarioBodega
                            BeStockRes.IdProductoBodega = vStockOrigen.IdProductoBodega

                            If vCantidadPendiente = vCantidadDispStock Then
                                vCantidadAReservarPorIdStock = vCantidadDispStock
                                vCantidadPendiente -= vCantidadDispStock
                                vCantidadPendiente = Math.Round(vCantidadPendiente, 6)
                            ElseIf vCantidadPendiente < vCantidadDispStock Then

                                If pBeConfigEnc.Codigo_proveedor_produccion = "1060315" Then

                                    If Not vStockOrigen.IdPresentacion = 0 Then

                                        If pStockRes.IdPresentacion = 0 Then

                                            vIdProducto = clsLnProducto_bodega.Get_IdProducto_By_IdProductoBodega(vStockOrigen.IdProductoBodega,
                                                                                                                  lConnection,
                                                                                                                  ltransaction)

                                            If Not vIdProducto = 0 Then
                                                BePres = clsLnProducto_presentacion.Get_Presentacion_Defecto_By_IdProducto(vIdProducto,
                                                                                                                           lConnection,
                                                                                                                           ltransaction)
                                            End If


                                        End If

                                        If Not BePres Is Nothing Then
                                            vCantidadEnStockEnPres = Math.Round(vCantidadDispStock / BePres.Factor, 6)
                                        End If

                                        '#EJC20190602_0137AM: Extraer la parte decimal y la entera
                                        Split_Decimal(vCantidadEnStockEnPres, vCantidadEnteraStockPres, vCantidadDecimalStockUMBas)
                                        Split_Decimal(pStockRes.Peso, vPesoEnteroPresStock, vPesoDecimalStockUMBas)

                                        '#EJC20190602_0137AM: Multiplicar la parte decimal por el factor, para obtener la cantidad de unidades de medida básica.
                                        vCantidadDecimalUMBasStock = Math.Ceiling(Math.Round(vCantidadDecimalUMBas * BePres.Factor, 2))


                                        If vCantidadDecimalUMBasStock > 0 Then

                                            If vCantidadPendiente < vCantidadDecimalUMBasStock Then

                                                '#EJC20220510: Insertar el stock en umbas y asociar a la reserva.
                                                BeStockDestino.Cantidad = vCantidadDecimalUMBasStock
                                                BeStockDestino.Fec_agr = Now
                                                BeStockDestino.IdPresentacion = 0
                                                BeStockDestino.IdStock = clsLnStock.MaxID(lConnection, ltransaction) + 1
                                                BeStockRes.IdStock = BeStockDestino.IdStock
                                                BeStockDestino.No_bulto = 1989
                                                clsLnStock.Insertar(BeStockDestino, lConnection, ltransaction)

                                                '#EJC20220510: Quitar al stock en cajas, las unidades.
                                                vStockOrigen.Cantidad -= vCantidadDecimalUMBasStock

                                                If vStockOrigen.Cantidad > 0 Then
                                                    clsLnStock.Actualizar_Cantidad(vStockOrigen, lConnection, ltransaction)
                                                Else
                                                    clsLnStock.Eliminar_By_IdStock(vStockOrigen.IdStock, lConnection, ltransaction)
                                                End If

                                                vCantidadAReservarPorIdStock = vCantidadPendiente
                                                vCantidadPendiente -= vCantidadAReservarPorIdStock
                                                vCantidadPendiente = Math.Round(vCantidadPendiente, 6)

                                            Else

                                                If vCantidadPendiente <= vCantidadEnteraStockPres Then
                                                    vCantidadAReservarPorIdStock = vCantidadPendiente
                                                    vCantidadPendiente -= vCantidadPendiente
                                                    vCantidadPendiente = Math.Round(vCantidadPendiente, 6)
                                                Else
                                                    Debug.Write("#EJC20220510: something is missing but still I don't know what it is.")
                                                    Continue For
                                                End If

                                            End If

                                        Else

                                            If vCantidadEnteraStockPres > 0 Then

                                                If vCantidadPendiente < vCantidadDispStock Then

                                                    vCantidadAReservarPorIdStock = vCantidadPendiente
                                                    vPesoAReservarPorIdStock = vPesoEnteroPresStock
                                                    vCantidadPendiente -= vCantidadAReservarPorIdStock
                                                    vPesoPendiente -= vPesoEnteroPresStock

                                                End If

                                            End If

                                        End If


                                    Else
                                        vCantidadAReservarPorIdStock = vCantidadPendiente
                                        vCantidadPendiente -= vCantidadAReservarPorIdStock
                                        vCantidadPendiente = Math.Round(vCantidadPendiente, 6)
                                    End If

                                Else
                                    vCantidadAReservarPorIdStock = vCantidadPendiente
                                    vCantidadPendiente -= vCantidadAReservarPorIdStock
                                    vCantidadPendiente = Math.Round(vCantidadPendiente, 6)
                                End If


                            ElseIf vCantidadPendiente > vCantidadDispStock Then

                                If pBeConfigEnc.Codigo_proveedor_produccion = "1060315" Then

                                    If Not vStockOrigen.IdPresentacion = 0 Then

                                        If Not BePres.Factor = 0 Then

                                            vCantidadEnStockEnPres = Math.Round(vCantidadDispStock / BePres.Factor, 6)

                                            '#EJC20190602_0137AM: Extraer la parte decimal y la entera
                                            Split_Decimal(vCantidadEnStockEnPres, vCantidadEnteraStockPres, vCantidadDecimalStockUMBas)
                                            Split_Decimal(pStockRes.Peso, vPesoEnteroPresStock, vPesoDecimalStockUMBas)

                                            '#EJC20190602_0137AM: Multiplicar la parte decimal por el factor, para obtener la cantidad de unidades de medida básica.
                                            vCantidadDecimalUMBasStock = Math.Ceiling(Math.Round(vCantidadDecimalUMBas * BePres.Factor, 2))

                                            If vCantidadDecimalUMBasStock > 0 Then

                                                If vCantidadPendiente < vCantidadDecimalUMBasStock Then

                                                    '#EJC20220510: Insertar el stock en umbas y asociar a la reserva.
                                                    BeStockDestino.Cantidad = vCantidadDecimalUMBasStock
                                                    BeStockDestino.Fec_agr = Now
                                                    BeStockDestino.IdPresentacion = 0
                                                    BeStockDestino.IdStock = clsLnStock.MaxID(lConnection, ltransaction) + 1
                                                    BeStockRes.IdStock = BeStockDestino.IdStock
                                                    BeStockDestino.No_bulto = 1989
                                                    clsLnStock.Insertar(BeStockDestino, lConnection, ltransaction)

                                                    '#EJC20220510: Quitar al stock en cajas, las unidades.
                                                    vStockOrigen.Cantidad -= vCantidadDecimalUMBasStock

                                                    If vStockOrigen.Cantidad > 0 Then
                                                        clsLnStock.Actualizar_Cantidad(vStockOrigen, lConnection, ltransaction)
                                                    Else
                                                        clsLnStock.Eliminar_By_IdStock(vStockOrigen.IdStock, lConnection, ltransaction)
                                                    End If

                                                    vCantidadAReservarPorIdStock = vCantidadDecimalUMBasStock
                                                    vCantidadPendiente -= vCantidadAReservarPorIdStock
                                                    vCantidadPendiente = Math.Round(vCantidadPendiente, 6)

                                                Else
                                                    Debug.Write("#EJC20220510: something is missing but still I don't know what it is.")
                                                    Continue For
                                                End If

                                            Else
                                                vCantidadAReservarPorIdStock = vCantidadPendiente
                                                vCantidadPendiente -= vCantidadAReservarPorIdStock
                                                vCantidadPendiente = Math.Round(vCantidadPendiente, 6)
                                            End If

                                        Else
                                            Debug.Write("Espera que el factor es 0.")
                                        End If

                                    Else
                                        Debug.Write("#EJC20220510: En teoría lo disponible es menor que lo solicitado..")
                                        Continue For
                                    End If

                                Else
                                    vCantidadAReservarPorIdStock = vCantidadPendiente
                                    vCantidadPendiente -= vCantidadAReservarPorIdStock
                                    vCantidadPendiente = Math.Round(vCantidadPendiente, 6)
                                End If

                            End If

                            BeStockRes.IdUbicacion = vStockOrigen.IdUbicacion
                            BeStockRes.IdProductoEstado = vStockOrigen.ProductoEstado.IdEstado


                            If pStockRes.IdPresentacion = 0 Then
                                BeStockRes.IdPresentacion = 0
                            Else
                                BeStockRes.IdPresentacion = vStockOrigen.Presentacion.IdPresentacion
                            End If

                            BeStockRes.IdUnidadMedida = vStockOrigen.IdUnidadMedida
                            BeStockRes.Lote = vStockOrigen.Lote
                            BeStockRes.Lic_plate = vStockOrigen.Lic_plate
                            '#EJC20220316: Guardar el número línea.
                            BeStockRes.Serial = pBeTrasladoDet.Line_No
                            BeStockRes.Peso = vStockOrigen.Peso
                            BeStockRes.Estado = "UNCOMMITED"
                            BeStockRes.Fecha_ingreso = vStockOrigen.Fecha_Ingreso
                            BeStockRes.Fecha_vence = vStockOrigen.Fecha_vence
                            BeStockRes.Uds_lic_plate = vStockOrigen.Uds_lic_plate
                            BeStockRes.Ubicacion_ant = vStockOrigen.IdUbicacion_anterior
                            BeStockRes.No_bulto = vStockOrigen.No_bulto
                            BeStockRes.IdRecepcion = vStockOrigen.IdRecepcionEnc
                            BeStockRes.IdPicking = 0
                            BeStockRes.IdPedido = pStockRes.IdPedido
                            BeStockRes.IdPedidoDet = pStockRes.IdPedidoDet
                            BeStockRes.IdDespacho = 0
                            BeStockRes.añada = vStockOrigen.Añada
                            BeStockRes.Fecha_manufactura = vStockOrigen.Fecha_Manufactura
                            BeStockRes.Cantidad = Math.Round(vCantidadAReservarPorIdStock, 6)
                            BeStockRes.IdRecepcion = vStockOrigen.IdRecepcionEnc
                            BeStockRes.Host = pBeTrasladoDet.Source_ID
                            BeStockRes.Codigo_Producto = pBeTrasladoDet.Item_No
                            'BeStockRes.No_Pedido = pBeTrasladoDet.Source_ID
                            vCantidadCompletada = (vCantidadPendiente = 0)
                            lBeStockAReservar.Add(BeStockRes)

                            If BeStockRes.Cantidad = 1 Then

                            End If

                            If vCantidadCompletada Then Exit For

                        End If

                    Next

                End If

                If lBeStockAReservar.Count > 0 Then

                    If Inserta_Stock_Reservado(lBeStockAReservar,
                                               lConnection,
                                               ltransaction) Then

                        If (pBeConfigEnc.Explosion_Automatica) AndAlso (vCantidadDecimalUMBas > 0) Then

                            '#EJC20190602: Si existe cantidad en fracción se reserva en unidad de medida básica en base a: ('#EJC20190602_0137AM_REF20190602-0848)
                            If vCantidadDecimalUMBas > 0 Then
                                BeStockRes.Cantidad = vCantidadDecimalUMBas
                                BeStockRes.IdPresentacion = 0
                                Reserva_Stock(BeStockRes,
                                              pIdPropietario,
                                              DiasVencimiento,
                                              MaquinaQueSolicita,
                                              lConnection,
                                              ltransaction)
                            End If

                        End If

                        '#EJC20220330: Intentar reservar unidades a partir de las cajas. (condition UP)
                        If Not vCantidadCompletada Then
                            If (pBeConfigEnc.Explosion_Automatica) Then
                                If pStockRes.IdPresentacion = 0 Then
                                    If vRecursionSolicitud = 0 Then
                                        pStockRes.Cantidad = vCantidadPendiente
                                        vRecursionSolicitud = 1
                                        lBeStockAReservarRecursivo = Reserva_Stock_Lista_Result(pStockRes,
                                                                                               DiasVencimiento,
                                                                                               MaquinaQueSolicita,
                                                                                               pBeConfigEnc,
                                                                                               pBeTrasladoDet,
                                                                                               pIdPropietario,
                                                                                               True,
                                                                                               lConnection,
                                                                                               ltransaction)
                                        vRecursionSolicitud = 0
                                        If lBeStockAReservar.Count > 0 Then
                                            lBeStockAReservar.AddRange(lBeStockAReservarRecursivo)
                                        End If
                                    End If
                                End If
                            End If
                        End If

                        Reserva_Stock_Lista_Result = lBeStockAReservar

                    Else
                        Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0006, pStockRes.IdProductoBodega))
                    End If

                Else

                    '#EJC20220330: Intentar reservar unidades a partir de las cajas. (Condition Down)
                    If Not vCantidadCompletada Then
                        If (pBeConfigEnc.Explosion_Automatica) Then
                            If pStockRes.IdPresentacion = 0 Then
                                If vRecursionSolicitud = 0 Then
                                    pStockRes.Cantidad = vCantidadPendiente
                                    vRecursionSolicitud = 1
                                    lBeStockAReservarRecursivo = Reserva_Stock_Lista_Result(pStockRes,
                                                                                           DiasVencimiento,
                                                                                           MaquinaQueSolicita,
                                                                                           pBeConfigEnc,
                                                                                           pBeTrasladoDet,
                                                                                           pIdPropietario,
                                                                                           True,
                                                                                           lConnection,
                                                                                           ltransaction)
                                    vRecursionSolicitud = 0
                                    If lBeStockAReservarRecursivo.Count > 0 Then
                                        Reserva_Stock_Lista_Result = lBeStockAReservarRecursivo
                                        Exit Function
                                    End If

                                End If
                            End If
                        End If
                    End If

                    Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0005, pStockRes.IdProductoBodega))

                End If

            Else

                If pStockRes.IdPresentacion = 0 Then
                    Throw New Exception(String.Format("{0} Código:{1} UMBas={2} Pres='Sin pres' Cant={3} (Verifique si tiene existencia en UMBas en WMS) ", clsDalEx.ErrorS0004, BeProducto.Codigo, BeProducto.UnidadMedida.Nombre, pStockRes.Cantidad))
                Else
                    Throw New Exception(String.Format("{0} Código:{1} UMBas={2} Pres={3} Cant={4} (Verifique si tiene existencia en Pres. en WMS) ", clsDalEx.ErrorS0004,
                                                                                                                                                     BeProducto.Codigo,
                                                                                                                                                     BeProducto.UnidadMedida.Nombre,
                                                                                                                                                     pStockRes.IdPresentacion,
                                                                                                                                                     pStockRes.Cantidad))
                End If

            End If

        Catch ex As Exception
            Throw ex
        End Try

    End Function
    Public Shared Function Reserva_Stock_Especifico(ByRef pStockRes As clsBeStock_res,
                                                    ByVal DiasVencimiento As Double,
                                                    ByVal MaquinaQueSolicita As String,
                                                    ByRef pBeStockEspecifico As clsBeStock,
                                                    ByRef lConnection As SqlConnection,
                                                    ByRef ltransaction As SqlTransaction) As Boolean

        Reserva_Stock_Especifico = False

        Try

            Dim lBeStockAReservar As New List(Of clsBeStock_res)
            Dim BeProducto As New clsBeProducto
            Dim BeStockRes As New clsBeStock_res

            '#EJC20171018_0750PM: Restar el stock reservado de la lista de stock
            Dim vCantidadReservada As Double = 0

            vCantidadReservada = Get_Cantidad_Reservada_By_IdStock(pBeStockEspecifico.IdStock,
                                                                   lConnection,
                                                                   ltransaction)

            If vCantidadReservada <> 0 Then
                pBeStockEspecifico.Cantidad -= vCantidadReservada
            End If

            Dim StockOrdenado As Object = Nothing

            Dim vCantidadCompletada As Boolean = False
            Dim vCantidadStock As Double = 0
            Dim vCantidadPendiente As Double = 0
            Dim vCantidadSolicitadaPedido As Double = 0
            Dim vValorEnteroCantidadSolicitadaPedido As Integer = 0
            Dim vCantidadAReservarPorIdStock As Double = 0

            If pStockRes.IdPresentacion = 0 Then
                vCantidadSolicitadaPedido = pStockRes.Cantidad
            Else

                Dim BePres As New clsBeProducto_Presentacion With {.IdPresentacion = pStockRes.IdPresentacion}
                clsLnProducto_presentacion.GetSingle(BePres,
                                                     lConnection,
                                                     ltransaction)

                If BePres.EsPallet Then

                    Dim vFactorPallet As Double = (BePres.Factor * BePres.CajasPorCama * BePres.CamasPorTarima)

                    If vFactorPallet > 0 Then
                        vCantidadSolicitadaPedido = pStockRes.Cantidad * vFactorPallet
                    Else
                        Throw New Exception("No se pudo reservar el stock para el tipo de producto pallet porque los factores de conversión dan un denominador = 0")
                    End If

                Else

                    vCantidadSolicitadaPedido = pStockRes.Cantidad * BePres.Factor

                    If Not clsLnProducto.Tiene_Control_Por_Peso_By_IdProductoBodega(pStockRes.IdProductoBodega,
                                                                                    lConnection,
                                                                                    ltransaction) Then

                        If Integer.TryParse(vCantidadSolicitadaPedido, vValorEnteroCantidadSolicitadaPedido) Then
                            vCantidadSolicitadaPedido = vValorEnteroCantidadSolicitadaPedido
                        Else
                            vCantidadSolicitadaPedido = Math.Truncate(vCantidadSolicitadaPedido)
                        End If

                    Else
                        vCantidadSolicitadaPedido = Math.Round(vCantidadSolicitadaPedido, 6)

                    End If

                End If

            End If

            vCantidadPendiente = vCantidadSolicitadaPedido

            vCantidadStock = pBeStockEspecifico.Cantidad

            BeStockRes = New clsBeStock_res
            BeStockRes.IdTransaccion = pStockRes.IdTransaccion
            BeStockRes.Indicador = "PED"
            BeStockRes.IdBodega = pBeStockEspecifico.IdBodega
            BeStockRes.IdStock = pBeStockEspecifico.IdStock
            BeStockRes.IdPropietarioBodega = pBeStockEspecifico.IdPropietarioBodega
            BeStockRes.IdProductoBodega = pBeStockEspecifico.IdProductoBodega

            If vCantidadPendiente = vCantidadStock Then
                vCantidadAReservarPorIdStock = vCantidadStock
                vCantidadPendiente -= vCantidadStock
            ElseIf vCantidadPendiente < vCantidadStock Then
                vCantidadAReservarPorIdStock = vCantidadPendiente
                vCantidadPendiente -= vCantidadAReservarPorIdStock
            ElseIf vCantidadPendiente > vCantidadStock Then
                vCantidadAReservarPorIdStock = vCantidadStock
                vCantidadPendiente -= vCantidadStock
            End If

            clsPublic.CopyObject(pBeStockEspecifico, BeStockRes)

            BeStockRes.IdUbicacion = pBeStockEspecifico.IdUbicacion
            BeStockRes.IdProductoEstado = pBeStockEspecifico.IdProductoEstado
            BeStockRes.IdPresentacion = pBeStockEspecifico.IdPresentacion
            BeStockRes.IdUnidadMedida = pBeStockEspecifico.IdUnidadMedida
            BeStockRes.Lote = pBeStockEspecifico.Lote
            BeStockRes.Lic_plate = pBeStockEspecifico.Lic_plate
            BeStockRes.Serial = pBeStockEspecifico.Serial
            BeStockRes.Peso = pBeStockEspecifico.Peso
            BeStockRes.Estado = "UNCOMMITED"
            BeStockRes.Fecha_ingreso = pBeStockEspecifico.Fecha_Ingreso
            BeStockRes.Fecha_vence = pBeStockEspecifico.Fecha_vence
            BeStockRes.Uds_lic_plate = pBeStockEspecifico.Uds_lic_plate
            '#CF 20171120 06:41PM Guardé en el campo Ubicacion_ant el id de la ubicación anterio de Stock
            BeStockRes.Ubicacion_ant = pBeStockEspecifico.IdUbicacion_anterior
            BeStockRes.No_bulto = pBeStockEspecifico.No_bulto
            BeStockRes.IdRecepcion = pBeStockEspecifico.IdRecepcionEnc
            BeStockRes.IdPicking = 0
            BeStockRes.IdPedido = pStockRes.IdPedido
            BeStockRes.IdPedidoDet = pStockRes.IdPedidoDet
            BeStockRes.IdDespacho = 0
            BeStockRes.añada = pBeStockEspecifico.Añada
            BeStockRes.Fecha_manufactura = pBeStockEspecifico.Fecha_Manufactura
            '#CM20181308_3:23PM:Redondea la cantidad a reservar por IdStock a 6 cifras.
            BeStockRes.Cantidad = Math.Round(vCantidadAReservarPorIdStock, 6)
            BeStockRes.IdRecepcion = pBeStockEspecifico.IdRecepcionEnc
            '#EJC20171018_0715PM: Registrar en tabla stock_res la PC que bloqueó/reservó el stock
            BeStockRes.Host = MaquinaQueSolicita
            vCantidadCompletada = (vCantidadPendiente = 0)

            'pStockRes.Cantidad = vCantidadReservada
            lBeStockAReservar.Add(BeStockRes)

            If lBeStockAReservar.Count > 0 Then

                If Inserta_Stock_Reservado(lBeStockAReservar, lConnection, ltransaction) Then
                    Reserva_Stock_Especifico = True
                Else
                    Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0006, pStockRes.IdProductoBodega))
                End If

            Else
                Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0005, pStockRes.IdProductoBodega))
            End If

        Catch ex As Exception
            Dim vMsgError As String = String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message)
            clsLnLog_error_wms.Agregar_Error(vMsgError)
            Throw ex
        End Try

    End Function
    Public Shared Function Reserva_Stock_Especifico(ByRef pStockRes As clsBeStock_res,
                                                    ByVal DiasVencimiento As Double,
                                                    ByVal MaquinaQueSolicita As String,
                                                    ByRef pListStockResOUT As List(Of clsBeStock_res),
                                                    ByRef pBeStockEspecifico As clsBeStock,
                                                    ByRef lConnection As SqlConnection,
                                                    ByRef ltransaction As SqlTransaction) As Boolean

        Reserva_Stock_Especifico = False

        pListStockResOUT = Nothing

        Try

            Dim lBeStockAReservar As New List(Of clsBeStock_res)
            Dim BeProducto As New clsBeProducto
            Dim BeStockRes As New clsBeStock_res

            '#EJC20171018_0750PM: Restar el stock reservado de la lista de stock
            Dim vCantidadReservada As Double = 0
            Dim vPesoReservado As Double = 0

            '#EJC20220303:Antes de manejo de peso Cealsa
            'vCantidadReservada = Get_Cantidad_Reservada_By_IdStock(pBeStockEspecifico.IdStock, lConnection, ltransaction)

            Get_Cantidad_Y_Peso_ReservadaUMBas_By_IdStock(pBeStockEspecifico.IdStock, False, vCantidadReservada, vPesoReservado, lConnection, ltransaction)

            If vCantidadReservada <> 0 Then
                pBeStockEspecifico.Cantidad -= vCantidadReservada
            End If

            Dim StockOrdenado As Object = Nothing

            Dim vCantidadCompletada As Boolean = False
            Dim vCantidadStock As Double = 0
            Dim vPesoStock As Double = 0
            Dim vCantidadPendiente As Double = 0
            Dim vPesoPendiente As Double = 0
            Dim vCantidadSolicitadaPedido As Double = 0
            Dim vPesoSolicitadoPedido As Double = 0
            Dim vValorEnteroCantidadSolicitadaPedido As Integer = 0
            Dim vCantidadAReservarPorIdStock As Double = 0
            Dim vPesoAReservarPorIdStock As Double = 0

            If pStockRes.IdPresentacion = 0 Then
                vCantidadSolicitadaPedido = pStockRes.Cantidad
                vPesoSolicitadoPedido = pStockRes.Peso
            Else

                Dim BePres As New clsBeProducto_Presentacion With {.IdPresentacion = pStockRes.IdPresentacion}
                clsLnProducto_presentacion.GetSingle(BePres, lConnection, ltransaction)

                If BePres.EsPallet Then

                    Dim vFactorPallet As Double = (BePres.Factor * BePres.CajasPorCama * BePres.CamasPorTarima)

                    If vFactorPallet > 0 Then
                        vCantidadSolicitadaPedido = pStockRes.Cantidad * vFactorPallet
                        vPesoSolicitadoPedido = pStockRes.Peso
                    Else
                        Throw New Exception("No se pudo reservar el stock para el tipo de producto pallet porque los factores de conversión dan un denominador = 0")
                    End If

                Else

                    vCantidadSolicitadaPedido = pStockRes.Cantidad * BePres.Factor

                    If Not clsLnProducto.Tiene_Control_Por_Peso_By_IdProductoBodega(pStockRes.IdProductoBodega, lConnection, ltransaction) Then

                        If Integer.TryParse(vCantidadSolicitadaPedido, vValorEnteroCantidadSolicitadaPedido) Then
                            vCantidadSolicitadaPedido = vValorEnteroCantidadSolicitadaPedido
                            vPesoSolicitadoPedido = pStockRes.Peso
                        Else
                            vCantidadSolicitadaPedido = Math.Truncate(vCantidadSolicitadaPedido)
                            vPesoSolicitadoPedido = pStockRes.Peso
                        End If

                    Else
                        vCantidadSolicitadaPedido = Math.Round(vCantidadSolicitadaPedido, 6)
                        vPesoSolicitadoPedido = pStockRes.Peso
                    End If

                End If

            End If

            vCantidadPendiente = vCantidadSolicitadaPedido
            vPesoPendiente = vPesoSolicitadoPedido

            vCantidadStock = pBeStockEspecifico.Cantidad
            vPesoStock = pBeStockEspecifico.Peso

            BeStockRes = New clsBeStock_res
            BeStockRes.IdTransaccion = pStockRes.IdTransaccion
            BeStockRes.Indicador = "PED"
            BeStockRes.IdBodega = pBeStockEspecifico.IdBodega
            BeStockRes.IdStock = pBeStockEspecifico.IdStock
            BeStockRes.IdPropietarioBodega = pBeStockEspecifico.IdPropietarioBodega
            BeStockRes.IdProductoBodega = pBeStockEspecifico.IdProductoBodega

            If vCantidadPendiente = vCantidadStock Then
                vCantidadAReservarPorIdStock = vCantidadStock
                vCantidadPendiente -= vCantidadStock
                vPesoAReservarPorIdStock = vPesoStock
                vPesoPendiente -= vPesoStock
            ElseIf vCantidadPendiente < vCantidadStock Then
                vCantidadAReservarPorIdStock = vCantidadPendiente
                vCantidadPendiente -= vCantidadAReservarPorIdStock
                vPesoAReservarPorIdStock = vPesoPendiente
                vPesoPendiente -= vPesoAReservarPorIdStock
            ElseIf vCantidadPendiente > vCantidadStock Then
                vCantidadAReservarPorIdStock = vCantidadStock
                vCantidadPendiente -= vCantidadStock
                vPesoAReservarPorIdStock = vPesoStock
                vPesoPendiente -= vPesoStock
            End If

            clsPublic.CopyObject(pBeStockEspecifico, BeStockRes)

            BeStockRes.IdUbicacion = pBeStockEspecifico.IdUbicacion
            BeStockRes.IdProductoEstado = pBeStockEspecifico.IdProductoEstado

            '#EJC20210727: Si se solicitó stock específicio que tiene presentación, pero luego se le quitó la presentación manualmente.
            'Conservar la solicitud en UMBAS.
            If pStockRes.IdPresentacion = 0 Then
                BeStockRes.IdPresentacion = 0
            Else
                BeStockRes.IdPresentacion = pBeStockEspecifico.IdPresentacion
            End If

            BeStockRes.IdUnidadMedida = pBeStockEspecifico.IdUnidadMedida

            BeStockRes.Lote = pBeStockEspecifico.Lote
            BeStockRes.Lic_plate = pBeStockEspecifico.Lic_plate
            BeStockRes.Serial = pBeStockEspecifico.Serial
            BeStockRes.Estado = "UNCOMMITED"
            BeStockRes.Fecha_ingreso = pBeStockEspecifico.Fecha_Ingreso
            BeStockRes.Fecha_vence = pBeStockEspecifico.Fecha_vence
            BeStockRes.Uds_lic_plate = pBeStockEspecifico.Uds_lic_plate
            '#CF 20171120 06:41PM Guardé en el campo Ubicacion_ant el id de la ubicación anterio de Stock
            BeStockRes.Ubicacion_ant = pBeStockEspecifico.IdUbicacion_anterior
            BeStockRes.No_bulto = pBeStockEspecifico.No_bulto
            BeStockRes.IdRecepcion = pBeStockEspecifico.IdRecepcionEnc
            BeStockRes.IdPicking = 0
            BeStockRes.IdPedido = pStockRes.IdPedido
            BeStockRes.IdPedidoDet = pStockRes.IdPedidoDet
            BeStockRes.IdDespacho = 0
            BeStockRes.añada = pBeStockEspecifico.Añada
            BeStockRes.Fecha_manufactura = pBeStockEspecifico.Fecha_Manufactura
            '#CM20181308_3:23PM:Redondea la cantidad a reservar por IdStock a 6 cifras.
            BeStockRes.Cantidad = Math.Round(vCantidadAReservarPorIdStock, 6)
            '#EJC20220303:Reservar peso relacionado a la cantidad.
            BeStockRes.Peso = Math.Round(vPesoAReservarPorIdStock, 6)
            BeStockRes.IdRecepcion = pBeStockEspecifico.IdRecepcionEnc
            '#EJC20171018_0715PM: Registrar en tabla stock_res la PC que bloqueó/reservó el stock
            BeStockRes.Host = MaquinaQueSolicita
            vCantidadCompletada = (vCantidadPendiente = 0)
            '#GT08102025: la reserva maneja la fecha del dia del pedido no del ingreso a stock
            BeStockRes.Fec_agr = pStockRes.Fec_agr
            BeStockRes.Fec_mod = pStockRes.Fec_mod

            'pStockRes.Cantidad = vCantidadReservada
            lBeStockAReservar.Add(BeStockRes)

            If lBeStockAReservar.Count > 0 Then

                If Inserta_Stock_Reservado(lBeStockAReservar, lConnection, ltransaction) Then
                    pListStockResOUT = lBeStockAReservar
                    Reserva_Stock_Especifico = True
                Else
