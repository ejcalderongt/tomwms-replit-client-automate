    '#CKFK 20180130 04:24 PM Función creada para eliminar el stockres asociado a un IdStockRes
    '#CKFK 20180208 10:08 PM Se le agregó transaccionalidad
    Public Shared Function Eliminar_Stock_Reservado_By_IdStockRes(ByVal IdStockRes As Integer,
                                                                  Optional ByRef pConnection As SqlConnection = Nothing,
                                                                  Optional ByRef pTransaction As SqlTransaction = Nothing) As Integer

        Dim lConnection As New SqlConnection(Configuration.ConfigurationManager.AppSettings("CST"))
        Dim lTransaction As SqlTransaction = Nothing

        Eliminar_Stock_Reservado_By_IdStockRes = 0

        Try

            Dim Es_Transaccion_Remota As Boolean = (Not pConnection Is Nothing AndAlso Not pTransaction Is Nothing)

            If Not Es_Transaccion_Remota Then
                lConnection.Open() : lTransaction = lConnection.BeginTransaction(IsolationLevel.ReadUncommitted)
            End If

            'Elimina el stock reservado
            Dim sp As String = " Delete from stock_res 
                                 WHERE IdStockRes =@IdStockRes "

            Dim rowsAffected As Integer = 0

            Using cmd As New SqlCommand(sp, IIf(Es_Transaccion_Remota, pConnection, lConnection), IIf(Es_Transaccion_Remota, pTransaction, lTransaction)) _
                             With {.CommandType = CommandType.Text}

                cmd.Parameters.Add(New SqlParameter("@IdStockRes", IdStockRes))

                rowsAffected = cmd.ExecuteNonQuery()

                If Not Es_Transaccion_Remota Then lTransaction.Commit()

            End Using

            Eliminar_Stock_Reservado_By_IdStockRes = rowsAffected

        Catch ex As Exception
            If lTransaction IsNot Nothing Then lTransaction.Rollback()
            Throw ex
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close() : lConnection.Dispose()
            If lTransaction IsNot Nothing Then lTransaction.Dispose()
        End Try

    End Function

    '#CKFK 20180130 04:24 PM Función creada para actualizar la cantidad del stockres asociado a un IdStockRes
    Public Shared Function Actualizar_Stock_Reservado_By_IdStockRes(ByVal IdStockRes As Integer,
                                                                    ByVal cantidad As Double,
                                                                    ByRef lConnection As SqlConnection,
                                                                    ByRef ltransaction As SqlTransaction) As Integer

        Actualizar_Stock_Reservado_By_IdStockRes = 0

        Try

            'Actualiza el stock reservado
            Dim sp As String = " Update stock_res set cantidad = cantidad - @cantidad " &
                               " WHERE IdStockRes =@IdStockRes "

            Dim rowsAffected As Integer = 0

            Using cmd As New SqlCommand(sp, lConnection, ltransaction) With {.CommandType = CommandType.Text}

                cmd.Parameters.Add(New SqlParameter("@IdStockRes", IdStockRes))
