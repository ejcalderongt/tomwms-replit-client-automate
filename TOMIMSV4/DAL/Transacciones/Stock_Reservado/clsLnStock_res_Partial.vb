                                        BeTrans_log_reubic_stock_res.Fecha_Sistema = Now

                                        clsLnTrans_log_reubic_stock_res.Insertar(BeTrans_log_reubic_stock_res, lConnection, lTransaction)
                                        vIdLogReubicStockRes += 1

                                        'Actualizar stock reservado
                                        rowsAffected += Actualizar_Ubicacion_Stock_Reservado_By_IdStockRes(BeStockResAReubicar.IdStockRes,
                                                                                                           StockRes.IdStock,
                                                                                                           IdBodega,
                                                                                                           IdUbicacion,
                                                                                                           BeStockOrigen.IdUbicacion,
                                                                                                           lConnection,
                                                                                                           lTransaction)

                                        'Actualiza el picking ubic.
                                        rowsAffected += clsLnTrans_picking_ubic.Actualizar_IdUbicacion_By_IdStockRes(IdUbicacion,
