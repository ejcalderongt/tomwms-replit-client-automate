    ''' 
    Public Shared Function Actualizar_Ubicacion_Stock_Reservado_By_IdStock(ByVal IdStock As Integer,
                                                                           ByVal IdBodega As Integer,
                                                                           ByVal IdUbicacion As Integer,
                                                                           ByVal pIdOperador As Integer) As Integer

        Actualizar_Ubicacion_Stock_Reservado_By_IdStock = 0

        Dim lConnection As New SqlConnection(Configuration.ConfigurationManager.AppSettings("CST"))
        Dim lTransaction As SqlTransaction = Nothing
        Dim rowsAffected As Integer = 0
        Dim BeStockOrigen As New clsBeStock()
        Dim vIdLogReubicStockRes As Integer
        Dim vResultActualizar_IdUbicacion_By_IdStockRes As Integer = 0
        Dim vResultActualizar_IdUbicacion_By_IdStock As Integer = 0
        Dim lGet_All_PickingUbic_By_IdStockRes_And_IdStock As New List(Of clsBeTrans_picking_ubic)
        Dim vResultActualizar_Ubicacion_Stock_Reservado_By_IdStockRes As Integer = 0
        Dim lBeStockRes As New List(Of clsBeStock_res)
        Dim BeMovimiento As clsBeTrans_movimientos = Nothing

        Try

            lConnection.Open() : lTransaction = lConnection.BeginTransaction(IsolationLevel.ReadUncommitted)

            lBeStockRes = Get_All_By_IdStock_And_IdBodega(IdStock,
                                                          IdBodega,
                                                          lConnection,
                                                          lTransaction)

            If Not lBeStockRes Is Nothing Then

                vIdLogReubicStockRes = clsLnTrans_log_reubic_stock_res.MaxID(lConnection, lTransaction) + 1

                If lBeStockRes.Count > 0 Then

                    BeStockOrigen = clsLnStock.GetSingle(IdStock,
                                                         lConnection,
                                                         lTransaction)

                    If Not BeStockOrigen Is Nothing Then


                        'Actualiza el stock
                        vResultActualizar_IdUbicacion_By_IdStock = clsLnStock.Actualizar_IdUbicacion_By_IdStock(IdUbicacion,
                                                                                                                BeStockOrigen.IdUbicacion,
                                                                                                                IdBodega,
                                                                                                                IdStock,
                                                                                                                lConnection,
                                                                                                                lTransaction)

                        If vResultActualizar_IdUbicacion_By_IdStock > 0 Then

                            rowsAffected += vResultActualizar_IdUbicacion_By_IdStock

                            For Each BeStockResAReubicar As clsBeStock_res In lBeStockRes
                                Dim BeEmpresa = clsLnEmpresa.GetSingle_By_IdBodega(BeStockResAReubicar.IdBodega)

                                BeMovimiento = New clsBeTrans_movimientos()

                                BeMovimiento.IdMovimiento = clsLnTrans_movimientos.MaxID(lConnection, lTransaction)
                                BeMovimiento.IdTransaccion = BeStockResAReubicar.IdPicking
                                BeMovimiento.IdEmpresa = BeEmpresa.IdEmpresa
                                BeMovimiento.IdBodegaOrigen = BeStockResAReubicar.IdBodega
                                BeMovimiento.IdPropietarioBodega = BeStockResAReubicar.IdPropietarioBodega
                                BeMovimiento.IdProductoBodega = BeStockResAReubicar.IdProductoBodega
                                BeMovimiento.IdUbicacionOrigen = BeStockOrigen.IdUbicacion
                                BeMovimiento.IdEstadoOrigen = BeStockResAReubicar.IdProductoEstado
                                BeMovimiento.IdEstadoDestino = BeStockResAReubicar.IdProductoEstado
                                BeMovimiento.IdUbicacionDestino = IdUbicacion
                                BeMovimiento.IdPresentacion = BeStockResAReubicar.IdPresentacion
                                BeMovimiento.IdUnidadMedida = BeStockResAReubicar.IdUnidadMedida
                                BeMovimiento.IdTipoTarea = 24
                                BeMovimiento.IdBodegaDestino = BeStockResAReubicar.IdBodega
                                BeMovimiento.Cantidad = BeStockResAReubicar.Cantidad

                                BeMovimiento.Serie = BeStockResAReubicar.Serial
                                BeMovimiento.Peso = BeStockResAReubicar.Peso
                                BeMovimiento.Lote = BeStockResAReubicar.Lote
                                BeMovimiento.Barra_pallet = BeStockResAReubicar.Lic_plate
                                BeMovimiento.Fecha_vence = BeStockResAReubicar.Fecha_vence
                                BeMovimiento.Fecha_agr = Now
                                BeMovimiento.Usuario_agr = pIdOperador
                                BeMovimiento.IdPedidoDet = BeStockResAReubicar.IdPedidoDet
                                BeMovimiento.IdPedidoEnc = BeStockResAReubicar.IdPedido
                                BeMovimiento.IdDespachoEnc = BeStockResAReubicar.IdDespacho
                                BeMovimiento.IdOperadorBodega = clsLnOperador_bodega.Get_IdOperadorBodega_By_IdOperador(pIdOperador, IdBodega, lConnection, lTransaction)
                                BeMovimiento.IdDespachoDet = 0

                                clsLnTrans_movimientos.Insertar(BeMovimiento)

                                'Insertar en tabla de LOG.
                                Dim BeTrans_log_reubic_stock_res As New clsBeTrans_log_reubic_stock_res
                                BeTrans_log_reubic_stock_res.IdLogReubicStockRes = vIdLogReubicStockRes
                                BeTrans_log_reubic_stock_res.IdBodega = BeStockResAReubicar.IdBodega
                                BeTrans_log_reubic_stock_res.IdPickingUbic = BeStockResAReubicar.IdPicking
                                BeTrans_log_reubic_stock_res.IdPickingDet = 0
                                BeTrans_log_reubic_stock_res.IdPedidoEnc = BeStockResAReubicar.IdPedido
                                BeTrans_log_reubic_stock_res.IdPedidoDet = BeStockResAReubicar.IdPedidoDet
                                BeTrans_log_reubic_stock_res.IdStock = BeStockResAReubicar.IdStock
                                BeTrans_log_reubic_stock_res.IdStockRes = BeStockResAReubicar.IdStockRes
                                BeTrans_log_reubic_stock_res.IdUbicacion = BeStockResAReubicar.IdUbicacion
                                BeTrans_log_reubic_stock_res.IdUsuario = pIdOperador
                                BeTrans_log_reubic_stock_res.Codigo_Producto = BeStockResAReubicar.Codigo_Producto
                                BeTrans_log_reubic_stock_res.Lote = BeStockResAReubicar.Lote
                                BeTrans_log_reubic_stock_res.Lic_Plate = BeStockResAReubicar.Lic_plate
                                BeTrans_log_reubic_stock_res.Fecha_Vence = BeStockResAReubicar.Fecha_vence
                                BeTrans_log_reubic_stock_res.Cantidad = BeStockResAReubicar.Cantidad
                                BeTrans_log_reubic_stock_res.Peso = BeStockResAReubicar.Peso
                                BeTrans_log_reubic_stock_res.Referencia = 0
                                BeTrans_log_reubic_stock_res.Observacion = "Se liberó producto del IdStock: " & BeStockResAReubicar.IdStock & " hacia la ubicación " & IdUbicacion
                                BeTrans_log_reubic_stock_res.IdProductoBodega = BeStockResAReubicar.IdProductoBodega
                                BeTrans_log_reubic_stock_res.IdProductoEstado = BeStockResAReubicar.IdProductoEstado
                                BeTrans_log_reubic_stock_res.IdPropietarioBodega = BeStockResAReubicar.IdPropietarioBodega
                                BeTrans_log_reubic_stock_res.IdUnidadMedida = BeStockResAReubicar.IdUnidadMedida
                                BeTrans_log_reubic_stock_res.IdPresentacion = BeStockResAReubicar.IdPresentacion
                                BeTrans_log_reubic_stock_res.IdUbicacionAnterior = BeStockResAReubicar.Ubicacion_ant
                                BeTrans_log_reubic_stock_res.Fecha_Sistema = Now

                                rowsAffected += clsLnTrans_log_reubic_stock_res.Insertar(BeTrans_log_reubic_stock_res,
                                                                                             lConnection,
                                                                                             lTransaction)

                                vIdLogReubicStockRes += 1

                                '#EJC202210110949: Validar que si tiene picking, entonces actualiza el picking, de lo contrario NO, en proceso de Actualizar_Ubicación_Stock_Reservado_By_IdStock
                                If BeStockResAReubicar.IdPicking <> 0 Then

                                    '#EJC202210061337: Optimizar después-
                                    lGet_All_PickingUbic_By_IdStockRes_And_IdStock = clsLnTrans_picking_ubic.Get_All_PickingUbic_By_IdStockRes_And_IdStock(BeStockResAReubicar.IdStockRes,
                                                                                                                                                           IdStock,
                                                                                                                                                           lConnection,
                                                                                                                                                           lTransaction)

                                    If Not lGet_All_PickingUbic_By_IdStockRes_And_IdStock Is Nothing Then

                                        'Actualizar stock reservado
                                        vResultActualizar_Ubicacion_Stock_Reservado_By_IdStockRes = Actualizar_Ubicacion_Stock_Reservado_By_IdStockRes(BeStockResAReubicar.IdStockRes,
                                                                                                                                                       IdStock,
                                                                                                                                                       IdBodega,
                                                                                                                                                       IdUbicacion,
                                                                                                                                                       BeStockOrigen.IdUbicacion,
                                                                                                                                                       lConnection,
                                                                                                                                                       lTransaction)

                                        If Not vResultActualizar_Ubicacion_Stock_Reservado_By_IdStockRes = 0 Then

                                            rowsAffected += vResultActualizar_Ubicacion_Stock_Reservado_By_IdStockRes

                                            'Actualiza el picking ubic.
                                            vResultActualizar_IdUbicacion_By_IdStockRes = clsLnTrans_picking_ubic.Actualizar_IdUbicacion_By_IdStockRes(IdUbicacion,
                                                                                                                                                       BeStockOrigen.IdUbicacion,
                                                                                                                                                       IdBodega,
                                                                                                                                                       IdStock,
                                                                                                                                                       BeStockResAReubicar.IdStockRes,
                                                                                                                                                       lConnection,
                                                                                                                                                       lTransaction)

                                            If vResultActualizar_IdUbicacion_By_IdStockRes = 0 Then
                                                Throw New Exception("ERROR_20221006_1325A: No se pudo actualizar el identificador de ubicación para la reserva de stock, IdStock: " & IdStock & " IdStockRes: " & BeStockResAReubicar.IdStockRes)
                                            Else
                                                If Not vResultActualizar_IdUbicacion_By_IdStockRes = lGet_All_PickingUbic_By_IdStockRes_And_IdStock.Count Then
                                                    Throw New Exception("ERROR_20221006_1325B: La eurística del sistema detectó una inconsistencia al actualizar los valores del picking en relación a la reserva, por prevención se ha revertido la transacción. IdStock: " & IdStock & " IdStockRes: " & BeStockResAReubicar.IdStockRes)
                                                Else
                                                    rowsAffected += vResultActualizar_IdUbicacion_By_IdStockRes
                                                End If
                                            End If

                                        Else
                                            Throw New Exception("ERROR_20221006_1325C: No se pudo actualizar el identificador de ubicación para la reserva de stock, IdStock: " & IdStock & " IdStockRes: " & BeStockResAReubicar.IdStockRes)
                                        End If

                                    Else
                                        Throw New Exception("ERROR_20221006_1329: No se pubo Actualizar_Ubicacion_Stock_Reservado_By_IdStockRes con los parámetros IdStockRes: " & BeStockResAReubicar.IdStockRes & " e IdStock: " & IdStock)
                                    End If

                                Else

                                    vResultActualizar_Ubicacion_Stock_Reservado_By_IdStockRes = Actualizar_Ubicacion_Stock_Reservado_By_IdStockRes(BeStockResAReubicar.IdStockRes,
                                                                                                                                                   IdStock,
                                                                                                                                                   IdBodega,
                                                                                                                                                   IdUbicacion,
                                                                                                                                                   BeStockOrigen.IdUbicacion,
                                                                                                                                                   lConnection,
                                                                                                                                                   lTransaction)

                                    If Not vResultActualizar_Ubicacion_Stock_Reservado_By_IdStockRes = 0 Then
                                        rowsAffected += vResultActualizar_Ubicacion_Stock_Reservado_By_IdStockRes
                                    Else
                                        Throw New Exception("ERROR_20221006_1325C: No se pudo actualizar el identificador de ubicación para la reserva de stock, IdStock: " & IdStock & " IdStockRes: " & BeStockResAReubicar.IdStockRes)
                                    End If


                                End If

                            Next

                        Else
                            Throw New Exception("ERROR_20221006_1319: No se pudo actualizar el identificador de ubicación en stock. (Actualizar_IdUbicacion_By_IdStock)")
                        End If

                    Else
                        Throw New Exception("ERROR_20221006_1321A: No se pudo obtener el objeto de stock base con identificador: " & IdStock)
                    End If

                Else
                    Throw New Exception("ERROR_20221006_1321B: El count de la lista de stock reservado con los parámetros IdStock: " & IdStock & " e IdBodega: " & IdBodega & " es 0.")
                End If

                lTransaction.Commit()

                Actualizar_Ubicacion_Stock_Reservado_By_IdStock = rowsAffected

            Else
                Throw New Exception("ERROR_20221006_1321B: No se pudo obtener la lista de stock reservado con los parámetros IdStock: " & IdStock & " e IdBodega: " & IdBodega)
            End If

        Catch ex As Exception
            If Not lTransaction Is Nothing Then lTransaction.Rollback()
            Throw ex
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close()
        End Try

    End Function

    '#AT20220916  Copia de Actualizar_Ubicacion_Stock_Reservado_By_IdStock para cambiar stock reservado
