                                                                                                                     StockRes.IdStock,
                                                                                                                     BeStockResAReubicar.IdStockRes,
                                                                                                                     lConnection,
                                                                                                                     lTransaction)

                                    Next

                                End If

                            End If

                        End Using
                    Next

                End If

            End If

            lTransaction.Commit()

            Actualizar_Ubicacion_Stock_Reservado_By_StockRes = rowsAffected

        Catch ex As Exception
            If Not lTransaction Is Nothing Then lTransaction.Rollback()
            Throw ex
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close()
        End Try

