    Public Shared Function Get_Cantidad_Y_Peso_ReservadaUMBas_By_IdStock(ByVal pIdStock As Integer,
                                                                         ByVal ConvertirPresentacion As Boolean,
                                                                         ByRef Cantidad_Reservada As Double,
                                                                         ByRef Peso_Reservado As Double,
                                                                         ByRef lConnection As SqlConnection,
                                                                         ByRef lTransaction As SqlTransaction) As Boolean

        Get_Cantidad_Y_Peso_ReservadaUMBas_By_IdStock = False

        Try

            Dim lStockRes As New List(Of clsBeStock_res)

            lStockRes = Get_All_By_IdStock(pIdStock, lConnection, lTransaction)

            Dim vTotalCantidadReservada As Double = 0
            Dim vTotalPesoReservado As Double = 0

            Dim BePres As New clsBeProducto_Presentacion
            Dim vIndicePres As Integer = -1

            For Each StockRes As clsBeStock_res In lStockRes

                If ConvertirPresentacion AndAlso (StockRes.IdPresentacion <> 0) Then

                    If StockRes.IdPresentacion <> 0 Then

                        vIndicePres = lPresentaciones.FindIndex(Function(x) x.IdPresentacion = StockRes.IdPresentacion)

                        If vIndicePres = -1 Then
                            BePres = New clsBeProducto_Presentacion
                            BePres.IdPresentacion = StockRes.IdPresentacion
                            clsLnProducto_presentacion.GetSingle(BePres, lConnection, lTransaction)
                            lPresentaciones.Add(BePres)
                        Else
                            BePres = lPresentaciones(vIndicePres)
                        End If

                        If BePres.EsPallet Then
                            vTotalCantidadReservada += StockRes.Cantidad / (BePres.Factor * BePres.CajasPorCama * BePres.CamasPorTarima)
                            vTotalPesoReservado += StockRes.Peso / (BePres.Factor * BePres.CajasPorCama * BePres.CamasPorTarima)
                        Else
                            vTotalCantidadReservada += (StockRes.Cantidad / BePres.Factor)
                            vTotalPesoReservado += (StockRes.Peso / BePres.Factor)
                        End If

                    Else
                        vTotalCantidadReservada += StockRes.Cantidad
                        vTotalPesoReservado += StockRes.Peso
                    End If

                Else
                    vTotalCantidadReservada += StockRes.Cantidad
                    vTotalPesoReservado += StockRes.Peso
                End If

            Next

            Cantidad_Reservada = vTotalCantidadReservada
            Peso_Reservado = vTotalPesoReservado

            Get_Cantidad_Y_Peso_ReservadaUMBas_By_IdStock = True

        Catch ex As Exception
            Dim vMsgError As String = String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message)
            clsLnLog_error_wms.Agregar_Error(vMsgError)
            Throw ex
        End Try

    End Function

