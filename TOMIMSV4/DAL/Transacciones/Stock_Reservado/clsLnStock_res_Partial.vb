    Private Shared Sub Get_Objetos_Producto(ByRef pStockResSolicitud As clsBeStock_res,
                                            ByRef BePresentacionStock As clsBeProducto_Presentacion,
                                            ByRef IdProducto As Integer,
                                            ByRef BeProducto As clsBeProducto,
                                            ByRef lConnection As SqlConnection,
                                            ByRef ltransaction As SqlTransaction)

        Dim vIdIndiceProductoExistenteEnMemoria As Integer = -1
        Dim vIdProducto As Integer = IdProducto

        Try

            IdProducto = clsLnProducto_bodega.Get_IdProducto_By_IdProductoBodega(pStockResSolicitud.IdProductoBodega, lConnection, ltransaction)

            BePresentacionStock = Nothing
            If IdProducto <> 0 Then
                BePresentacionStock = clsLnProducto_presentacion.Get_Presentacion_Defecto_By_IdProducto(IdProducto, lConnection, ltransaction)
            End If

            If Not lProductosInMemory Is Nothing Then

                If lProductosInMemory.Count > 0 Then

                    vIdIndiceProductoExistenteEnMemoria = lProductosInMemory.FindIndex(Function(x) x.IdProducto = vIdProducto)

                    If vIdIndiceProductoExistenteEnMemoria = -1 Then

                        BeProducto = New clsBeProducto
                        BeProducto = clsLnProducto_bodega.Get_BeProducto_By_IdProductoBodega(pStockResSolicitud.IdProductoBodega, lConnection, ltransaction)

                        If BeProducto Is Nothing Then
                            Throw New Exception("Error_202302021128: No se pudo obtener el objeto de producto asociado al IdProductoBodega: " & pStockResSolicitud.IdProductoBodega)
                        End If

                        lProductosInMemory.Add(BeProducto)

                    Else
                        BeProducto = New clsBeProducto
                        BeProducto = lProductosInMemory(vIdIndiceProductoExistenteEnMemoria).Clone()
                    End If

                Else

                    BeProducto = New clsBeProducto
                    BeProducto = clsLnProducto_bodega.Get_BeProducto_By_IdProductoBodega(pStockResSolicitud.IdProductoBodega, lConnection, ltransaction)
                    lProductosInMemory.Add(BeProducto)

                End If

            End If

        Catch ex As Exception
            Throw
        End Try

    End Sub

    Public Shared Function Tiene_Cantidad_Suficiente(ByVal listaStock As List(Of clsBeStock),
                                                    ByVal stockResSolicitud As clsBeStock_res) As Boolean

        Tiene_Cantidad_Suficiente = False

        Try

            ' Verificar si la lista no está vacía
            If listaStock IsNot Nothing AndAlso listaStock.Count > 0 Then
                ' Recorrer cada elemento en la lista
                For Each stockItem In listaStock
                    ' Verificar si la cantidad es mayor a 0 y mayor o igual a la cantidad de la solicitud
                    If stockItem.Cantidad > 0 AndAlso stockItem.Cantidad >= stockResSolicitud.Cantidad Then
                        Tiene_Cantidad_Suficiente = True ' Encontramos al menos un elemento que cumple con la condición
                    End If
                Next
            End If

        Catch ex As Exception
            Throw
        End Try

    End Function

    Private Shared Function Get_Fecha_Vence_Minima_Stock_Reserva_MI3(ByVal pStockResSolicitud As clsBeStock_res,
                                                                     ByVal DiasVencimiento As Double,
                                                                     ByVal pBeConfigEnc As clsBeI_nav_config_enc,
                                                                     ByVal lConnection As SqlConnection,
                                                                     ByVal ltransaction As SqlTransaction,
                                                                     ByVal BeProducto As clsBeProducto,
                                                                     ByVal Excluir_Zona_Reabasto As Boolean,
                                                                     ByRef pListaStockExistente As List(Of clsBeStock),
                                                                     ByRef ref_FechaVenceZonaPicking As Date,
                                                                     ByRef ref_FechaVenceZonaALM As Date,
                                                                     ByVal lStockRecorrido As List(Of clsBeStock),
                                                                     ByVal pBePresentacionDefecto As clsBeProducto_Presentacion) As Date

        Dim vFechaDefecto As Date = New Date(1900, 1, 1)
        Dim FechaMinimaVencePICK As Date = vFechaDefecto
        Dim FechaMinimaVenceALM As Date = vFechaDefecto
        Dim FechaMinimaVencePICKPres As Date = vFechaDefecto
        Dim FechaMinimaVenceALMPres As Date = vFechaDefecto
        Dim FechaMinimaVenceRecorrido As Date = vFechaDefecto
        Dim vBusquedaStockEnPresentacion As Boolean = False
        Dim pStockResSolicitudPres As New clsBeStock_res


        Try
            ' Zona ALM
            Dim lBeStockExistenteZonasALM = pListaStockExistente.Where(Function(x) Not x.UbicacionPicking).ToList()
            If lBeStockExistenteZonasALM.Count > 0 Then
                If FechaMinimaVenceALM.Date = vFechaDefecto Then
                    FechaMinimaVenceALM = lBeStockExistenteZonasALM.Min(Function(x) x.Fecha_vence)
                End If
            End If

            ' Zona Picking
            Dim lBeStockExistenteZonaPicking = pListaStockExistente.Where(Function(x) x.UbicacionPicking = True).ToList()
            If lBeStockExistenteZonaPicking.Count > 0 Then
                If FechaMinimaVencePICK.Date = vFechaDefecto Then
                    FechaMinimaVencePICK = lBeStockExistenteZonaPicking.Min(Function(x) x.Fecha_vence)
                End If
            End If

            'Stock Recorrido
            If lStockRecorrido?.Any(Function(x) x.Cantidad > 0) Then
                FechaMinimaVenceRecorrido = lStockRecorrido.Min(Function(x) x.Fecha_vence)
            End If

            If pStockResSolicitud.IdPresentacion = 0 Then

                ' Si no hay stock en Zona Picking y ALM
                If Not lBeStockExistenteZonaPicking?.Any() And Not lBeStockExistenteZonasALM?.Any() Then

                    clsPublic.CopyObject(pStockResSolicitud, pStockResSolicitudPres)

                    'Buscar en presentación
                    pStockResSolicitudPres.IdPresentacion = pBePresentacionDefecto.IdPresentacion

                    'Zona Picking Presentación
                    Dim lBeStockExistenteZonaPickingPres = clsLnStock.lStock(pStockResSolicitudPres,
                                                                             BeProducto,
                                                                             DiasVencimiento,
                                                                             pBeConfigEnc,
                                                                             lConnection,
                                                                             ltransaction,
                                                                             False,
                                                                             False,
                                                                             Excluir_Zona_Reabasto)

                    Restar_Stock_Reservado(lBeStockExistenteZonaPickingPres, pBeConfigEnc, lConnection, ltransaction)
                    lBeStockExistenteZonaPickingPres = lBeStockExistenteZonaPickingPres.FindAll(Function(x) x.Cantidad > 0 And x.UbicacionPicking = True)
                    If lBeStockExistenteZonaPickingPres.Count > 0 Then
                        FechaMinimaVencePICKPres = lBeStockExistenteZonaPickingPres.Min(Function(x) x.Fecha_vence)
                    End If

                    'Zona ALM Presentación
                    Dim lBeStockExistenteZonaALMPres = clsLnStock.lStock(pStockResSolicitudPres,
                                                                         BeProducto,
                                                                         DiasVencimiento,
                                                                         pBeConfigEnc,
                                                                         lConnection,
                                                                         ltransaction,
                                                                         True,
                                                                         False,
                                                                         Excluir_Zona_Reabasto)

                    Restar_Stock_Reservado(lBeStockExistenteZonaALMPres, pBeConfigEnc, lConnection, ltransaction)
                    lBeStockExistenteZonaALMPres = lBeStockExistenteZonaALMPres.FindAll(Function(x) x.Cantidad > 0)
                    If lBeStockExistenteZonaALMPres.Count > 0 Then
                        FechaMinimaVenceALMPres = lBeStockExistenteZonaALMPres.Min(Function(x) x.Fecha_vence)
                    End If

                    vBusquedaStockEnPresentacion = True

                End If

            End If

            ' Determinar la fecha mínima entre todas las fechas
            Dim fechas As List(Of Date) = New List(Of Date) From {FechaMinimaVencePICK, FechaMinimaVenceALM, FechaMinimaVencePICKPres, FechaMinimaVenceALMPres}.Where(Function(d) d > vFechaDefecto).ToList()

            Dim vFechaMinima As Date = If(fechas.Any(), fechas.Min(), vFechaDefecto)

            ' Asignar fechas de referencia
            If Not vBusquedaStockEnPresentacion Then
                ref_FechaVenceZonaPicking = FechaMinimaVencePICK
                ref_FechaVenceZonaALM = FechaMinimaVenceALM
            Else
                ref_FechaVenceZonaPicking = FechaMinimaVencePICKPres
                ref_FechaVenceZonaALM = FechaMinimaVenceALMPres
            End If

            Return vFechaMinima

        Catch ex As Exception
            Throw ex
        End Try

    End Function

    ''' <summary>
    ''' #EJC202312201733: La idea de esta función, es obtener una lista de todos los IdStockReservados, de tal forma que el proceso de restar stock reservado sea más eficiente.
    ''' </summary>
    ''' <param name="pIdBodega"></param>
    ''' <param name="lConnection"></param>
    ''' <param name="lTransaction"></param>
    ''' <returns></returns>
    Public Shared Function Get_All_By_IdBodega(ByVal pIdBodega As Integer, ByRef lConnection As SqlConnection, ByRef lTransaction As SqlTransaction) As List(Of Integer)

        Dim lReturnValue As New List(Of Integer)


        Try
            Const sp As String = "SELECT IdStock FROM Stock_res WHERE IdBodega = @IdBodega"

            Using cmd As New SqlCommand(sp, lConnection, lTransaction)

                cmd.CommandType = CommandType.Text
                cmd.Parameters.AddWithValue("@IdBodega", pIdBodega)

                Using lDataReader As SqlDataReader = cmd.ExecuteReader()
                    While lDataReader.Read()
                        lReturnValue.Add(lDataReader.GetInt32(0)) ' Suponiendo que IdStock es el primer campo
                    End While
                End Using

            End Using

        Catch ex1 As SqlException
            Throw ex1
        Catch ex As Exception
            Dim vMsgError As String = String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message)
            clsLnLog_error_wms.Agregar_Error(vMsgError)
            Throw ex
        End Try

        Return lReturnValue

    End Function

