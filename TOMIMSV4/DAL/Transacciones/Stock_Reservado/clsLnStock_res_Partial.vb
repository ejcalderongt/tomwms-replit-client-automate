    Public Shared Function Actualizar_Ubicacion_Stock_Reservado_By_IdStockRes(ByVal IdStockRes As Integer,
                                                                              ByVal IdStock As Integer,
                                                                              ByVal IdBodega As Integer,
                                                                              ByVal IdUbicacion As Integer,
                                                                              ByVal IdUbicacionAnterior As Integer,
                                                                              ByVal lConnection As SqlConnection,
                                                                              ByVal lTransaction As SqlTransaction) As Integer

        Actualizar_Ubicacion_Stock_Reservado_By_IdStockRes = 0


        Dim rowsAffected As Integer = 0

        Try


            'Insertar el BeStockResAReubicar en tabla de log.
            Dim sp As String = " Update stock_res 
                                        set IdUbicacion = @IdUbicacion,  
                                            ubicacion_ant = @ubicacion_ant 
                                 WHERE IdStock =@IdStock AND IdBodega = @IdBodega AND IdStockRes = @IdStockRes"

            Using cmd As New SqlCommand(sp, lConnection, lTransaction) With {.CommandType = CommandType.Text}

                cmd.Parameters.Add(New SqlParameter("@IdUbicacion", IdUbicacion))
                cmd.Parameters.Add(New SqlParameter("@ubicacion_ant", IdUbicacionAnterior))
                cmd.Parameters.Add(New SqlParameter("@IdStock", IdStock))
                cmd.Parameters.Add(New SqlParameter("@IdBodega", IdBodega))
                cmd.Parameters.Add(New SqlParameter("@IdStockRes", IdStockRes))

                rowsAffected = cmd.ExecuteNonQuery()

            End Using

            Return rowsAffected

        Catch ex As Exception
            Throw ex
        End Try

    End Function

