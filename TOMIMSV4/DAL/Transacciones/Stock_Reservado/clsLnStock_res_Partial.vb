    '#EJC20171018_0734: Función para obtener la cantidad reservada por IdStock con transacción
    ''' <summary>
    ''' Devuelve la cantidad reservada para un IdStock.
    ''' </summary>
    ''' <param name="pIdStock"></param>
    ''' <param name="lConnection"></param>
    ''' <param name="lTransaction"></param>
    ''' <returns></returns>
    Public Shared Function Get_Cantidad_Reservada_By_IdStock(ByVal pIdStock As Integer,
                                                             ByRef lConnection As SqlConnection,
                                                             ByRef lTransaction As SqlTransaction) As Double

        Get_Cantidad_Reservada_By_IdStock = 0

        Try

            Dim lStockRes As New List(Of clsBeStock_res)
            Dim vIndicePres As Integer = 0

            lStockRes = Get_All_By_IdStock(pIdStock, lConnection, lTransaction)

            Dim vTotalReservado As Double = 0
            Dim BePres As New clsBeProducto_Presentacion

            For Each StockRes As clsBeStock_res In lStockRes

                If StockRes.IdPresentacion <> 0 Then

                    vIndicePres = lPresentaciones.FindIndex(Function(x) x.IdPresentacion = StockRes.IdPresentacion)

                    If vIndicePres = -1 Then
                        BePres = New clsBeProducto_Presentacion
                        BePres.IdPresentacion = StockRes.IdPresentacion
                        clsLnProducto_presentacion.GetSingle(BePres, lConnection, lTransaction)
                        lPresentaciones.Add(BePres)
                    Else
                        BePres = lPresentaciones(vIndicePres)
                    End If

                    If BePres.EsPallet Then
                        vTotalReservado += StockRes.Cantidad / (BePres.Factor * BePres.CajasPorCama * BePres.CamasPorTarima)
                    Else
                        vTotalReservado += (StockRes.Cantidad / BePres.Factor)
                    End If

                Else
                    vTotalReservado += StockRes.Cantidad
                End If

            Next

            Return vTotalReservado

        Catch ex As Exception
            Dim vMsgError As String = String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message)
            clsLnLog_error_wms.Agregar_Error(vMsgError)
            Throw ex
        End Try

    End Function

