    Private Shared Function Restar_Stock_Reservado(ByVal lStock As List(Of clsBeStock),
                                                   ByVal pBeConfigEnc As clsBeI_nav_config_enc,
                                                   ByVal lConnection As SqlConnection,
                                                   ByVal lTransaction As SqlTransaction) As Boolean

        Dim vCantidadReservadaRef As Double = 0
        Dim vPesoReservadoRef As Double = 0
        Dim vCantidadEnStockEnPresentacionClavaud As Double = 0
        Dim vCantidadProductoPorTarima As Double = 0
        Dim vCantidadTarimasCompletasAPickearClavaud As Double = 0
        Dim vCantidadEnteraTarimasCompletasClavaud As Double = 0
        Dim vCantidadDecimalTarimasCompletasClavaud As Double = 0
        Dim vIndicePresentacion As Integer = -1

        Restar_Stock_Reservado = False

        Try

            Dim BePresentacionStock As New clsBeProducto_Presentacion
            Dim vHash As String = ""

            If lStock Is Nothing Then Return True

            Dim lIdStocksReservados As New List(Of Integer)
            lIdStocksReservados = Get_All_By_IdBodega(pBeConfigEnc.Idbodega, lConnection, lTransaction)

            For Each BeStock In lStock

                If BeStock.IdStock = 753660 Or BeStock.IdStock = 762637 Or
                                                BeStock.IdStock = 762991 Or BeStock.IdStock = 764875 Or BeStock.IdStock = 767730 Then
                    Debug.Write("Hola")
                End If

                If lIdStocksReservados.Contains(BeStock.IdStock) Then

                    BePresentacionStock = BeStock.Presentacion

                    If Get_Cantidad_Y_Peso_ReservadaUMBas_By_IdStock(BeStock.IdStock,
                                                                    False,
                                                                    vCantidadReservadaRef,
                                                                    vPesoReservadoRef,
                                                                    lConnection,
                                                                    lTransaction) Then

                        If vCantidadReservadaRef <> 0 Then

                            If (BeStock.Cantidad_Reservada <> 0 And BeStock.Cantidad_Reservada <> vCantidadReservadaRef) _
                            Or BeStock.Cantidad_Reservada = 0 Then

                                BeStock.Cantidad_Reservada = vCantidadReservadaRef
                                BeStock.Pallet_Completo = False

                                If BeStock.Cantidad > 0 Then
                                    If vCantidadReservadaRef >= BeStock.Cantidad Then
                                        BeStock.Cantidad = 0
                                    Else
                                        BeStock.Cantidad -= vCantidadReservadaRef
                                        BeStock.Peso -= vPesoReservadoRef
                                    End If
                                End If
                            End If

                        Else
                            BeStock.Pallet_Completo = True
                        End If

                        '#CKFK20230209 Agregué la parametrizacion de si permitir paletizado en el reabasto
                        'Aquí lo vamos a usar para saber el entarimado de cada IdStock
                        If pBeConfigEnc.considerar_paletizado_en_reabasto Then

                            '#EJC202211091806: Parametrizar porque a Marcelo no le sirve que se valide si coincide con la tarima...
                            If Not BePresentacionStock Is Nothing Then

                                If BeStock.IdPresentacion = 0 Then
                                    BePresentacionStock = New clsBeProducto_Presentacion()
                                    BePresentacionStock.IdPresentacion = BeStock.IdPresentacion
                                    clsLnProducto_presentacion.GetSingle(BePresentacionStock, lConnection, lTransaction)
                                    lPresentaciones.Add(BePresentacionStock.Clone())
                                Else

                                    '#EJC202211081012:Buscar cantidad de tarimas por conservar zona de picking merhonsa clavaud.
                                    BePresentacionStock = New clsBeProducto_Presentacion With {.IdPresentacion = BeStock.IdPresentacion}

                                    vIndicePresentacion = lPresentaciones.FindIndex(Function(x) x.IdPresentacion = BePresentacionStock.IdPresentacion)

                                    If vIndicePresentacion <> -1 Then
                                        BePresentacionStock = New clsBeProducto_Presentacion()
                                        BePresentacionStock = lPresentaciones(vIndicePresentacion).Clone()
                                    Else
                                        BePresentacionStock = New clsBeProducto_Presentacion()
                                        BePresentacionStock.IdPresentacion = BeStock.IdPresentacion
                                        clsLnProducto_presentacion.GetSingle(BePresentacionStock, lConnection, lTransaction)
                                        lPresentaciones.Add(BePresentacionStock.Clone())
                                    End If

                                    If Not BePresentacionStock Is Nothing Then

                                        If BePresentacionStock.Factor > 0 Then

                                            If (BePresentacionStock.CajasPorCama > 0) AndAlso (BePresentacionStock.CamasPorTarima > 0) Then

                                                vCantidadProductoPorTarima = Math.Round(BePresentacionStock.CajasPorCama * BePresentacionStock.CamasPorTarima, 2)

                                                vCantidadTarimasCompletasAPickearClavaud = Math.Round(BeStock.Cantidad / vCantidadProductoPorTarima, 2)

                                                Split_Decimal(vCantidadTarimasCompletasAPickearClavaud,
                                                              vCantidadEnteraTarimasCompletasClavaud,
                                                              vCantidadDecimalTarimasCompletasClavaud)

                                            End If

                                        End If

                                    End If

                                End If

                                If BePresentacionStock.Factor > 0 Then

                                    If (BePresentacionStock.CajasPorCama > 0) AndAlso (BePresentacionStock.CamasPorTarima > 0) Then

                                        vCantidadProductoPorTarima = Math.Round(BePresentacionStock.CajasPorCama * BePresentacionStock.CamasPorTarima, 2)
                                        vCantidadTarimasCompletasAPickearClavaud = Math.Round(BeStock.Cantidad / vCantidadProductoPorTarima, 2)

                                        Split_Decimal(vCantidadTarimasCompletasAPickearClavaud,
                                                      vCantidadEnteraTarimasCompletasClavaud,
                                                      vCantidadDecimalTarimasCompletasClavaud)

                                        If (BePresentacionStock.CajasPorCama > 0) AndAlso (BePresentacionStock.CamasPorTarima > 0) Then

                                            vCantidadEnStockEnPresentacionClavaud = Math.Round(BeStock.Cantidad / BePresentacionStock.Factor, 6)

                                            '#EJC202211081355: Solo en teoría, luego hay que validar contra la presentación si ya el pallet se desarmó previamente.
                                            BeStock.Pallet_Completo = (vCantidadEnStockEnPresentacionClavaud = vCantidadProductoPorTarima)

                                            If BeStock.IdStock = 753660 Or BeStock.IdStock = 762637 Or
                                                BeStock.IdStock = 762991 Or BeStock.IdStock = 764875 Or BeStock.IdStock = 767730 Then
                                                Debug.Write("Hola")
                                            End If

                                            Debug.WriteLine("El pallet está " & IIf(BeStock.Pallet_Completo, "in", "") & "completo para el el IdStock: " & BeStock.IdStock & " - " & BeStock.Pallet_Completo)

                                        End If

                                    End If

                                End If

                            End If

                        End If

                    End If

                Else
                    BeStock.Pallet_Completo = True
                End If

            Next

            Restar_Stock_Reservado = True

        Catch ex As Exception
            Dim vMsgError As String = String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message)
            clsLnLog_error_wms.Agregar_Error(vMsgError)
            Throw ex
        End Try


    End Function

