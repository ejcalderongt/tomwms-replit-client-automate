    Public Shared Function Get_All_Stock_Res_By_IdPedidoDet(ByVal pIdPedidoDet As Integer, ByVal IdPedidoEnc As Integer) As List(Of clsBeStock_res)

        Dim lReturnList As New List(Of clsBeStock_res)
        Dim lDTA As New SqlDataAdapter
        Dim lConnection As New SqlConnection(Configuration.ConfigurationManager.AppSettings("CST"))
        Dim lTransaction As SqlTransaction = Nothing

        Try

            lConnection.Open() : lTransaction = lConnection.BeginTransaction(IsolationLevel.ReadUncommitted)

            Dim vSQL As String = "SELECT * FROM stock_res 
                                  WHERE IdPedidoDet = @IdPedidoDet AND IdPedido = @IdPedidoEnc"

            lDTA = New SqlDataAdapter(vSQL, lConnection)

            lDTA.SelectCommand.Transaction = lTransaction
            lDTA.SelectCommand.CommandType = CommandType.Text
            lDTA.SelectCommand.Parameters.AddWithValue("@IdPedidoDet", pIdPedidoDet)
            lDTA.SelectCommand.Parameters.AddWithValue("@IdPedidoEnc", IdPedidoEnc)

            Dim lDataTable As New DataTable
            lDTA.Fill(lDataTable)

            Dim Obj As clsBeStock_res

            If lDataTable IsNot Nothing AndAlso lDataTable.Rows.Count > 0 Then

                For Each lRow As DataRow In lDataTable.Rows

                    Obj = New clsBeStock_res
                    Cargar(Obj, lRow)
                    lReturnList.Add(Obj)

                Next

            End If

            lTransaction.Commit()

            Return lReturnList

        Catch ex As Exception
            lTransaction.Rollback()
            Throw ex
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close()
            lConnection.Dispose()
            If lTransaction IsNot Nothing Then lTransaction.Dispose()
        End Try

    End Function

    '#CKFK 20201125 Le agregué valores por defecto a estos campos cuando sean nulos IdPresentacion, ubicacion_ant, lote, lic_plate, serial,
    'user_agr, user_mode
    '#CKFK 20211221 Agregué el campo pallet_no_estandar al select
    Public Shared Function Get_All_Stock_Res_By_IdPedidoDet(ByVal pIdPedidoDet As Integer,
                                                  ByRef lConnection As SqlConnection,
                                                  ByRef lTransaction As SqlTransaction) As List(Of clsBeStock_res)

        Dim lReturnList As New List(Of clsBeStock_res)
        Dim lDTA As New SqlDataAdapter

        Try

            Dim vSQL As String = "SELECT IdStockRes, IdTransaccion, Indicador, IdPedidoDet, IdStock, IdPropietarioBodega, IdProductoBodega, 
                                         IdProductoEstado, ISNULL(IdPresentacion,0) AS IdPresentacion, IdUnidadMedida, IdUbicacion, 
	                                     ISNULL(ubicacion_ant,0) as ubicacion_ant, IdRecepcion, ISNULL(lote, '') lote,
	                                     ISNULL(lic_plate, '') lic_plate, ISNULL(serial,'') serial, cantidad, peso, estado, 
	                                     fecha_ingreso, fecha_vence, uds_lic_plate, no_bulto, IdPicking, IdPedido, IdDespacho, 
	                                     ISNULL(user_agr, '') user_agr, fec_agr,  ISNULL(user_mod,'')  user_mod, fec_mod, host, añada, 
	                                     fecha_manufactura, idbodega, pallet_no_estandar
                                  FROM stock_res
