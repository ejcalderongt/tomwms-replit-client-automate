    '#AT 20220124 Reservar  Stock Reemplazo verificación
    Public Shared Function Reservar_Stock_By_IdStock(ByVal IdStock As Integer,
                                                     ByVal CantSol As Double,
                                                     ByVal MaquinaQueSolicita As String,
                                                     ByVal IdPickingEnc As Integer,
                                                     ByVal IdPedidoEnc As Integer,
                                                     ByVal IdUsuarioHH As Integer,
                                                     ByVal IdPedidoDet As Integer,
                                                     ByVal IdPickingUbic As Integer,
                                                     ByVal EsPicking As Boolean,
                                                     ByVal IdPresentacionPedido As Integer,
                                                     ByVal Tipo As Integer,
                                                     ByRef lConnection As SqlConnection,
                                                     ByRef lTransaction As SqlTransaction) As Boolean

        Reservar_Stock_By_IdStock = False

        Try

            Dim lBeStockAReservar As New List(Of clsBeStock_res)
            Dim BeStock As New clsBeStock
            Dim BeStockRes As New clsBeStock_res

            If IdStock <> 0 Then

                lConnection.Open() : lTransaction = lConnection.BeginTransaction(IsolationLevel.ReadUncommitted)

                BeStock.IdStock = IdStock

                '#CKFK 20180331 11:25 PM Agregué la función con transaccionalidad anteriormente estaba esta clsLnStock.GetSingle(BeStock)
                BeStock = clsLnStock.GetSingle(BeStock.IdStock,
                                               lConnection,
                                               lTransaction)

                Dim vCantidadCompletada As Boolean = False
                Dim vCantidadStock As Double = 0
                Dim vCantidadPendiente As Double = 0
                Dim vCantidadSolicitadaPedido As Double = 0
                Dim vValorEnteroCantidadSolicitadaPedido As Integer = 0
                Dim vCantidadAReservarPorIdStock As Double = 0

                If IdPresentacionPedido = 0 Then
                    vCantidadSolicitadaPedido = CantSol
                Else

                    Dim BePres As New clsBeProducto_Presentacion With {.IdPresentacion = BeStock.IdPresentacion}

                    clsLnProducto_presentacion.GetSingle(BePres,
                                                         lConnection,
                                                         lTransaction)

                    If BePres.EsPallet Then

                        Dim vFactorPallet As Double = (BePres.Factor * BePres.CajasPorCama * BePres.CamasPorTarima)

                        If vFactorPallet > 0 Then
                            vCantidadSolicitadaPedido = CantSol * vFactorPallet
                        Else
                            Throw New Exception("No se pudo reservar el stock para el tipo de producto pallet porque los factores de conversión dan un denominador = 0")
                        End If

                    Else

                        vCantidadSolicitadaPedido = CantSol * BePres.Factor

                        If Not clsLnProducto.Tiene_Control_Por_Peso_By_IdProductoBodega(BeStock.IdProductoBodega,
                                                                                        lConnection,
                                                                                        lTransaction) Then

                            If Integer.TryParse(vCantidadSolicitadaPedido, vValorEnteroCantidadSolicitadaPedido) Then
                                vCantidadSolicitadaPedido = vValorEnteroCantidadSolicitadaPedido
                            Else
                                vCantidadSolicitadaPedido = Math.Truncate(vCantidadSolicitadaPedido)
                            End If

                        Else
                            vCantidadSolicitadaPedido = Math.Round(vCantidadSolicitadaPedido, 6)
                        End If

                    End If

                End If

                If Not BeStock Is Nothing Then

                    vCantidadPendiente = vCantidadSolicitadaPedido

                    vCantidadStock = BeStock.Cantidad

                    BeStockRes = New clsBeStock_res
                    BeStockRes.IdTransaccion = IdPedidoEnc
                    BeStockRes.Indicador = "PED"
                    BeStockRes.IdBodega = BeStock.IdBodega
                    BeStockRes.IdStock = BeStock.IdStock
                    BeStockRes.IdPropietarioBodega = BeStock.IdPropietarioBodega
                    BeStockRes.IdProductoBodega = BeStock.IdProductoBodega

                    If vCantidadPendiente = vCantidadStock Then
                        vCantidadAReservarPorIdStock = vCantidadStock
                        vCantidadPendiente -= vCantidadStock
                    ElseIf vCantidadPendiente < vCantidadStock Then
                        vCantidadAReservarPorIdStock = vCantidadPendiente
                        vCantidadPendiente -= vCantidadAReservarPorIdStock
                    ElseIf vCantidadPendiente > vCantidadStock Then
                        vCantidadAReservarPorIdStock = vCantidadStock
                        vCantidadPendiente -= vCantidadStock
                    End If

                    BeStockRes.IdUbicacion = BeStock.IdUbicacion
                    BeStockRes.IdProductoEstado = BeStock.IdProductoEstado
                    '#CKFK 20180219 Cambié la asignación de BeStock.Presentacion.IdPresentación por BeStosck.IdPresentacion
                    BeStockRes.IdPresentacion = IdPresentacionPedido
                    BeStockRes.IdUnidadMedida = BeStock.IdUnidadMedida
                    BeStockRes.Lote = BeStock.Lote
                    BeStockRes.Lic_plate = BeStock.Lic_plate
                    BeStockRes.Serial = BeStock.Serial
                    BeStockRes.Peso = BeStock.Peso
                    BeStockRes.Estado = "UNCOMMITED HH"
                    BeStockRes.Fecha_ingreso = BeStock.Fecha_Ingreso
                    BeStockRes.Fecha_vence = BeStock.Fecha_vence
                    BeStockRes.Uds_lic_plate = BeStock.Uds_lic_plate
                    '#CKFK 20171120 06:41PM Guardé en el campo Ubicacion_ant el id de la ubicación anterior de Stock
                    BeStockRes.Ubicacion_ant = BeStock.IdUbicacion_anterior
                    BeStockRes.No_bulto = BeStock.No_bulto
                    BeStockRes.IdRecepcion = BeStock.IdRecepcionEnc
                    BeStockRes.IdPicking = IdPickingEnc
                    BeStockRes.IdPedido = IdPedidoEnc
                    BeStockRes.IdPedidoDet = IdPedidoDet
                    BeStockRes.IdDespacho = 0
                    BeStockRes.añada = BeStock.Añada
                    BeStockRes.Fecha_manufactura = BeStock.Fecha_Manufactura
                    '#CM20181308_3:23PM:Redondea la cantidad a reservar por IdStock a 6 cifras.
                    BeStockRes.Cantidad = Math.Round(vCantidadAReservarPorIdStock, 6)
                    BeStockRes.IdRecepcion = BeStock.IdRecepcionEnc
                    '#EJC20171018_0715PM: Registrar en tabla stock_res la PC que bloqueó/reservó el stock
                    BeStockRes.Host = MaquinaQueSolicita
                    '#CKFK 20180208 08:50 PM agregué campos que faltaban en StockRes
                    BeStockRes.User_agr = IdUsuarioHH
                    BeStockRes.User_mod = IdUsuarioHH
                    vCantidadCompletada = (vCantidadPendiente = 0)

                    'pStockRes.Cantidad = vCantidadReservada
                    lBeStockAReservar.Add(BeStockRes)

                End If

                If lBeStockAReservar.Count > 0 Then

                    '#CKFK 20201129 Inserto el nuevo stock reservado
                    If Inserta_Stock_Reservado(lBeStockAReservar,
                                               lConnection,
                                               lTransaction) Then
                        Reservar_Stock_By_IdStock = True
                    Else
                        Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0006, BeStock.IdProductoBodega))
                    End If

                Else
                    Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0005, BeStock.IdProductoBodega))
                End If

                '#CKFK 20180208 11:47PM Actualizar la cantidad solicitada en trans_picking_ubic
                Dim bePickingUbicExistente As New clsBeTrans_picking_ubic With {
                    .IdPickingUbic = IdPickingUbic
                }

                '#CKFK 20180331 11:25 PM Agregué la función con transaccionalidad anteriormente estaba esta clsLnTrans_picking_ubic.GetSingle(bePickingUbic
                clsLnTrans_picking_ubic.GetSingle(bePickingUbicExistente,
                                                  lConnection,
                                                  lTransaction)

                bePickingUbicExistente.Cantidad_Solicitada -= CantSol

                If Not EsPicking Then
                    bePickingUbicExistente.Cantidad_Recibida -= CantSol
                End If

                If bePickingUbicExistente.Cantidad_Solicitada <> 0 Then

                    bePickingUbicExistente.IdStockRes = lBeStockAReservar(0).IdStockRes
                    bePickingUbicExistente.Cantidad_Solicitada = CantSol
                    bePickingUbicExistente.Acepto = 0
                    bePickingUbicExistente.Encontrado = 0
                    bePickingUbicExistente.Dañado_picking = False
                    bePickingUbicExistente.Dañado_verificacion = False

                    If Not EsPicking Then
                        bePickingUbicExistente.Cantidad_Recibida = CantSol
                    End If

                    bePickingUbicExistente.IdPickingUbic = clsLnTrans_picking_ubic.MaxID(lConnection, lTransaction) + 1

                    clsLnTrans_picking_ubic.Insertar(bePickingUbicExistente,
                                                     lConnection,
                                                     lTransaction)

                ElseIf bePickingUbicExistente.Cantidad_Solicitada = 0 Then

                    bePickingUbicExistente.IdStockRes = lBeStockAReservar(0).IdStockRes
                    bePickingUbicExistente.Cantidad_Solicitada = CantSol
                    bePickingUbicExistente.Acepto = 0
                    bePickingUbicExistente.Acepto = 0
                    bePickingUbicExistente.Encontrado = 0
                    bePickingUbicExistente.Dañado_picking = False
                    bePickingUbicExistente.Dañado_verificacion = False

                    If Not EsPicking Then
                        bePickingUbicExistente.Cantidad_Recibida = CantSol
                    End If

                    bePickingUbicExistente.IdPickingUbic = clsLnTrans_picking_ubic.MaxID(lConnection, lTransaction) + 1

                    clsLnTrans_picking_ubic.Insertar(bePickingUbicExistente,
                                                     lConnection,
                                                     lTransaction)

                End If

                If Not EsPicking Then

                    Dim BePickingEnc As New clsBeTrans_picking_enc
                    BePickingEnc.IdPickingEnc = clsLnTrans_picking_ubic.ObtienIdPickingEnc_Y_Verifica_Estado_PickingEnc_ByPickingUbic(IdPickingUbic,
                                                                                                                                      lConnection,
                                                                                                                                      lTransaction)

                    If BePickingEnc.IdPickingEnc <> 0 Then
                        BePickingEnc.Estado = "Pendiente"
                        clsLnTrans_picking_enc.ActualizarEstadoByRemplazo(BePickingEnc,
                                                                          lConnection,
                                                                          lTransaction)
                    End If

                End If

                lTransaction.Commit()

            Else
                Throw New Exception(String.Format("{0} IdProductoBodegaSol: {1}", clsDalEx.ErrorS0004, BeStock.IdProductoBodega))
            End If

        Catch ex As Exception
            If lTransaction IsNot Nothing Then lTransaction.Rollback()
            Throw New Exception(ex.Message)
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close() : lConnection.Dispose()
            If lTransaction IsNot Nothing Then lTransaction.Dispose()
        End Try

    End Function

