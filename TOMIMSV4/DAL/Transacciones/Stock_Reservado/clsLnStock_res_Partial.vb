            Dim CantidadCompletada As Boolean = False
            Dim result As Boolean = False

            CantTotal = pCantReemplazar

            '#AT 20220128 Se obtiene la lista de PickingUbic
            '#AT20241206 Agregue el parametro pIdPedidoEnc = 0
            tmpBePickingUbic = clsLnTrans_picking_ubic.Get_All_PickingUbic_By_IdPickingEnc_For_Verificacion(pIdPickingEnc, False, 0, plistPickingUbi.IdPedidoEnc, lConnection, lTransaction)

            BeBodega = New clsBeBodega With {.IdBodega = pIdBodega}
            clsLnBodega.GetSingle(BeBodega, lConnection, lTransaction)

            If tmpBePickingUbic.Count > 0 Then

                '#AT 20220128 Se filtra tmpBePickingUbic en base al codigoproducto, lote, fecha y Dañado_verificacion
                'tmpBePickingUbic.Where(Function(x) x.CodigoProducto = plistPickingUbi.CodigoProducto And x.Lote = plistPickingUbi.Lote And x.Fecha_Vence = plistPickingUbi.Fecha_Vence And x.Dañado_verificacion = 0)
                If BeBodega.Verificacion_Consolidada Then
                    ListPickingUbic = tmpBePickingUbic.Where(Function(x) x.CodigoProducto = plistPickingUbi.CodigoProducto And
                                                            x.Dañado_verificacion = 0 And
                                                            x.IdPresentacion = plistPickingUbi.IdPresentacion And
                                                            x.Dañado_picking = 0 And
                                                            x.No_encontrado = 0).ToList
                Else
                    ListPickingUbic = tmpBePickingUbic.Where(Function(x) x.CodigoProducto = plistPickingUbi.CodigoProducto And
                                                            x.Lote = plistPickingUbi.Lote And
                                                            x.Fecha_Vence = plistPickingUbi.Fecha_Vence And
                                                            x.Dañado_verificacion = 0 And
                                                            x.IdPresentacion = plistPickingUbi.IdPresentacion And
                                                            x.Dañado_picking = 0 And
                                                            x.No_encontrado = 0).ToList

                End If

                For Each tmp In ListPickingUbic
                    CantidadRecibida += tmp.Cantidad_Recibida
                    CantidadVerificada += tmp.Cantidad_Verificada
                Next

                Dim CantDisponible = CantidadRecibida - CantidadVerificada

                '#AT Se valida si la cantidad a reemplazar es mayor a la disponible
                If pCantTotal > CantDisponible Then
                    Throw New Exception("No se puede completar el proceso, la cantidad a reemplazar es mayor a la disponible: (" + CantDisponible.ToString + ")")
                End If

                '#AT 20220127 Se valida el estado del PickingEnc si esta Procesado se debe cambiar a Pendiente 
                'para que se pueda ver de nuevo en las tareas de pikcing
                BeTrans_picking_enc.IdPickingEnc = pIdPickingEnc
                clsLnTrans_picking_enc.GetSingle(BeTrans_picking_enc)

                If BeTrans_picking_enc.Estado.Equals("Procesado") Then
                    Dim bePickingEnc As New clsBeTrans_picking_enc() With {.IdPickingEnc = pIdPickingEnc, .Estado = "Pendiente"}
                    clsLnTrans_picking_enc.Actualizar_Estado(bePickingEnc)
                End If

                For Each pu In ListPickingUbic
                    Dim DisponibleReem = pu.Cantidad_Recibida - pu.Cantidad_Verificada

                    If pCantReemplazar >= DisponibleReem Then

                        tmpCantPend = pCantReemplazar - DisponibleReem
                        pCantReemplazar = DisponibleReem

                    End If

                    result = Reemplazar_IdStock_By_Stock(pBeStockRes,
                                                         pCantReemplazar,
                                                         pHost,
                                                         pu.IdPickingEnc,
                                                         pu.IdPedidoEnc,
                                                         pIdOperador,
                                                         pu.IdPedidoDet,
                                                         pu.IdPickingUbic,
                                                         False,
                                                         1,
                                                         pIdUbicDestino,
                                                         pIdEstadoDestino,
                                                         CantPend,
                                                         lConnection,
                                                         lTransaction)

                    pu.Cantidad_Recibida = pCantReemplazar
                    clsLnTrans_picking_det.Actualizar_Cantidad_Picking_Det(pu,
                                                                           lConnection,
                                                                           lTransaction)

                    CantTotal -= pCantReemplazar

                    If result Then
                        If CantTotal = 0 Then
                            Exit For
                        Else
                            pCantReemplazar = tmpCantPend
                        End If
                    End If
                Next
            Else
                Throw New Exception("No se puede completar el proceso, la cantidad a reemplazar es mayor a la disponible: (0)")
            End If

            lTransaction.Commit()

            Return True

        Catch ex As Exception
            If lTransaction IsNot Nothing Then lTransaction.Rollback()
            Throw ex
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close() : lConnection.Dispose()
            If lTransaction IsNot Nothing Then lTransaction.Dispose()
        End Try

    End Function

    '#AT 20240515 Funcion para el reemplazo automatico
    Public Shared Function Reemplazo_Automatico(ByVal pBeStock_res As clsBeStock_res,
                                                ByVal CantSol As Double,
                                                ByVal MaquinaQueSolicita As String,
                                                ByVal IdPickingEnc As Integer,
                                                ByVal IdPedidoEnc As Integer,
                                                ByVal IdUsuarioHH As Integer,
                                                ByVal IdPedidoDet As Integer,
                                                ByVal IdPickingUbic As Integer,
                                                ByVal EsPicking As Boolean,
                                                ByVal Tipo As Integer,
                                                ByVal IdUbicDestino As Integer,
                                                ByVal IdEstDestino As Integer,
                                                ByVal Picking As clsBeTrans_picking_ubic,
                                                ByRef CantPend As Double) As List(Of clsBeTrans_picking_ubic)

        Dim lConnection As New SqlConnection(Configuration.ConfigurationManager.AppSettings("CST"))
        lConnection.Open()

        Dim lTransaction As SqlTransaction = lConnection.BeginTransaction(IsolationLevel.ReadUncommitted)

        Reemplazo_Automatico = Nothing

        Try
            Dim clsLnStock As New clsLnStock
            Dim BeTransPickingUbic As New clsBeTrans_picking_ubic
            Dim BeTransPeEnc As New clsBeTrans_pe_enc
            Dim StockResList As New List(Of clsBeStock_res)
            Dim Stock As New List(Of clsBeStock)
            Dim vCantidadReservada, CantSolTotal As Double
            Dim CantidadCompletada As Boolean = False
            Dim CantidadPendiente As Double
            Dim IdPropietarioBodega As Integer = 0

            CantSolTotal = CantSol

            '#AT 202202008 se obtiene el picking actual y se valida que este disponible para aplicar el reemplazo o ne
            BeTransPickingUbic.IdPickingUbic = IdPickingUbic
            clsLnTrans_picking_ubic.GetSingle(BeTransPickingUbic, lConnection, lTransaction)

            Dim CantDisponible = BeTransPickingUbic.Cantidad_Solicitada - BeTransPickingUbic.Cantidad_Recibida
            Dim Diferencia As Double = BeTransPickingUbic.Cantidad_Solicitada - (CantSol + BeTransPickingUbic.Cantidad_Recibida)

            If Diferencia < 0 Then
                Throw New Exception("No se puede completar el proceso, la cantidad a reemplazar es mayor a la disponible: (" + CantDisponible.ToString + ")")
            End If

            Stock = clsLnStock.Get_Stock_Reemplazo_Automatico(pBeStock_res, lConnection, lTransaction)

            If Stock.Count > 0 Then
                For Each s In Stock
                    vCantidadReservada = Get_Cantidad_ReservadaUMBas_By_IdStock(s.IdStock,
                                                                                False,
                                                                                lConnection,
                                                                                lTransaction)

                    If vCantidadReservada <> 0 Then
                        s.Cantidad -= vCantidadReservada
                    End If
                Next

                If Stock.Any(Function(x) x.Cantidad > 0) Then

                    For Each i In Stock.Where(Function(x) x.Cantidad > 0)

                        If i.Cantidad >= CantSol Then
                            Dim resultRes As Boolean = Reservar_Stock_By_Stock_Reem(i,
                                                                            CantSol,
                                                                            MaquinaQueSolicita,
                                                                            IdPickingEnc,
                                                                            IdPedidoEnc,
                                                                            IdUsuarioHH,
                                                                            IdPedidoDet,
                                                                            IdPickingUbic,
                                                                            EsPicking,
                                                                            pBeStock_res.IdPresentacion,
                                                                            Tipo,
                                                                            CantidadPendiente,
                                                                            lConnection,
                                                                            lTransaction)

                            If resultRes Then
                                CantidadCompletada = (CantidadPendiente = 0)
                                If CantidadCompletada Then
                                    Exit For
                                Else
                                    CantSol = CantidadPendiente
                                End If
                            End If
                        Else
                            Throw New Exception("No hay existencia suficiente para completar el reemplazo.")
                        End If
                    Next

                    CantPend = CantidadPendiente
                    'BeTransPickingUbic.IdPickingUbic = IdPickingUbic
                    'clsLnTrans_picking_ubic.GetSingle(BeTransPickingUbic, lConnection, lTransaction)

                    BeTransPeEnc = clsLnTrans_pe_enc.GetSingle(IdPedidoEnc, lConnection, lTransaction)

                    If BeTransPeEnc IsNot Nothing Then
                        IdPropietarioBodega = BeTransPeEnc.IdPropietarioBodega
                    End If

                    StockResList = Get_All_Reemplazo_By_IdPedidoDet(IdPedidoDet,
                                                                IdPropietarioBodega,
                                                                IdPickingEnc,
                                                                IdPedidoEnc,
                                                                lConnection,
                                                                lTransaction)

                    If StockResList IsNot Nothing Then

                        Dim resultReemp As Boolean = False

                        resultReemp = clsLnTrans_picking_ubic.Reemplazo_Producto_En_Picking(BeTransPickingUbic.IdStock,
                                                                                    IdPickingEnc,
                                                                                    BeTransPickingUbic.IdPickingDet,
                                                                                    CantSolTotal,
                                                                                    MaquinaQueSolicita,
                                                                                    IdUsuarioHH,
                                                                                    StockResList,
                                                                                    BeTransPeEnc.IdBodega,
                                                                                    BeTransPeEnc.Cliente.IdEmpresa,
                                                                                    IdUbicDestino,
                                                                                    IdEstDestino,
                                                                                    BeTransPickingUbic.IdStockRes,
                                                                                    EsPicking,
                                                                                    lConnection,
                                                                                    lTransaction,
                                                                                    Tipo)
                        If Not resultReemp Then
                            Throw New Exception(String.Format("{0} {1}", MethodBase.GetCurrentMethod().Name, "No se logró reemplazar el IdStock"))
                        Else
                            Reemplazo_Automatico = clsLnTrans_picking_ubic.Get_PickingUbicRem_By_IdPickingUbic(Picking,
                                                                                                       pBeStock_res.Lic_plate,
                                                                                                       lConnection,
                                                                                                       lTransaction)
                        End If

                    End If
                Else
                    Throw New Exception("Licencia reservada por completo")
                End If
            Else
                Throw New Exception("No encontró existencia con la misma fecha de vencimiento y lote.")
            End If

            lTransaction.Commit()

            Return Reemplazo_Automatico

        Catch ex As Exception
            If lTransaction IsNot Nothing Then lTransaction.Rollback()
            Throw ex
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close() : lConnection.Dispose()
            If lTransaction IsNot Nothing Then lTransaction.Dispose()
        End Try

    End Function

    '#AT 20240515 Funcion para el reemplazo automatico consolidado
    Public Shared Function Reemplazo_Automatico_Conso(ByVal pBeStock_res As clsBeStock_res,
                                                       ByVal CantSol As Double,
                                                       ByVal MaquinaQueSolicita As String,
                                                       ByVal IdPickingEnc As Integer,
                                                       ByVal IdPedidoEnc As Integer,
                                                       ByVal IdUsuarioHH As Integer,
                                                       ByVal IdPedidoDet As Integer,
                                                       ByVal BePickingUbic As clsBeTrans_picking_ubic,
                                                       ByVal EsPicking As Boolean,
                                                       ByVal Tipo As Integer,
                                                       ByVal IdUbicDestino As Integer,
                                                       ByVal IdEstDestino As Integer,
                                                       ByVal CantidadTotal As Double,
                                                       ByRef CantPend As Double) As List(Of clsBeTrans_picking_ubic)
        Dim lConnection As New SqlConnection(Configuration.ConfigurationManager.AppSettings("CST"))
        Dim lTransaction As SqlTransaction = Nothing

        Reemplazo_Automatico_Conso = Nothing

        Try

            Dim clsLnStock As New clsLnStock
            Dim ListTransPickingUbic As New List(Of clsBeTrans_picking_ubic)
            Dim CantidadPendiente As Double = 0
            Dim tmpCantPend As Double = 0
            Dim CantTotal As Double = 0
            Dim CantSolicitada As Double = 0
            Dim CantRecibida As Double = 0
            Dim CantidadCompletada As Boolean = False
            Dim result As Boolean = False

            CantTotal = CantSol

            lConnection.Open() : lTransaction = lConnection.BeginTransaction(IsolationLevel.ReadUncommitted)

            If IdPedidoEnc = 0 Then

                IdPedidoEnc = clsLnTrans_pe_enc.Get_IdPedido_By_IdPickingEnc(IdPickingEnc,
                                                                             lConnection,
                                                                             lTransaction)

                If IdPedidoEnc = 0 Then
                    Throw New Exception("El IdPedidoEnc es 0 no se puede continuar el proceso")
                End If

            End If

            If BePickingUbic.IdPickingEnc = 0 Then
                BePickingUbic.IdPickingEnc = IdPickingEnc
            End If

            ListTransPickingUbic = clsLnTrans_picking_ubic.Get_All_PickingUbic_By_PickingUbic(BePickingUbic,
                                                                                              lConnection,
                                                                                              lTransaction)

            If ListTransPickingUbic.Count > 0 Then

                '#AT Suma cantidades solicitadas y recibidas para calcular la cantidad disponible 
                For Each tmp In ListTransPickingUbic
                    CantSolicitada += tmp.Cantidad_Solicitada
                    CantRecibida += tmp.Cantidad_Recibida
                Next

                Dim CantDisponible = CantSolicitada - CantRecibida

                '#AT Se valida si la cantidad a reemplazar es mayor a la disponible
                If CantidadTotal > CantDisponible Then
                    Throw New Exception("No se puede completar el proceso, la cantidad a reemplazar es mayor a la disponible: (" + CantDisponible.ToString + ")")
                End If

                For Each pu In ListTransPickingUbic

                    '#AT Se resta la cantidad recibida a la solicitada
                    Dim DisponibleReem = pu.Cantidad_Solicitada - pu.Cantidad_Recibida

                    If CantSol >= DisponibleReem Then

                        tmpCantPend = CantSol - (pu.Cantidad_Solicitada - pu.Cantidad_Recibida)
                        CantSol = DisponibleReem

                    End If

                    result = ReemplazarAuto_IdStock_By_Stock(pBeStock_res,
                                                         CantSol,
                                                         MaquinaQueSolicita,
                                                         IdPickingEnc,
                                                         pu.IdPedidoEnc,
                                                         IdUsuarioHH,
                                                         IIf(IdPedidoDet = 0, pu.IdPedidoDet, IdPedidoDet),
                                                         pu.IdPickingUbic,
                                                         EsPicking,
                                                         Tipo,
                                                         IdUbicDestino,
                                                         IdEstDestino,
                                                         CantPend,
                                                         lConnection,
                                                         lTransaction)

                    CantTotal -= CantSol

                    If result Then
                        'CantidadCompletada = (tmpCantPend = 0)
                        If CantTotal = 0 Then

                            Reemplazo_Automatico_Conso = clsLnTrans_picking_ubic.Get_PickingUbicRemConso_By_IdPickingUbic(BePickingUbic,
                                                                                                                    pBeStock_res.Lic_plate,
                                                                                                                    lConnection,
                                                                                                                    lTransaction)

                            Exit For
                        Else
                            CantSol = tmpCantPend
                        End If
                    End If
                Next

            Else
                Throw New Exception(": No se puede completar el proceso, la cantidad a reemplazar es mayor a la disponible: (0)")
            End If

            lTransaction.Commit()

            Return Reemplazo_Automatico_Conso

        Catch ex As Exception
            If lTransaction IsNot Nothing Then lTransaction.Rollback()
            Throw ex
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close() : lConnection.Dispose()
            If lTransaction IsNot Nothing Then lTransaction.Dispose()
        End Try

    End Function

