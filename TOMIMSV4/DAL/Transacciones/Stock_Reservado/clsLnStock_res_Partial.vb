    Public Shared Function Eliminar_Stock_Reservado_By_BePickingUbic_And_IdStock(ByVal BePickingUbic As clsBeTrans_picking_ubic,
                                                                                 ByVal IdPedidoEnc As Integer,
                                                                                 ByVal IdStock As Integer,
                                                                                 ByVal IdBodega As Integer,
                                                                                 ByRef lConnection As SqlConnection,
                                                                                 ByRef ltransaction As SqlTransaction) As Integer

        Dim rowsAffected As Integer = 0
        Dim vDiferencia As Double = 0
        Dim BeProductoPresentacion As New clsBeProducto_Presentacion()
        Dim vCantidadPickeadaUMBas As Double = 0

        Eliminar_Stock_Reservado_By_BePickingUbic_And_IdStock = 0

        Try

            '#EJC20220412: Si recibió menos de lo que solicitaron (aun tiene pendiente por pickear)
            If BePickingUbic.Cantidad_Solicitada > BePickingUbic.Cantidad_Recibida Then

                vDiferencia = BePickingUbic.Cantidad_Solicitada - BePickingUbic.Cantidad_Recibida

                '#EJC20220412: Another way to say, he didn't pick nothing.
                'If so, we should release all the stock_res.
                If BePickingUbic.Cantidad_Solicitada = vDiferencia Then

                    'Elimina el stock reservado
                    Dim sp As String = " DELETE from stock_res 
                                         WHERE IdPedidoDet =@IdPedidoDet AND IdPedido = @IdPedido 
                                         AND IdStock = @IdStock AND IdBodega = @IdBodega AND IdStockRes = @IdStockRes "

                    Using cmd As New SqlCommand(sp, lConnection, ltransaction) With {.CommandType = CommandType.Text}

                        cmd.Parameters.Add(New SqlParameter("@IDPEDIDODET", BePickingUbic.IdPedidoDet))
                        cmd.Parameters.Add(New SqlParameter("@IDPEDIDO", IdPedidoEnc))
                        cmd.Parameters.Add(New SqlParameter("@IDSTOCK", IdStock))
                        cmd.Parameters.Add(New SqlParameter("@IDBODEGA", IdBodega))
                        cmd.Parameters.Add(New SqlParameter("@IDSTOCKRES", BePickingUbic.IdStockRes))

                        rowsAffected = cmd.ExecuteNonQuery()

                    End Using

                Else

                    Dim lBeStockRes As New List(Of clsBeStock_res)
                    Dim BeStockRes As New clsBeStock_res()

                    lBeStockRes = Get_Single_By_BePickingUbic(BePickingUbic,
                                                              lConnection,
                                                              ltransaction)

                    If Not lBeStockRes Is Nothing Then

                        If lBeStockRes.Count = 1 Then

                            BeStockRes = lBeStockRes(0)
                            '#EJC20220412:La cantidad reservada está en UMBas.

                            If BePickingUbic.IdPresentacion = 0 Then

                                If BePickingUbic.Cantidad_Recibida < BeStockRes.Cantidad Then

                                    BeStockRes.Cantidad = BeStockRes.Cantidad - BePickingUbic.Cantidad_Recibida

                                    rowsAffected = Actualizar_Cantidad_Reservada_By_BeStockRes(BeStockRes,
                                                                                                  lConnection,
                                                                                                  ltransaction)

                                Else
                                    Throw New Exception("ERROR_202204121638 (UMBas): La cantidad pickeada: " & BePickingUbic.Cantidad_Recibida & " es mayor que el registro de reserva:" & BeStockRes.Cantidad)
                                End If

                            Else

                                BeProductoPresentacion = clsLnProducto_presentacion.GetSingle(BePickingUbic.IdPresentacion,
                                                                                              lConnection,
                                                                                              ltransaction)

                                If Not BeProductoPresentacion Is Nothing Then

                                    vCantidadPickeadaUMBas = Math.Round(BePickingUbic.Cantidad_Recibida * BeProductoPresentacion.Factor, 6)

                                    If vCantidadPickeadaUMBas <= BeStockRes.Cantidad Then

                                        '#EJC20220412:Dejar el registro de reserva con la cantidad que se pickeo.
                                        BeStockRes.Cantidad = BeStockRes.Cantidad - vCantidadPickeadaUMBas

                                        If BeStockRes.Cantidad = 0 Then

                                            rowsAffected = Eliminar_Stock_Reservado_By_IdPedidoDet_And_IdStock(BeStockRes.IdPedidoDet,
                                                                                                               BeStockRes.IdPedido,
                                                                                                               BeStockRes.IdStock,
                                                                                                               BeStockRes.IdBodega,
                                                                                                               lConnection,
                                                                                                               ltransaction)

                                        Else
                                            rowsAffected = Actualizar_Cantidad_Reservada_By_BeStockRes(BeStockRes,
                                                                                                      lConnection,
                                                                                                      ltransaction)
                                        End If


                                    Else
                                        Throw New Exception("ERROR_202204121638 (Pres): La cantidad pickeada: " & vCantidadPickeadaUMBas & " es mayor que el registro de reserva: " & BeStockRes.Cantidad)
                                    End If

                                End If

                            End If

                        Else
                            Throw New Exception("Error_202204121623: Escenario no controlado de reserva, se obtuvo más de un registro de reserva para la ubicación de picking.")
                        End If

                    Else
                        Throw New Exception("Error_20220818: No se pudo liberar el stock reservado asociado o el pedido ya no tiene stock reservado (creo).")
                    End If

                End If

            End If

            Eliminar_Stock_Reservado_By_BePickingUbic_And_IdStock = rowsAffected

        Catch ex As Exception
            Throw ex
        End Try

    End Function

