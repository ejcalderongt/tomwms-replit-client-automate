        Dim lConnection As New SqlConnection(Configuration.ConfigurationManager.AppSettings("CST"))
        lConnection.Open()

        Dim lTransaction As SqlTransaction = lConnection.BeginTransaction(IsolationLevel.ReadUncommitted)

        Reemplazo_Verificacion_By_ListPickingUbic = False

        Try
            Dim clsLnStock As New clsLnStock
            Dim BeTrans_picking_enc As New clsBeTrans_picking_enc
            Dim BeBodega As New clsBeBodega
