    Public Shared Function Actualizar_Estado_Pickeado(ByRef oBeStock_res As clsBeStock_res,
                                                      ByRef lConnection As SqlConnection,
                                                      ByRef ltransaction As SqlTransaction) As Integer

        Actualizar_Estado_Pickeado = 0

        Try

            'Actualiza el stock reservado
            Dim sp As String = " UPDATE stock_res 
                                 SET estado = @estado,
                                 user_mod = @user_mod,
                                 fec_mod = @fec_mod                    
                                 WHERE IdStockRes =@IdStockRes 
                                 AND IdBodega = @IdBodega "

            Dim rowsAffected As Integer = 0

            Using cmd As New SqlCommand(sp, lConnection, ltransaction) With {.CommandType = CommandType.Text}

                cmd.Parameters.Add(New SqlParameter("@IdStockRes", oBeStock_res.IdStockRes))
                cmd.Parameters.Add(New SqlParameter("@user_mod", oBeStock_res.User_mod))
                cmd.Parameters.Add(New SqlParameter("@fec_mod", oBeStock_res.Fec_mod))
                cmd.Parameters.Add(New SqlParameter("@IdBodega", oBeStock_res.IdBodega))
                cmd.Parameters.Add(New SqlParameter("@estado", oBeStock_res.Estado))

                rowsAffected = cmd.ExecuteNonQuery()

            End Using

            Actualizar_Estado_Pickeado = rowsAffected

        Catch ex As Exception
            Throw ex
        End Try

