                                        Throw New Exception("ERROR_202310021321: El producto seleccionado no tiene presentación por defecto conocida y el escenario requiere producto con presentación.")
                                    End If

                                Else
                                    Throw New Exception("ERROR_202310021315: El estado de producto definido en la configuración de la interface no es válido ( se busca config. IdProducto buen estado).")
                                End If

                            Else
                                Throw New Exception("ERROR_202310021315: La configuración de la interface no está definida y los valores son necesarios para las pruebas automatizadas.")
                            End If

                        Else
                            Throw New Exception("ERROR_202310021310: El código para el caso de uso no es válido.")
                        End If

                    Else
                        Throw New Exception("ERROR_202310021300: La base de datos no se pudo limpiar.")
                    End If

                Else
                    Throw New Exception("ERROR_202310021312: El código para el caso de uso no es válido.")
                End If

                'Fin de preparación del inventario.
                lTransaction.Commit() : lConnection.Close()

            End If

        Catch ex As Exception
            If Not lTransaction Is Nothing Then lTransaction.Rollback()
            Throw ex
        Finally
            If lConnection.State = ConnectionState.Open Then lConnection.Close()
        End Try

