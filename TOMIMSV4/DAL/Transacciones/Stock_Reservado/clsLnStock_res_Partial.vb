                Using lTransaction As SqlTransaction = lConnection.BeginTransaction(IsolationLevel.ReadUncommitted)

                    Dim lStockReservado As New List(Of clsBeVW_stock_res)
                    lStockReservado = Get_All_By_IdPedidoEnc(pIdPedidoEnc, lConnection, lTransaction)

                    If Not lStockReservado Is Nothing Then

                        If lStockReservado.Count > 0 Then

                            Dim vIdMaxIdLogLiberacion As Integer = clsLnTrans_log_pedido_liberacion.MaxID(lConnection, lTransaction) + 1

                            For Each Sr In lStockReservado

                                Dim Betrans_log_pedido_liberacion As New clsBeTrans_log_pedido_liberacion
                                Betrans_log_pedido_liberacion.IdLogLiberacionStock = vIdMaxIdLogLiberacion
                                Betrans_log_pedido_liberacion.IdUsuario = IdUsuario
                                Betrans_log_pedido_liberacion.Fecha = Now
                                Betrans_log_pedido_liberacion.IdPedidoEnc = pIdPedidoEnc
                                Betrans_log_pedido_liberacion.IdPedidoDet = Sr.IdPedidoDet
                                Betrans_log_pedido_liberacion.Referencia = Referencia
                                Betrans_log_pedido_liberacion.Codigo_Producto = Sr.Codigo_Producto
                                Betrans_log_pedido_liberacion.Lote = Sr.Lote
                                Betrans_log_pedido_liberacion.Lic_Plate = Sr.Lic_plate
                                Betrans_log_pedido_liberacion.Fecha_Vence = Sr.Fecha_Vence
                                Betrans_log_pedido_liberacion.Observacion = Observacion
                                clsLnTrans_log_pedido_liberacion.Insertar(Betrans_log_pedido_liberacion,
                                                                          lConnection,
                                                                          lTransaction)
                                vIdMaxIdLogLiberacion += 1

                            Next

                        End If

                    End If

                    'Elimina el stock reservado
                    Dim vSQLDelete As String = " Delete from stock_res Where(IdPedido = @IdPedidoEnc)"
                    Dim cmd As New SqlCommand(vSQLDelete, lConnection, lTransaction) With {.CommandType = CommandType.Text}
                    cmd.Parameters.Add(New SqlParameter("@IDPEDIDOENC", pIdPedidoEnc))
                    Eliminar_Stock_Res_By_IdPedidoEnc = (cmd.ExecuteNonQuery() > 0)

                    lTransaction.Commit()

                End Using

                lConnection.Close()

            End Using


        Catch ex As Exception
            Dim vMsgError As String = String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message)
            clsLnLog_error_wms.Agregar_Error(vMsgError)
            Throw ex
        End Try

    End Function


