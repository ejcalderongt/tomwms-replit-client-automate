    Private Sub grdIzq_CellEndEdit(sender As Object, e As DataGridViewCellEventArgs) Handles grdIzq.CellEndEdit

        Dim os, ns As String

        If e.ColumnIndex <> 1 Then Return

        Try
            os = grdIzq.Rows(e.RowIndex).Cells(1).Value : os = UCase(os)
            ns = Parse_String(os)
            grdIzq.Rows(e.RowIndex).Cells(1).Value = ns
            If os <> ns Then MsgBox("Nombre ajustado al formato requerido.")
        Catch ex As Exception
            MsgBox(ex.Message)
        End Try

    End Sub

