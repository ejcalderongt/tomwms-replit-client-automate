    Private Sub Actualizar_Grid()

        Try

            ' This line of code is generated by Data Source Configuration Wizard
            Bodega_sectorTableAdapter1.Fill(DetTramoByBodega1.bodega_sector, IdBodega)


        Catch ex As Exception
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message),
    Text,
    MessageBoxButtons.OK,
    MessageBoxIcon.Error)
        End Try

    End Sub

    Private Sub Carga_Registros()

        grdIzq.Rows.Clear()
        grdDer.Rows.Clear()

        Try

            listBeEstructuraTramos = clsLnEstructura_tramo.Get_All_By_IdSector(IdSector, AP.IdBodega)

            For Each t As clsBeEstructura_tramo In listBeEstructuraTramos

                If t.Horizontal Then
                    If t.Orientacion = 1 Then
                        grdIzq.Rows.Add(t.IdTramo,
                                        t.Descripcion,
                                        t.Largo,
                                        t.Ancho,
                                        t.Margen_izquierdo,
                                        t.Margen_superior,
                                        t.Sistema,
                                        t.Horizontal,
                                        t.Orden_Descendente)

                    Else
                        grdDer.Rows.Add(t.IdTramo,
                                        t.Descripcion,
                                        t.Largo,
                                        t.Ancho,
                                        t.Margen_izquierdo,
                                        t.Margen_superior,
                                        t.Sistema,
                                        t.Horizontal,
                                        t.Orden_Descendente)
                    End If
                Else
                    If t.Orientacion = 0 Then
                        grdIzq.Rows.Add(t.IdTramo,
                                        t.Descripcion,
                                        t.Largo,
                                        t.Ancho,
                                        t.Margen_izquierdo,
                                        t.Margen_superior,
                                        t.Sistema,
                                        t.Horizontal,
                                        t.Orden_Descendente)
                    Else
                        grdDer.Rows.Add(t.IdTramo,
                                        t.Descripcion,
                                        t.Largo,
                                        t.Ancho,
                                        t.Margen_izquierdo,
                                        t.Margen_superior,
                                        t.Sistema,
                                        t.Horizontal,
                                        t.Orden_Descendente)
                    End If
                End If

            Next

        Catch ex As Exception
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message),
                        Text,
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Error)
        End Try

    End Sub

    Private Function Guardar_Tramos() As Boolean

        Dim vEliminarTramo As Boolean = False

        Try

            If XtraMessageBox.Show("Se sugiere eliminar el detalle si modificó (márgenes, tamaño, etc), ¿Eliminar detalle?", Text,
                        MessageBoxButtons.YesNo,
                        MessageBoxIcon.Error) = vbYes Then
                vEliminarTramo = True
            End If

            Return clsLnEstructura_Tramo.Procesa_Batch(IdSector, listBeEstructuraTramos, vEliminarTramo)

        Catch ex As Exception
            MsgBox(ex.Message)
        End Try

    End Function

    Private Function Datos_Validos() As Boolean

        Dim IdTramo, MaxId As Integer
        Dim Codigo, Nombre As String
        Dim largo, ancho, m_izq, m_sup As Double


        listBeEstructuraTramos.Clear()

        grdIzq.EndEdit() : grdDer.EndEdit()

        MaxId = clsLnEstructura_tramo.MaxID()

        For vI = 0 To grdIzq.Rows.Count - 2

            Try

                Codigo = grdIzq.Rows(vI).Cells(0).Value

                Try
                    IdTramo = Codigo
                    If (IdTramo = 0) Then Throw New Exception
                Catch ex As Exception
                    MaxId += 1 : IdTramo = MaxId
                End Try

                Nombre = grdIzq.Rows(vI).Cells(1).Value : If Nombre = "" Then Throw New Exception

                largo = grdIzq.Rows(vI).Cells(2).Value : If largo < 0 Then Throw New Exception
                ancho = grdIzq.Rows(vI).Cells(3).Value : If ancho < 0 Then Throw New Exception
                m_izq = grdIzq.Rows(vI).Cells(4).Value : If m_izq < 0 Then Throw New Exception
                m_sup = grdIzq.Rows(vI).Cells(5).Value : If m_sup < 0 Then Throw New Exception

                BeEstructura_tramo = clsLnEstructura_tramo.Crear_Default(AP.UsuarioAp.IdUsuario)

                BeEstructura_tramo.IdArea = BeSector.IdArea
                BeEstructura_tramo.IdSector = IdSector
                BeEstructura_tramo.IdTramo = IdTramo
                BeEstructura_tramo.Descripcion = Nombre

                BeEstructura_tramo.Largo = largo
                BeEstructura_tramo.Ancho = ancho
                BeEstructura_tramo.Margen_izquierdo = m_izq
                BeEstructura_tramo.Margen_superior = m_sup

                BeEstructura_tramo.Codigo = IdTramo
                BeEstructura_tramo.Indice_x = vI + 1
                BeEstructura_tramo.IdBodega = AP.IdBodega
                BeEstructura_tramo.Sistema = grdIzq.Rows(vI).Cells(6).Value
                BeEstructura_tramo.Horizontal = grdIzq.Rows(vI).Cells(7).Value
                BeEstructura_tramo.Orden_Descendente = grdIzq.Rows(vI).Cells(8).Value

                BeEstructura_tramo.Orientacion = IIf(BeEstructura_tramo.Horizontal, 1, 0)

                listBeEstructuraTramos.Add(BeEstructura_tramo)

            Catch ex As Exception

                grdIzq.Focus()
                grdIzq.ClearSelection()
                grdIzq.Rows(vI).Selected = True
                grdIzq.FirstDisplayedScrollingRowIndex = vI

                MsgBox("Panel izquierdo , linea " & vI + 1 & " : datos incorrectos")

                Return False

            End Try
        Next

        For vI = 0 To grdDer.Rows.Count - 2
            Try

                Codigo = grdDer.Rows(vI).Cells(0).Value

                Try
                    IdTramo = Codigo
                    If (IdTramo = 0) Then Throw New Exception
                Catch ex As Exception
                    MaxId += 1 : IdTramo = MaxId
                End Try

                Nombre = grdDer.Rows(vI).Cells(1).Value : If Nombre = "" Then Throw New Exception

                largo = grdDer.Rows(vI).Cells(2).Value : If largo < 0 Then Throw New Exception
                ancho = grdDer.Rows(vI).Cells(3).Value : If ancho < 0 Then Throw New Exception
                m_izq = grdDer.Rows(vI).Cells(4).Value : If m_izq < 0 Then Throw New Exception
                m_sup = grdDer.Rows(vI).Cells(5).Value : If m_sup < 0 Then Throw New Exception

                BeEstructura_tramo = clsLnEstructura_tramo.Crear_Default(AP.UsuarioAp.IdUsuario)

                BeEstructura_tramo.IdArea = BeSector.IdArea
                BeEstructura_tramo.IdSector = IdSector
                BeEstructura_tramo.IdTramo = IdTramo
                BeEstructura_tramo.Descripcion = Nombre

                BeEstructura_tramo.Largo = largo
                BeEstructura_tramo.Ancho = ancho
                BeEstructura_tramo.Margen_izquierdo = m_izq
                BeEstructura_tramo.Margen_superior = m_sup

                BeEstructura_tramo.Codigo = IdTramo
                BeEstructura_tramo.Indice_x = vI + 1
                BeEstructura_tramo.IdBodega = AP.IdBodega
                BeEstructura_tramo.Sistema = grdDer.Rows(vI).Cells(6).Value
                BeEstructura_tramo.Horizontal = grdDer.Rows(vI).Cells(7).Value
                BeEstructura_tramo.Orden_Descendente = grdDer.Rows(vI).Cells(8).Value

                BeEstructura_tramo.Orientacion = IIf(BeEstructura_tramo.Horizontal, 0, 1)

                listBeEstructuraTramos.Add(BeEstructura_tramo)

            Catch ex As Exception

                grdDer.Focus()
                grdDer.ClearSelection()
                grdDer.Rows(vI).Selected = True
                grdDer.FirstDisplayedScrollingRowIndex = vI

                MsgBox("Panel derecho , linea " & vI + 1 & " : datos incorrectos")

                Return False

            End Try
        Next

        Return True

    End Function

#End Region

#Region " Eventos "

    Private Sub mnuActualizar_ItemClick(sender As Object, e As DevExpress.XtraBars.ItemClickEventArgs) Handles mnuActualizar.ItemClick

        mnuActualizar.Enabled = False
        If Datos_Validos() Then
            If Guardar_Tramos() Then
                XtraMessageBox.Show("Datos guardados correctamente", Text, MessageBoxButtons.OK, MessageBoxIcon.Information)
                Close()
            End If
        End If
        mnuActualizar.Enabled = True
    End Sub

    Private Sub grdIzq_KeyDown(sender As Object, e As KeyEventArgs) Handles grdIzq.KeyDown

        Dim ri As Integer

        If e.KeyCode = Keys.V And e.Control Then
            Paste_Izq() : Return
        End If

        If e.KeyCode = Keys.Insert Then
            Try
                ri = grdIzq.CurrentRow.Index
                grdIzq.Rows.Insert(ri)
            Catch ex As Exception
                grdIzq.Rows.Add()
            End Try
            Return
        End If

        If e.KeyCode = Keys.Delete Then
            Try
                ri = grdIzq.CurrentRow.Index
                grdIzq.Rows.RemoveAt(ri)
            Catch ex As Exception
            End Try
            Return
        End If

    End Sub

    Private Sub grdDer_KeyDown(sender As Object, e As KeyEventArgs) Handles grdDer.KeyDown

        Dim ri As Integer

        If e.KeyCode = Keys.V And e.Control Then
            Paste_Der() : Return
        End If

        If e.KeyCode = Keys.Insert Then
            Try
                ri = grdDer.CurrentRow.Index
                grdDer.Rows.Insert(ri)
            Catch ex As Exception
                grdDer.Rows.Add()
            End Try
            Return
        End If

        If e.KeyCode = Keys.Delete Then
            Try
                ri = grdDer.CurrentRow.Index
                grdDer.Rows.RemoveAt(ri)
            Catch ex As Exception
            End Try
            Return
        End If

    End Sub

