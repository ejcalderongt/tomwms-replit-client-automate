    End Sub

    Private Sub btnInsIzq_Click(sender As Object, e As EventArgs) Handles btnInsIzq.Click

        Dim ri As Integer

        Try

            If Not grdIzq.CurrentRow Is Nothing Then
                ri = grdIzq.CurrentRow.Index
                grdIzq.Rows.Insert(ri)
            Else
                XtraMessageBox.Show("Error: valide datos",
                                        Text,
                                        MessageBoxButtons.OK,
                                        MessageBoxIcon.Error)
            End If

        Catch ex As Exception
            grdIzq.Rows.Add()
        End Try

    End Sub

    Private Sub btnBorIzq_Click(sender As Object, e As EventArgs) Handles btnBorIzq.Click

        Dim ri As Integer

        Try

            If AP.IdBodega = AP.IdBodegaAnterior Then

                ri = grdIzq.CurrentRow.Index
                grdIzq.Rows.RemoveAt(ri)

            Else

                If XtraMessageBox.Show(String.Format("¿Está seguro de borrar el tramo {0}?", grdIzq.CurrentRow.Cells(1).Value), Text, MessageBoxButtons.YesNo, MessageBoxIcon.Question) = DialogResult.Yes Then

                    If XtraMessageBox.Show("¿Está totalmente seguro?", Text, MessageBoxButtons.YesNo, MessageBoxIcon.Question) = DialogResult.Yes Then

                        ri = grdIzq.CurrentRow.Index
                        grdIzq.Rows.RemoveAt(ri)

                    End If

                End If

            End If


        Catch ex As Exception
            Dim vMsgError As String = ex.Message
            clsLnLog_error_wms.Agregar_Error(vMsgError)
        End Try

    End Sub

    Private Sub btnLimpiarIzq_Click(sender As Object, e As EventArgs) Handles btnLimpiarIzq.Click

        If AP.IdBodega = AP.IdBodegaAnterior Then

            If MessageBox.Show("Borrar todos los registros", "", MessageBoxButtons.YesNo) = DialogResult.Yes Then grdIzq.Rows.Clear()

        Else

            If XtraMessageBox.Show("¿Está seguro de borrar todos los tramos?", Text, MessageBoxButtons.YesNo, MessageBoxIcon.Question) = DialogResult.Yes Then

                If XtraMessageBox.Show("¿Está totalmente seguro?", Text, MessageBoxButtons.YesNo, MessageBoxIcon.Question) = DialogResult.Yes Then

                    grdIzq.Rows.Clear()

                End If

            End If

        End If

    End Sub

