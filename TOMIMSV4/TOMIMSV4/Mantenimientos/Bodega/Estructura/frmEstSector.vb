#Region " Aux "

    Private Sub Paste_Izq()

        Dim vArr() As String
        Dim vRow() As String
        Dim vI, vII, vCC, vR, vRL, vRows As Integer

        grdIzq.SuspendLayout()

        Try

            vArr = Clipboard.GetText().Split(Environment.NewLine)

            vR = grdIzq.Rows.Count

            vRows = vArr.Length
            vRow = vArr(0).Split(vbTab)
            grdIzq.Rows.Add(vRows)

            For vI = 0 To vArr.Length - 1

                If vArr(vI) <> "" Then

                    vRow = vArr(vI).Split(vbTab) : vCC = 0
                    vRL = vRow.Length : If vRL > 5 Then vRL = 5

                    grdIzq.Item(vCC, 0).Value = ""

                    For vII = 0 To vRL - 1
                        grdIzq.Item(vCC + 1, vR).Value = vRow(vII).TrimStart
                        vCC = vCC + 1
                    Next

                    vR = vR + 1

                End If

            Next

        Catch ex As Exception
            Dim vMsgError As String = ex.Message
            clsLnLog_error_wms.Agregar_Error(vMsgError)
        End Try

        For vI = grdIzq.Rows.Count - 1 To 0 Step -1
            Try
                If grdIzq.Rows(vI).Cells(1).Value = "" Then grdIzq.Rows.RemoveAt(vI)
            Catch ex As Exception
            End Try
        Next

        grdIzq.ResumeLayout()

    End Sub

    Private Sub Paste_Der()

        Dim vArr() As String
        Dim vRow() As String
        Dim vI, vII, vCC, vR, vRL, vRows As Integer

        grdDer.SuspendLayout()

        Try

            vArr = Clipboard.GetText().Split(Environment.NewLine)
            vR = grdDer.Rows.Count

            vRows = vArr.Length
            vRow = vArr(0).Split(vbTab)
            grdDer.Rows.Add(vRows)

            For vI = 0 To vArr.Length - 1

                If vArr(vI) <> "" Then

                    vRow = vArr(vI).Split(vbTab) : vCC = 0
                    vRL = vRow.Length : If vRL > 5 Then vRL = 5

                    grdDer.Item(vCC, 0).Value = ""

                    For vII = 0 To vRow.Length - 1
                        grdDer.Item(vCC + 1, vR).Value = vRow(vII).TrimStart
                        vCC = vCC + 1
                    Next

                    vR = vR + 1

                End If

            Next

        Catch ex As Exception
            Dim vMsgError As String = ex.Message
            clsLnLog_error_wms.Agregar_Error(vMsgError)
        End Try

        For vI = grdDer.Rows.Count - 1 To 0 Step -1
            Try
                If grdDer.Rows(vI).Cells(1).Value = "" Then grdDer.Rows.RemoveAt(vI)
            Catch ex As Exception
            End Try
        Next

        grdDer.ResumeLayout()

    End Sub

    Private Function Parse_String(ByVal ss As String) As String

        Dim s1, s2 As String
        Dim sp() As String

        Try

            sp = ss.Split("-")
            s1 = sp(0) : s1 = Mid(s1, 1, 3)
            s2 = sp(1) : s2 = Mid(s2, 1, 2)

        Catch ex As Exception
            s1 = Mid(ss, 1, 3) : s2 = ""
        End Try

        Return UCase(s1 & "-" & s2)

    End Function

