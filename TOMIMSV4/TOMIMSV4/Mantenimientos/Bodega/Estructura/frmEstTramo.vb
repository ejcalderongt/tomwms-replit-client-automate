#Region " Aux "

    Private Function Datos_Validos() As Boolean
        Dim i As Integer
        Dim vCant, vTamano, vOffset As Integer
        Dim vAncho, vAlto, vLargo As Double
        Dim vPalet As Boolean
        Dim vOrient As Integer

        If grdData.Rows.Count = 0 Then Return True

        grdData.EndEdit()
        grdData.Update()

        For i = 0 To grdData.Rows.Count - 1

            Try
                vCant = grdData.Rows(i).Cells(2).Value
                If vCant < 1 Then Throw New Exception
            Catch ex As Exception
                MsgBox("Linea " & i + 1 & " Valor incorrecto : Cant")
            End Try

            Try
                vTamano = grdData.Rows(i).Cells(3).Value
                ' If vTamano < 1 Then Throw New Exception
            Catch ex As Exception
                MsgBox("Linea " & i + 1 & " Valor incorrecto : Tamano")
            End Try

            Try
                vOffset = grdData.Rows(i).Cells(4).Value
                If vOffset < 0 Then Throw New Exception
            Catch ex As Exception
                MsgBox("Linea " & i + 1 & " Valor incorrecto : Offset")
            End Try

            Try
                vAncho = grdData.Rows(i).Cells(5).Value
                'If vAncho < 0.1 Then Throw New Exception
            Catch ex As Exception
                MsgBox("Linea " & i + 1 & " Valor incorrecto : Ancho")
            End Try

            Try
                vAlto = grdData.Rows(i).Cells(6).Value
                'If vAlto < 0.1 Then Throw New Exception
            Catch ex As Exception
                MsgBox("Linea " & i + 1 & " Valor incorrecto : Alto")
            End Try

            Try
                vLargo = grdData.Rows(i).Cells(7).Value
                'If vLargo < 0.1 Then Throw New Exception
            Catch ex As Exception
                MsgBox("Linea " & i + 1 & " Valor incorrecto : Largo")
            End Try

            Try
                vPalet = grdData.Rows(i).Cells(8).Value
            Catch ex As Exception
                MsgBox("Linea " & i + 1 & " Valor incorrecto : Palet")
            End Try

            Try
                vOrient = grdData.Rows(i).Cells(9).Value
                If vOrient < 1 Then Throw New Exception
                If vOrient > 4 Then Throw New Exception
            Catch ex As Exception
                MsgBox("Linea " & i + 1 & " Valor incorrecto : Orient")
            End Try

        Next

        Return True
    End Function

    Private Sub Llena_Datos()

        Dim i As Integer
        Dim vID, vCant, vTamano, vOffset As Integer
        Dim vAncho, vAlto, vLargo As Double
        Dim vPalet As Boolean
        Dim vOrient As Integer
        Dim vOrdenDesc As Boolean

        Try

            items = New List(Of clsBeEstructura_grupo)

            If grdData.Rows.Count = 0 Then Return

            For i = 0 To grdData.Rows.Count - 1

                vID = grdData.Rows(i).Cells(0).Value
                vCant = grdData.Rows(i).Cells(2).Value
                vTamano = grdData.Rows(i).Cells(3).Value
                vOffset = grdData.Rows(i).Cells(4).Value
                vAncho = grdData.Rows(i).Cells(5).Value
                vAlto = grdData.Rows(i).Cells(6).Value
                vLargo = grdData.Rows(i).Cells(7).Value
                vPalet = grdData.Rows(i).Cells(8).Value
                vOrient = grdData.Rows(i).Cells(9).Value
                vOrdenDesc = rbOrdenDescendente.Checked

                item = New clsBeEstructura_grupo
                item.IdGrupo = vID
                item.IdTramo = IdTramo
                item.IdBodega = IdBodega
                item.Pos = i + 1
                item.Cant = vCant
                item.Tamano = vTamano
                item.Offset = vOffset
                item.Ancho = vAncho
                item.Alto = vAlto
                item.Largo = vLargo
                item.Palet = IIf(vPalet, 1, 0)
                item.Orient = vOrient
                item.Agrupacion = IIf(rdbVertical.Checked, 1, 0)
                item.Orden_Descendente = vOrdenDesc
                items.Add(item)

            Next

        Catch ex As Exception
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message),
                        Text,
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Error)
        End Try

    End Sub

    Private Sub actualizaPosicion()
        Dim i As Integer

        If grdData.Rows.Count = 0 Then Return

        For i = 0 To grdData.Rows.Count - 1
            grdData.Rows(i).Cells(1).Value = i + 1
        Next
    End Sub

    Private BeEstructuraTramo As New clsBeEstructura_tramo

    Private Sub frmEstTramo_Shown(sender As Object, e As EventArgs) Handles Me.Shown

        SplashScreenManager.ShowForm(Me, GetType(WaitForm), True, True, False)
        SplashScreenManager.Default.SetWaitFormDescription("Listando tramos...")

        Try

            lblUbic.Text = ""

            '#EJC20211110: Heredar la descendencia del padre...
            BeEstructuraTramo = clsLnEstructura_Tramo.Get_Single_By_IdBodega_And_IdTramo(IdBodega, IdTramo)

            If Not BeEstructuraTramo Is Nothing Then
                rbOrdenAscendente.Checked = Not BeEstructuraTramo.Orden_Descendente
                rbOrdenDescendente.Checked = BeEstructuraTramo.Orden_Descendente
                rbOrdenAscendente.Enabled = False : rbOrdenDescendente.Enabled = False
            End If


            Cargar_Grupos()

            rdbVertical.Checked = True

            If (items.Count > 0) Then
                If items(0).Agrupacion <> 1 Then rdbHorizontal.Checked = True
            End If

            If rdbVertical.Checked Then
                If Not grdData.Columns("ColCant") Is Nothing Then
                    grdData.Columns("ColCant").HeaderText = "Columnas"
                    grdData.Columns("ColTamaño").HeaderText = "Niveles"
                End If
            End If

            Actualizar_Grid()

        Catch ex As Exception
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message),
                        Text,
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Error)
        Finally
            SplashScreenManager.CloseForm(False)
        End Try

    End Sub

#End Region

End Class