    Private Sub RadioButton2_CheckedChanged(sender As Object, e As EventArgs) Handles rdbHorizontal.CheckedChanged

        Try

            If Not grdData.Columns("ColCant") Is Nothing Then
                grdData.Columns("ColCant").HeaderText = "Filas"
