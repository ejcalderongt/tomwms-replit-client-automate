Imports System.Reflection
Imports DevExpress.XtraEditors
Imports DevExpress.XtraSplashScreen

Public Class frmEstTramo

    Sub New()
        InitializeComponent()
    End Sub

    Public Property IdTramo As Integer = 0
    Public Property IdBodega As Integer = 0

    Private items As New List(Of clsBeEstructura_grupo)
    Private item As New clsBeEstructura_grupo

    Private ii, scant, stamano, soffset, srow, scol As Integer
    Private changed As Boolean

    Private Sub Actualizar_Grid()

        Try

            ' This line of code is generated by Data Source Configuration Wizard
            Bodega_tramoTableAdapter1.Fill(DetTramoByBodega1.bodega_tramo, IdBodega)

        Catch ex As Exception
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message),
                        Text,
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Error)
        End Try

    End Sub

#Region " Metodos principales "

    Private Sub Cargar_Grupos()

        Dim pp As Integer = 0

        grdData.Rows.Clear() : changed = True

        Try

            items = clsLnEstructura_grupo.Get_All_By_IdBodega_And_IdTramo(IdBodega, IdTramo)

            For Each it As clsBeEstructura_grupo In items

                pp += 1
                grdData.Rows.Add(it.IdGrupo,
                                 pp,
                                 it.Cant,
                                 it.Tamano,
                                 it.Offset,
                                 it.Ancho,
                                 it.Alto,
                                 it.Largo,
                                 it.Palet = 1,
                                 it.Orient)

            Next

            changed = False

        Catch ex As Exception
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message),
                        Text,
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Error)
        End Try

    End Sub

    Private Sub dibujaEstructura()

        lblUbic.Text = ""

        If Not Datos_Validos() Then Return

        grdStruct.SuspendLayout()
        grdStruct.Rows.Clear()

        For ii = grdStruct.Columns.Count - 1 To 1 Step -1
            grdStruct.Columns.RemoveAt(ii)
        Next

        If rdbVertical.Checked Then
            estructuraVertical()
        Else
            estructuraHorizontal()
        End If

        grdStruct.ResumeLayout()
        grdStruct.ClearSelection()

    End Sub

    Private Sub estructuraVertical()

        Dim rc, rcv, cpos, rpos, j, jj, ori, omul, tpos As Integer

        If grdData.Rows.Count = 0 Then Return

        tpos = 0

        Try

            For ii = 0 To grdData.Rows.Count - 1
                rcv = CInt(grdData.Rows(ii).Cells(3).Value) + CInt(grdData.Rows(ii).Cells(4).Value)
                If (rcv > rc) Then rc = rcv
            Next

            rcv = 0
            For ii = rc To 1 Step -1
                grdStruct.Rows.Add(1)
                grdStruct.Rows(rcv).Cells(0).Value = ii
                grdStruct.Rows(rcv).Cells(0).Style.BackColor = Color.Gainsboro
                rcv += 1
            Next

            cpos = 1
            For ii = 0 To grdData.Rows.Count - 1

                scant = grdData.Rows(ii).Cells(2).Value
                stamano = grdData.Rows(ii).Cells(3).Value
                soffset = grdData.Rows(ii).Cells(4).Value
                scol = 25 * grdData.Rows(ii).Cells(5).Value
                srow = 25 * grdData.Rows(ii).Cells(6).Value

                ori = grdData.Rows(ii).Cells(9).Value
                Select Case ori
                    Case 1 : omul = 1
                    Case 2 : omul = 2
                    Case 3 : omul = 2
                    Case 4 : omul = 4
                End Select
                tpos = tpos + scant * stamano * omul

                For j = 1 To scant

                    grdStruct.Columns.Add(cpos, cpos) : grdStruct.Columns(cpos).Width = 25

                    For jj = soffset To soffset + stamano - 1
                        rpos = rc - jj - 1

                        grdStruct.Rows(rpos).Cells(cpos).Style.BackColor = Color.White
                        grdStruct.Rows(rpos).Height = srow
                        grdStruct.Columns(cpos).Width = scol
                    Next

                    cpos += 1
                Next

            Next
        Catch ex As Exception
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message),
                        Text,
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Error)
        End Try

        lblUbic.Text = "Total ubicaciones : " & tpos

    End Sub

    Private Sub estructuraHorizontal()

        Dim cc, ccv, rc, rcv, rpos, ori, omul, tpos As Integer

        If grdData.Rows.Count = 0 Then Return

        tpos = 0

        Try

            For ii = 0 To grdData.Rows.Count - 1
                rc = rc + grdData.Rows(ii).Cells(2).Value
                ccv = CInt(grdData.Rows(ii).Cells(3).Value) + CInt(grdData.Rows(ii).Cells(4).Value)
                If (ccv > cc) Then cc = ccv
            Next

            For ii = 1 To cc
                grdStruct.Columns.Add(ii, ii) : grdStruct.Columns(ii).Width = 25
            Next

            rcv = 0
            For ii = rc To 1 Step -1
                grdStruct.Rows.Add(1)
                grdStruct.Rows(rcv).Cells(0).Value = ii
                grdStruct.Rows(rcv).Cells(0).Style.BackColor = Color.Gainsboro
                rcv += 1
            Next

            rpos = rc - 1
            For ii = 0 To grdData.Rows.Count - 1

                scant = grdData.Rows(ii).Cells(2).Value
                stamano = grdData.Rows(ii).Cells(3).Value
                soffset = grdData.Rows(ii).Cells(4).Value
                scol = 25 * grdData.Rows(ii).Cells(5).Value
                srow = 25 * grdData.Rows(ii).Cells(6).Value

                ori = grdData.Rows(ii).Cells(9).Value
                Select Case ori
                    Case 1 : omul = 1
                    Case 2 : omul = 2
                    Case 3 : omul = 2
                    Case 4 : omul = 4
                End Select
                tpos = tpos + scant * stamano * omul

                For j = 1 To scant

                    For jj = soffset To soffset + stamano - 1
                        grdStruct.Rows(rpos).Cells(jj + 1).Style.BackColor = Color.White
                        grdStruct.Rows(rpos).Height = srow
                        grdStruct.Columns(jj + 1).Width = scol
                    Next

                    rpos -= 1
                Next

            Next

        Catch ex As Exception
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message),
                        Text,
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Error)
        End Try

        lblUbic.Text = "Total ubicaciones : " & tpos

    End Sub

    Private Sub intercambiaLineas(r1 As Integer, r2 As Integer)

        Dim i As Integer
        Dim val As Object

        Try

            For i = 0 To 9
                val = grdData.Rows(r1).Cells(i).Value
                grdData.Rows(r1).Cells(i).Value = grdData.Rows(r2).Cells(i).Value
                grdData.Rows(r2).Cells(i).Value = val
            Next

        Catch ex As Exception
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message),
                        Text,
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Error)
        End Try

    End Sub

#End Region

#Region " Eventos "

    Private Sub btnGuardar_ItemClick(sender As Object, e As DevExpress.XtraBars.ItemClickEventArgs) Handles btnGuardar.ItemClick

        btnGuardar.Enabled = False

        If Not Datos_Validos() Then
            btnGuardar.Enabled = True
            Return
        End If

        Try

            Llena_Datos()

            If Not items Is Nothing Then

                If items.Count > 0 Then

                    If clsLnEstructura_grupo.Insertar_Batch(IdTramo, IdBodega, items) Then
                        XtraMessageBox.Show("Datos guardados correctamente", Text, MessageBoxButtons.OK, MessageBoxIcon.Information)
                        Cargar_Grupos()
                        Close()
                    End If

                    btnGuardar.Enabled = True

                Else

                    XtraMessageBox.Show("La lista está un poco vacía",
                      Text,
                      MessageBoxButtons.OK,
                      MessageBoxIcon.Error)

                End If

            Else

                XtraMessageBox.Show("No se obtuvieron los datos con g",
                        Text,
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Error)

            End If


        Catch ex As Exception
            btnGuardar.Enabled = True
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message),
                        Text,
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Error)
        End Try

    End Sub

    Private Sub btnAgregar_ItemClick(sender As Object, e As DevExpress.XtraBars.ItemClickEventArgs) Handles btnAgregar.ItemClick

        Dim rp As Integer

        rp = grdData.Rows.Count
        btnAgregar.Enabled = False

        Try

            item = New clsBeEstructura_grupo
            item.IdGrupo = clsLnEstructura_grupo.MaxID() + 1
            item.IdTramo = IdTramo
            item.IdBodega = IdBodega
            item.Pos = rp + 1
            item.Cant = 1
            item.Tamano = 1
            item.Offset = 0
            item.Ancho = 1
            item.Alto = 1
            item.Largo = 1
            item.Palet = 0
            item.Orient = 1
            item.Agrupacion = IIf(rdbVertical.Checked, 1, 0)
            item.Orden_Descendente = rbOrdenDescendente.Checked

            clsLnEstructura_grupo.Insertar(item)

            grdData.Rows.Insert(rp,
                                item.IdGrupo,
                                item.Pos,
                                item.Cant,
                                item.Tamano,
                                item.Offset,
                                item.Ancho,
                                item.Alto,
                                item.Largo,
                                item.Palet = 1,
                                item.Orient,
                                item.Orden_Descendente)

            btnAgregar.Enabled = True

        Catch ex As Exception
            btnAgregar.Enabled = True
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message),
                        Text,
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Error)
        End Try

        Try
            grdData.Rows(rp).Cells(1).Selected = True
        Catch ex As Exception
            Dim vMsgError As String = ex.Message
            clsLnLog_error_wms.Agregar_Error(vMsgError)
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message),
                        Text,
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Error)

        End Try

        actualizaPosicion() : changed = True

    End Sub

    Private Sub btnBorrar_ItemClick(sender As Object, e As DevExpress.XtraBars.ItemClickEventArgs) Handles btnBorrar.ItemClick

        Dim rp As Integer
        btnBorrar.Enabled = False

        Try

            If AP.IdBodega <> AP.IdBodegaAnterior Then

                If XtraMessageBox.Show("¿Está seguro de borrar la linea?", Text, MessageBoxButtons.YesNo, MessageBoxIcon.Question) = DialogResult.Yes Then

                    If XtraMessageBox.Show("¿Está totalmente seguro?", Text, MessageBoxButtons.YesNo, MessageBoxIcon.Question) = DialogResult.Yes Then

                        rp = grdData.SelectedCells(0).RowIndex

                        clsLnEstructura_grupo.Eliminar(grdData.Rows(rp).Cells(0).Value)

                        grdData.Rows.RemoveAt(rp)


                    End If

                End If

            Else

                rp = grdData.SelectedCells(0).RowIndex

                If MessageBox.Show("Borrar linea " & rp + 1, "", MessageBoxButtons.YesNo) <> DialogResult.Yes Then Return

                clsLnEstructura_grupo.Eliminar(grdData.Rows(rp).Cells(0).Value)
                grdData.Rows.RemoveAt(rp)

            End If

            btnBorrar.Enabled = True

        Catch ex As Exception
            btnBorrar.Enabled = True
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message),
                        Text,
                        MessageBoxButtons.OK,
                        MessageBoxIcon.Error)
        End Try

        Try
            grdData.Rows(0).Cells(1).Selected = True
        Catch ex As Exception
            Dim vMsgError As String = ex.Message
            clsLnLog_error_wms.Agregar_Error(vMsgError)
        End Try

        actualizaPosicion() : changed = True

    End Sub

    Private Sub btnArriba_ItemClick(sender As Object, e As DevExpress.XtraBars.ItemClickEventArgs) Handles btnArriba.ItemClick

        Dim rp, rpp As Integer

        Try
            rp = grdData.SelectedCells(0).RowIndex : rpp = rp - 1 : If rp = 0 Then Return
            intercambiaLineas(rp, rpp)

            grdData.Rows(rpp).Cells(1).Selected = True
            grdData.FirstDisplayedScrollingRowIndex = rpp

            actualizaPosicion() : changed = True
        Catch ex As Exception
            Dim vMsgError As String = ex.Message
            clsLnLog_error_wms.Agregar_Error(vMsgError)
        End Try
    End Sub

    Private Sub btnAbajo_ItemClick(sender As Object, e As DevExpress.XtraBars.ItemClickEventArgs) Handles btnAbajo.ItemClick
        Dim rp, rpp As Integer

        Try
            rp = grdData.SelectedCells(0).RowIndex : rpp = rp + 1 : If rp = grdData.Rows.Count - 1 Then Return
            intercambiaLineas(rp, rpp)

            grdData.Rows(rpp).Cells(1).Selected = True
            grdData.FirstDisplayedScrollingRowIndex = rpp

            actualizaPosicion() : changed = True
        Catch ex As Exception
            Dim vMsgError As String = ex.Message
            clsLnLog_error_wms.Agregar_Error(vMsgError)
        End Try
    End Sub

    Private Sub btnRefresh_ItemClick(sender As Object, e As DevExpress.XtraBars.ItemClickEventArgs) Handles btnRefresh.ItemClick
        btnRefresh.Enabled = False
        dibujaEstructura()
        btnRefresh.Enabled = True
    End Sub

    Private Sub SimpleButton1_Click(sender As Object, e As EventArgs) Handles SimpleButton1.Click
        rdbVertical.Checked = True
    End Sub

    Private Sub SimpleButton2_Click(sender As Object, e As EventArgs) Handles SimpleButton2.Click
