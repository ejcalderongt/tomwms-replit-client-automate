 #Region "Control peso, ejc."

+    Private Function ObtenerResumenPesoImpreso() As Decimal
+        Try
+            If pTransOC_Det Is Nothing Then Return 0D
+
+            Using cn As New SqlConnection(clsLnConexion.GetConexionString())
+                cn.Open()
+
+                Using cmd As New SqlCommand("
+                    SELECT ISNULL(SUM(ISNULL(Pallet_Weight,0)),0)
+                    FROM trans_oc_det_lote
+                    WHERE IdOrdenCompraEnc = @Enc
+                      AND IdOrdenCompraDet = @Det", cn)
+
+                    cmd.Parameters.AddWithValue("@Enc", pTransOC_Enc.IdOrdenCompraEnc)
+                    cmd.Parameters.AddWithValue("@Det", pTransOC_Det.IdOrdenCompraDet)
+
+                    Dim result = cmd.ExecuteScalar()
+                    If result IsNot Nothing Then
+                        Return CDec(result)
+                    End If
+                End Using
+            End Using
+
+        Catch
+        End Try
+
+        Return 0D
+    End Function
+
     Private Function ObtenerPesoTotalLinea() As Decimal
         If pTransOC_Det Is Nothing Then Return 0D

         Return CDec(pTransOC_Det.Peso_Neto)
     End Function

