    Private Sub Actualizar_Grid_Estado()

        Try

            If pListBEEstado IsNot Nothing AndAlso pListBEEstado.Count > 0 Then

                Dim DT As New DataTable("EstadoProducto")
                DT.Columns.Add(("Seleccion"), GetType(Boolean))
                DT.Columns.Add(("idEstado"), GetType(Integer))
                DT.Columns.Add(("Nombre"), GetType(String))
                DT.Columns.Add(("Propietario"), GetType(String))

                For Each Obj As clsBeProducto_estado_selection In pListBEEstado
                    DT.Rows.Add(Obj.Seleccion, Obj.idEstado, Obj.Nombre, Obj.Propietario.Nombre_comercial)
                Next

                DgridEstadoProducto.DataSource = DT

            End If

            If grdvEstadoProducto.Columns.Count > 0 Then
                grdvEstadoProducto.LayoutChanged()
            End If

            Dim item As GridColumnSummaryItem = New GridColumnSummaryItem(SummaryItemType.Count, "Seleccion", "Estados={0}")

            If grdvEstadoProducto.Columns("Seleccion").Summary.Count = 0 Then
                grdvEstadoProducto.Columns("Seleccion").Summary.Add(item)
            End If

        Catch ex As Exception
            Dim vMsgError As String = ex.Message
            clsLnLog_error_wms.Agregar_Error(vMsgError)
            Throw ex
        End Try

    End Sub

