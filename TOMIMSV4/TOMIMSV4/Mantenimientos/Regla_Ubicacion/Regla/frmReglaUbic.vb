    Private Sub XtraTabControl1_SelectedPageChanged(sender As Object, e As DevExpress.XtraTab.TabPageChangedEventArgs) Handles XtraTabControl1.SelectedPageChanged

        Try

            Dim selectedTab As DevExpress.XtraTab.XtraTabPage = e.Page
            Dim lPropietarios As New List(Of Integer)
            Dim lTiposRotacion As New List(Of Integer)
            Dim lIndicesRotacion As New List(Of Integer)

            If selectedTab Is tabTiposProductos Then

                ' Iterar sobre las filas del GridView
                For i As Integer = 0 To grdvPropietario.RowCount - 1
                    ' Verificar si la fila está seleccionada (checkbox marcado)
                    Dim isChecked As Boolean = Convert.ToBoolean(grdvPropietario.GetRowCellValue(i, "Seleccion"))

                    If isChecked Then
                        ' Obtener el valor del IdPropietario
                        Dim idPropietario As Integer = Convert.ToInt32(grdvPropietario.GetRowCellValue(i, "IdPropietarioBodega"))
                        ' Agregar a la lista
                        lPropietarios.Add(idPropietario)
                    End If
                Next

                ' Iterar sobre las filas del GridView
                For i As Integer = 0 To grdvTipoRotacion.RowCount - 1
                    ' Verificar si la fila está seleccionada (checkbox marcado)
                    Dim isChecked As Boolean = Convert.ToBoolean(grdvTipoRotacion.GetRowCellValue(i, "Activo"))

                    If isChecked Then
                        ' Obtener el valor del IdPropietario
                        Dim IdTipoRotacion As Integer = Convert.ToInt32(grdvTipoRotacion.GetRowCellValue(i, "IdTipoRotacion"))
                        ' Agregar a la lista
                        lTiposRotacion.Add(IdTipoRotacion)
                    End If
                Next

                ' Iterar sobre las filas del GridView
                For i As Integer = 0 To grdvIndiceRotacion.RowCount - 1
                    ' Verificar si la fila está seleccionada (checkbox marcado)
                    Dim isChecked As Boolean = Convert.ToBoolean(grdvIndiceRotacion.GetRowCellValue(i, "Activo"))

                    If isChecked Then
                        ' Obtener el valor del IdPropietario
                        Dim IdIndiceRotacion As Integer = Convert.ToInt32(grdvIndiceRotacion.GetRowCellValue(i, "IdIndiceRotacion"))
                        ' Agregar a la lista
                        lIndicesRotacion.Add(IdIndiceRotacion)
                    End If
                Next

                pListBETipo = clsLnProducto_tipo.Get_All_For_Seleccion_By_Filtros(lPropietarios, lTiposRotacion, lIndicesRotacion)

                Listar_Tipo()

            End If

        Catch ex As Exception
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message), Text, MessageBoxButtons.OK, MessageBoxIcon.Error)
        End Try

    End Sub

End Class