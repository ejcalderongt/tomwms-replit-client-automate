    Private Sub Listar_Propietarios()

        Try

            If Not pBeReglaUbicEnc.listDetRegla_Ubic_Det_Prop Is Nothing Then

                Dim lindex As Integer = -1
                Dim lindex1 As Integer = -1

                For Each Prop As clsBeRegla_ubic_det_prop In pBeReglaUbicEnc.listDetRegla_Ubic_Det_Prop

                    lindex = pBeReglaUbicEnc.listDetRegla_Ubic_Det_Prop.FindIndex(Function(x) x.IdPropietarioBodega = Prop.IdPropietarioBodega)
                    lindex1 = pListBEPropietarioSeleccion.FindIndex(Function(x) x.IdPropietarioBodega = Prop.IdPropietarioBodega)

                    If lindex <> -1 AndAlso lindex1 <> -1 Then
                        pListBEPropietarioSeleccion(lindex1).Seleccion = pBeReglaUbicEnc.listDetRegla_Ubic_Det_Prop(lindex).Activo
                    End If

                Next

                Actualizar_Grid_Propietarios()

            End If

        Catch ex As Exception
            XtraMessageBox.Show(ex.Message, Text, MessageBoxButtons.OK, MessageBoxIcon.Exclamation)
        End Try


    End Sub

    Private Sub Listar_TipoRotacion()

        Try

            If Not pBeReglaUbicEnc.listDetRegla_Ubic_Det_Tr Is Nothing Then

                Dim lindex As Integer = -1
                Dim lindex1 As Integer = -1

                For Each Tr As clsBeRegla_ubic_det_tr In pBeReglaUbicEnc.listDetRegla_Ubic_Det_Tr

                    lindex = pBeReglaUbicEnc.listDetRegla_Ubic_Det_Tr.FindIndex(Function(x) x.IdTipoRotacion = Tr.IdTipoRotacion)
                    lindex1 = pListBETipoRSeleccion.FindIndex(Function(x) x.IdTipoRotacion = Tr.IdTipoRotacion)

                    If lindex <> -1 AndAlso lindex1 <> -1 Then
                        pListBETipoRSeleccion(lindex1).Activo = pBeReglaUbicEnc.listDetRegla_Ubic_Det_Tr(lindex).Activo
