    Private Sub frmTipoTarima_Load(sender As Object, e As EventArgs) Handles MyBase.Load


        Try

            Top = 50
            Left = (Screen.PrimaryScreen.WorkingArea.Width - Width) / 2
            grdvPropietario.FocusRectStyle = Views.Grid.DrawFocusRectStyle.RowFullFocus
            grdvTipoRotacion.FocusRectStyle = Views.Grid.DrawFocusRectStyle.RowFullFocus
            grdvIndiceRotacion.FocusRectStyle = Views.Grid.DrawFocusRectStyle.RowFullFocus
            grdvEstadoProducto.FocusRectStyle = Views.Grid.DrawFocusRectStyle.RowFullFocus
            grdvTipoProducto.FocusRectStyle = Views.Grid.DrawFocusRectStyle.RowFullFocus
            grdvPresentation.FocusRectStyle = Views.Grid.DrawFocusRectStyle.RowFullFocus

            SplashScreenManager.ShowForm(Me, GetType(WaitForm), True, True, False)
            SplashScreenManager.Default.SetWaitFormCaption("Cargando...")

            Get_Listas()

            SplashScreenManager.ShowForm(Me, GetType(WaitForm), True, True, False)
            SplashScreenManager.Default.SetWaitFormCaption("Actualizando Grid...")

            Actualizar_Grid_Propietarios()
            Actualizar_Grid_TipoRotacion()
            Actualizar_Grid_IndiceRotacion()
            Actualizar_Grid_Estado()
            Actualizar_Grid_Tipo()
            Actualizar_Grid_Pres()

            pListObjT = clsBD.GetLongitudByTabla("regla_ubic_enc")

            Select Case Modo

                Case TipoTrans.Nuevo

                    pBeReglaUbicEnc = New clsBeRegla_ubic_enc With
                        {.IdReglaUbicacionEnc = clsLnRegla_ubic_enc.MaxID(),
                        .IsNew = True}

                    lblCodigo.Text = pBeReglaUbicEnc.IdReglaUbicacionEnc

                    User_agrTextEdit.Text = AP.UsuarioAp.IdUsuario
                    Fec_agrDateEdit.Text = Now
                    User_modTextEdit.Text = AP.UsuarioAp.IdUsuario
                    Fec_modDateEdit.Text = Now

                    If OpcionesMenu IsNot Nothing Then
                        mnuGuardar.Enabled = OpcionesMenu.Modificar
                    End If

                    mnuActualizar.Enabled = False
                    mnuEliminar.Enabled = False

                    RibbonPageGroup4.Visible = False

                Case TipoTrans.Editar

                    clsLnRegla_ubic_enc.GetSingleWithDetails(pBeReglaUbicEnc)

                    Listar_Detalle()

                    lblCodigo.Text = pBeReglaUbicEnc.IdReglaUbicacionEnc
                    txtNombre.Text = pBeReglaUbicEnc.Nombre
                    chkActivo.Checked = pBeReglaUbicEnc.Activo

                    User_agrTextEdit.Text = pBeReglaUbicEnc.User_agr
                    Fec_agrDateEdit.Text = pBeReglaUbicEnc.Fec_agr
                    User_modTextEdit.Text = pBeReglaUbicEnc.User_mod
                    Fec_modDateEdit.Text = pBeReglaUbicEnc.Fec_mod

                    mnuGuardar.Enabled = False

                    If OpcionesMenu IsNot Nothing Then
                        mnuActualizar.Enabled = OpcionesMenu.Modificar
                        mnuEliminar.Enabled = OpcionesMenu.Eliminar
                    End If

                    RibbonPageGroup4.Visible = True

            End Select

            Dim ritem As RepositoryItemCheckEdit = TryCast(grdvPropietario.Columns("Seleccion").RealColumnEdit, RepositoryItemCheckEdit)
            AddHandler ritem.CheckedChanged, AddressOf ritemPropietario_CheckedChanged

            Dim ritem1 As RepositoryItemCheckEdit = TryCast(grdvTipoRotacion.Columns("Activo").RealColumnEdit, RepositoryItemCheckEdit)
            AddHandler ritem1.CheckedChanged, AddressOf ritemTipoR_CheckedChanged

            Dim ritem2 As RepositoryItemCheckEdit = TryCast(grdvIndiceRotacion.Columns("Activo").RealColumnEdit, RepositoryItemCheckEdit)
            AddHandler ritem2.CheckedChanged, AddressOf ritemIndiceR_CheckedChanged

            Dim ritem3 As RepositoryItemCheckEdit = TryCast(grdvEstadoProducto.Columns("Seleccion").RealColumnEdit, RepositoryItemCheckEdit)
            AddHandler ritem3.CheckedChanged, AddressOf ritemEstadoProd_CheckedChanged

            Dim ritem4 As RepositoryItemCheckEdit = TryCast(grdvTipoProducto.Columns("Seleccion").RealColumnEdit, RepositoryItemCheckEdit)
            AddHandler ritem4.CheckedChanged, AddressOf ritemTipoProd_CheckedChanged

            Dim ritem5 As RepositoryItemCheckEdit = TryCast(grdvPresentation.Columns("Seleccion").RealColumnEdit, RepositoryItemCheckEdit)
            AddHandler ritem5.CheckedChanged, AddressOf ritemPresentation_CheckedChanged

            Focus()
            txtNombre.Focus()

        Catch ex As Exception

            SplashScreenManager.CloseForm(False)

            XtraMessageBox.Show(ex.Message,
            Text,
            MessageBoxButtons.OK,
            MessageBoxIcon.Error)

            Dim vMsgError As String = ex.Message
            clsLnLog_error_wms.Agregar_Error(vMsgError)

        Finally
            SplashScreenManager.CloseForm(False)
        End Try

    End Sub

    Private Sub ritemPropietario_CheckedChanged(sender As Object, e As EventArgs)

        Try

            Dim ritem As CheckEdit = TryCast(sender, CheckEdit)

            If Not ritem Is Nothing Then

                Dim Dr As New clsBePropietarioBodegaSeleccion
                Dr = grdvPropietario.GetFocusedRow
                Dim lIndex As Integer = -1

                lIndex = pBeReglaUbicEnc.listDetRegla_Ubic_Det_Prop.FindIndex(Function(b) b.IdPropietarioBodega = Dr.IdPropietarioBodega)

                If lIndex > -1 Then

                    If ritem.Checked Then
                        pBeReglaUbicEnc.listDetRegla_Ubic_Det_Prop(lIndex).Activo = True
                    Else
                        pBeReglaUbicEnc.listDetRegla_Ubic_Det_Prop(lIndex).Activo = False
                    End If

                    pBeReglaUbicEnc.listDetRegla_Ubic_Det_Prop(lIndex).User_mod = AP.UsuarioAp.IdUsuario
                    pBeReglaUbicEnc.listDetRegla_Ubic_Det_Prop(lIndex).Fec_mod = Now

                Else

                    Dim Obj As New clsBeRegla_ubic_det_prop() With {.IdPropietarioBodega = Dr.IdPropietarioBodega, .User_agr = AP.UsuarioAp.IdUsuario, .Fec_agr = Now, .User_mod = AP.UsuarioAp.IdUsuario, .Fec_mod = Now, .Activo = True, .IsNew = True}
                    pBeReglaUbicEnc.listDetRegla_Ubic_Det_Prop.Add(Obj)

                End If

            End If

        Catch ex As Exception

            XtraMessageBox.Show(ex.Message,
            Text,
            MessageBoxButtons.OK,
            MessageBoxIcon.Error)

            Dim vMsgError As String = ex.Message
            clsLnLog_error_wms.Agregar_Error(vMsgError)

        End Try

    End Sub

