    Private Function Guardar_Regla() As Boolean

        Guardar_Regla = False

        Try

            If pBeReglaUbicEnc.IsNew Then

                pBeReglaUbicEnc.IdReglaUbicacionEnc = clsLnRegla_ubic_enc.MaxID
                pBeReglaUbicEnc.IdEmpresa = AP.IdEmpresa
                pBeReglaUbicEnc.IdBodega = AP.IdBodega

            End If

            pBeReglaUbicEnc.User_agr = AP.UsuarioAp.IdUsuario
            pBeReglaUbicEnc.Fec_agr = Now
            pBeReglaUbicEnc.User_mod = AP.UsuarioAp.IdUsuario
            pBeReglaUbicEnc.Fec_mod = Now

            pBeReglaUbicEnc.Nombre = txtNombre.Text.Trim()
            pBeReglaUbicEnc.Activo = chkActivo.Checked

            Guardar_Regla = clsLnRegla_ubic_enc.Guardar_Regla(pBeReglaUbicEnc)

        Catch ex As Exception
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message), Text, MessageBoxButtons.OK, MessageBoxIcon.Error)
        End Try

    End Function

    Private Sub mnuGuardar_ItemClick(sender As Object, e As DevExpress.XtraBars.ItemClickEventArgs) Handles mnuGuardar.ItemClick

        Try

            mnuGuardar.Enabled = False

            If Datos_Correctos() Then
                If XtraMessageBox.Show("¿Guardar?", Text, MessageBoxButtons.YesNo, MessageBoxIcon.Question) = DialogResult.Yes Then
                    If Guardar_Regla() Then
                        XtraMessageBox.Show("Se guardó el registro", Text, MessageBoxButtons.OK, MessageBoxIcon.Information)
                        If InvokeListarReglas IsNot Nothing Then
                            InvokeListarReglas.Invoke()
                        End If
                        RibbonPageGroup4.Visible = True
                    End If
                End If
            End If

        Catch ex As Exception
            mnuGuardar.Enabled = True
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message), Text, MessageBoxButtons.OK, MessageBoxIcon.Error)
        End Try

    End Sub

    Private Sub mnuActualizar_ItemClick(sender As Object, e As DevExpress.XtraBars.ItemClickEventArgs) Handles mnuActualizar.ItemClick

        mnuActualizar.Enabled = False

        Try

            If Datos_Correctos() Then
                If XtraMessageBox.Show("¿Guardar registro?", Text, MessageBoxButtons.YesNo, MessageBoxIcon.Question) = DialogResult.Yes Then
                    If Guardar_Regla() Then
                        Botones_Modo_Edicion()
                        XtraMessageBox.Show("Se actualizó el registro", Text, MessageBoxButtons.OK, MessageBoxIcon.Information)
                        If InvokeListarReglas IsNot Nothing Then
                            InvokeListarReglas.Invoke()
                        End If
                        PanelControl1.Visible = True
                        Close()
                    End If
                End If
            End If

        Catch ex As Exception
            XtraMessageBox.Show(String.Format("{0} {1}", MethodBase.GetCurrentMethod.Name(), ex.Message), Text, MessageBoxButtons.OK, MessageBoxIcon.Error)
        End Try

        mnuActualizar.Enabled = True
    End Sub

    Private Sub Botones_Modo_Edicion()

        mnuGuardar.Enabled = False
        mnuActualizar.Enabled = True
        mnuEliminar.Enabled = True

        RibbonPageGroup4.Visible = True

    End Sub
