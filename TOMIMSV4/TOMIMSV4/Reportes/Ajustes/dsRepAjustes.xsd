	trans_ajuste_det.talla_origen,trans_ajuste_det.talla_destino,
						 trans_ajuste_det.color_origen, trans_ajuste_det.color_destino
FROM            trans_ajuste_det INNER JOIN
                         ajuste_tipo ON trans_ajuste_det.idtipoajuste = ajuste_tipo.idtipoajuste INNER JOIN
                         ajuste_motivo ON trans_ajuste_det.idmotivoajuste = ajuste_motivo.idmotivoajuste</CommandText>
