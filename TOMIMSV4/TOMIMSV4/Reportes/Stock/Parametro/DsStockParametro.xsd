                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>
                      SELECT sp.IdStock AS StockId, sp.valor_texto AS 'Valor Texto', sp.valor_numerico AS 'Valor Numérico', sp.valor_fecha AS 'Valor Fecha',
                      sp.valor_logico AS 'Valor Lógico'
                      FROM stock_parametro AS sp
