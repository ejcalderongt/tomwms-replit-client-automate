                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT        res.IdPicking, res.IdPedido, p.codigo, p.nombre, pp.nombre AS Presentación, pp.factor AS Factor, pe.nombre AS Estado, um.Nombre AS UMBas, 
                         pr.nombre_comercial AS Propietario, bu.descripcion AS Ubicación, s.cantidad / pp.factor AS Cantidad, res.IdPedidoDet, res.IdUbicacion, 
                         res.cantidad AS CantidadReservada, trans_picking_ubic.cantidad_recibida AS Cantidad_Pickeada, trans_picking_ubic.cantidad_verificada AS Cantidad_Verificada, 
                          s.cantidad AS Cantidad_Stock, res.fecha_ingreso, res.fecha_vence
FROM            stock_res AS res INNER JOIN
                         propietario_bodega AS prb ON res.IdPropietarioBodega = prb.IdPropietarioBodega INNER JOIN
                         producto_bodega AS pb ON pb.IdProductoBodega = res.IdProductoBodega INNER JOIN
                         producto AS p ON pb.IdProducto = p.IdProducto AND prb.IdPropietario = p.IdPropietario INNER JOIN
                         bodega_ubicacion AS bu ON res.IdUbicacion = bu.IdUbicacion INNER JOIN
                         producto_estado AS pe ON res.IdProductoEstado = pe.IdEstado AND prb.IdPropietario = pe.IdPropietario INNER JOIN
                         unidad_medida AS um ON res.IdUnidadMedida = um.IdUnidadMedida AND prb.IdPropietario = um.IdPropietario INNER JOIN
                         stock AS s ON res.IdStock = s.IdStock INNER JOIN
                         propietarios AS pr ON prb.IdPropietario = pr.IdPropietario INNER JOIN
                         trans_picking_ubic ON bu.IdUbicacion = trans_picking_ubic.IdUbicacion INNER JOIN
                         trans_picking_det ON trans_picking_ubic.IdPickingDet = trans_picking_det.IdPickingDet AND res.IdPedidoDet = trans_picking_det.IdPedidoDet LEFT OUTER JOIN
                         producto_presentacion AS pp ON res.IdPresentacion = pp.IdPresentacion AND p.IdProducto = pp.IdProducto
WHERE        (res.IdPedido = @IdPedido)</CommandText>
                    <Parameters>
                      <Parameter AllowDbNull="true" AutogeneratedName="IdPedido" ColumnName="IdPedido" DataSourceName="IMS4MB_QA.dbo.stock_res" DataTypeServer="bigint" DbType="Int64" Direction="Input" ParameterName="@IdPedido" Precision="0" ProviderType="BigInt" Scale="0" Size="8" SourceColumn="IdPedido" SourceColumnNullMapping="false" SourceVersion="Current" />
