@page "/Login"
@model TOMWMSUX.Pages.Login.LoginModel
@{
    ViewData["Title"] = "Login";
}

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.08);
        border-radius: 15px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        max-width: 420px;
        margin: 10vh auto;
        padding: 35px 40px;
        color: #1d1d1d;
        text-align: center;
        font-family: 'Segoe UI', sans-serif;
        background-image: linear-gradient(to bottom right, #ffffffcc, #f0f0f066);
    }

        .glass-card h2 {
            font-size: 28px;
            margin-bottom: 25px;
            color: #1d1d1d;
        }

    .alert-danger {
        margin-top: 15px;
    }
</style>

<div class="glass-card" style="max-width:400px;margin:auto;margin-top:10vh;">
    <h2 class="text-center mb-4">TOMWMS</h2>

    <form method="post" id="loginForm">
        <div id="usernameBox"></div>
        <br />
        <div id="passwordBox"></div>
        <br />
        <div id="submitBtnBox"></div>
    </form>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger mt-3">@Model.ErrorMessage</div>
    }
</div>

@section Scripts {
    <script src="~/js/login.js"></script>
}