@{
    ViewData["Title"] = "Reporte de ocupación de bodega";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="page-rpt-ocupacion-bodega">
    <nav class="navbar navbar-expand-lg navbar-light bg-light border mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" href="#"><i class="fas fa-warehouse"></i> Ocupación de bodega</a>
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#nav-rpt-ocupacion-bdega"
                    aria-controls="nav-rpt-ocupacion-bdega"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="nav-rpt-ocupacion-bdega">
                <form class="d-flex" v-on:submit.prevent="buscar">
                    <select class="form-select ms-sm-2" v-model="bform.bodega" required v-bind:disabled="buscandoBodegas">
                        <option value="">{{ buscandoBodegas ? 'Cargando bodegas...' : 'Bodega' }}</option>
                        <option v-bind:value="b.codigo" v-bind:key="b.codigo" v-for="b in cat.bodegas">{{ b.nombre }}</option>
                    </select>
                    <button class="btn btn-info my-2 my-sm-0 ms-sm-2" type="submit" v-bind:disabled="buscando" title="Buscar">
                        <i class="fas fa-search"></i>
                    </button>
                </form>
                @*<ul class="navbar-nav ms-auto">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle"
                           href="#"
                           id="navbarDropdown"
                           role="button"
                           data-toggle="dropdown"
                           aria-haspopup="true"
                           aria-expanded="false"
                           v-bind:class="{disabled: buscando}"
                           title="Descargar">
                            <i class="fas fa-download"></i> Descargar
                        </a>
                        <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbardropdown">
                            <a class="dropdown-item" href="#" v-on:click.prevent="exportarExcel">
                                <i class="fas fa-file-excel"></i> Excel
                            </a>
                            <a class="dropdown-item" href="#" v-on:click.prevent="exportarPDF">
                                <i class="fas fa-file-pdf"></i> PDF
                            </a>
                        </div>
                    </li>
                </ul>*@
            </div>
        </div>
    </nav>

    <div class="text-center" v-show="buscando">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Buscando...</span>
        </div>
        <br />
        Buscando datos...
    </div>
    <div class="row g-0" v-show="!buscando && lista.length > 0">
        <div class="card col-sm-12 col-lg-6 rounded-0">
            <div class="card-body w-100 m-0 px-2 py-0">
                <div id="indicador" style="width: 100%; height: 45vh;"></div>
            </div>
        </div>

        <div class="card col-sm-12 col-lg-6 rounded-0">
            <div class="card-body w-100 m-0 px-2 py-0">
                <div id="grafica" style="width: 100%; height: 45vh;"></div>
            </div>
        </div>
    </div>
    <div class="row g-0 text-center" v-show="msgInicio">
        <div class="alert alert-warning" role="alert">
            Seleccione una bodega y presione el boton buscar (<i class="fas fa-search"></i>)
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/Js/Mixins/Reporte.js" asp-append-version="true"></script>
    <script src="~/Js/Pages/Reportes/OcupacionBodega.js" asp-append-version="true"></script>
}
