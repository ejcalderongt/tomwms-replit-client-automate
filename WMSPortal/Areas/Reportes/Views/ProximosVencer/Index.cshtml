
@{
    ViewData["Title"] = "Reporte de productos proximos a vencer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="page-rpt-existencias">
    <nav class="navbar navbar-expand-lg navbar-light bg-light border mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">
                <i class="fas fa-calendar-minus"></i> Productos proximos a vencer
            </a>
            <button class="navbar-toggler"
                    type="button"
                    data-toggle="collapse"
                    data-target="#nav-proximos-a-vencer"
                    aria-controls="nav-proximos-a-vencer"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse" id="nav-proximos-a-vencer">
                <form class="d-flex" v-on:submit.prevent="buscar">
                    <select class="form-select ms-sm-2" v-model="bform.bodega" v-bind:disabled="buscandoBodegas" title="Filtro para bodega">
                        <option value="">{{ buscandoBodegas ? 'Cargando bodegas...' : 'Bodega' }}</option>
                        <option v-bind:value="b.codigo" v-bind:key="b.codigo" v-for="b in cat.bodegas">{{ b.nombre }}</option>
                    </select>

                    <div>
                        <input v-model="bform.dias_tolerancia"
                            type="range"
                            class="form-range ms-sm-2"
                            min="0"
                            max="720"
                            step="1"
                            required
                            style="width: 300px;"
                            placeholder="Dias tolerancia"
                            title="Filtro para días de tolerancia">
                        <div class="text-center" style="display: block; position: relative; margin-top: -10px !important; width:100%;"> Días de tolerancia {{ bform.dias_tolerancia }}</div>
                    </div>

                    <button class="btn btn-info my-2 my-sm-0 ms-sm-2" type="submit" v-bind:disabled="buscando" title="Buscar">
                        <i class="fas fa-search"></i>
                    </button>
                </form>

                <ul class="navbar-nav ms-auto">

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle"
                           href="#"
                           id="navbarDropdown"
                           role="button"
                           data-toggle="dropdown"
                           aria-haspopup="true"
                           aria-expanded="false"
                           v-bind:class="{disabled: buscando}"
                           title="Descargar">
                            <i class="fas fa-download"></i> Descargar

                        </a>
                        <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                            <a class="dropdown-item" href="#" v-on:click.prevent="exportarExcel">
                                <i class="fas fa-file-excel"></i> Excel
                            </a>
                            <a class="dropdown-item" href="#" v-on:click.prevent="exportarPDF">
                                <i class="fas fa-file-pdf"></i> PDF
                            </a>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="text-center" v-show="buscando">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Buscando...</span>
        </div>
        <br />
        Buscando registros...
    </div>
    <div class="row g-0" v-if="!buscando">
        <h6><b>{{ lista.length }}</b> registros encontrados</h6>
    </div>
    <div id="grid-proximos-a-vencer" v-show="!buscando"></div>
</div>

@section Scripts {
    <script src="~/Js/Mixins/ReporteDev.js" asp-append-version="true"></script>
    <script src="~/Js/Pages/Reportes/ProximosVencer.js" asp-append-version="true"></script>
}
