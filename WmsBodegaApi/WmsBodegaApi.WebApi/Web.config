<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!--
      CST = mismo connection string que usa la DAL actual del WMS.
      La DAL lee: Configuration.ConfigurationManager.AppSettings("CST")
      Ejemplo:
        Server=52.41.114.122,1437;Database=TOMWMS_KILLIOS_PRD;User Id=...;Password=...;TrustServerCertificate=True;
      IMPORTANTE: en producción esta WebAPI debe correr en EC2 AWS, en la misma VPC del SQL Server.
                  Localmente para el POC podés apuntar al mismo servidor remoto, pero la idea de medir
                  performance solo aplica cuando la WebAPI vive al lado de la BD.
    -->
    <add key="CST" value="Server=PON_TU_SERVER;Database=TOMWMS_KILLIOS_PRD;User Id=sa;Password=PON_TU_PWD;TrustServerCertificate=True;Connection Timeout=15;" />
    <!-- Auth simple por API key (POC). En PRD usar Azure AD / IIS auth integrada. -->
    <add key="ApiKey" value="poc-bodega-key-cambiar" />
  </appSettings>
  <system.web>
    <compilation debug="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" maxRequestLength="51200" />
    <authentication mode="None" />
  </system.web>
  <system.webServer>
    
    <httpProtocol>
      <customHeaders>
        <add name="Access-Control-Allow-Origin" value="*" />
        <add name="Access-Control-Allow-Headers" value="Content-Type, X-API-Key" />
        <add name="Access-Control-Allow-Methods" value="GET, POST, PUT, DELETE, OPTIONS" />
      </customHeaders>
    </httpProtocol>
  <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <remove name="OPTIONSVerbHandler" />
      <remove name="TRACEVerbHandler" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0" path="*." verb="*" type="System.Web.Handlers.TransferRequestHandler" preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers></system.webServer>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
